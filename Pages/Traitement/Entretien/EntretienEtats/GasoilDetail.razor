@page "/et-gasoil-detail"
@attribute [Authorize]
@implements IDisposable
@if (IsLoaded)
{
    <Card_1 Title="CONSOMMATION GASOIL - DÉTAIL">

        <RadzenContent>
            <div class="grid-container no-border">
                <SfToolbar CssClass="btns">
                    <ToolbarItems>
                        <ToolbarItem Align="ItemAlign.Left">
                            <Template>
                                <SfMessage Severity="MessageSeverity.Info" Variant="MessageVariant.Outlined"><div style="text-transform: uppercase;">EXERCICE EN COURS: @DateTime.Today.Year.ToString()</div></SfMessage>
                            </Template>
                        </ToolbarItem>
                        <ToolbarItem Align="ItemAlign.Right" Type="ItemType.Input">
                            <Template>
                                <SfDatePicker Width="140px" TValue="DateTime ?" @bind-Value="date1" Placeholder="Date Début" ShowClearButton ShowTodayButton>
                                    <DatePickerEvents TValue="DateTime ?" ValueChange="@(args => LoadData())"> </DatePickerEvents>
                                </SfDatePicker>
                            </Template>
                        </ToolbarItem>
                        <ToolbarItem Align="ItemAlign.Right" Type="ItemType.Input">
                            <Template>
                                <SfDatePicker Width="140px" TValue="DateTime ?" @bind-Value="date2" Placeholder="Date Fin" ShowClearButton ShowTodayButton>
                                    <DatePickerEvents TValue="DateTime ?" ValueChange="@(args => LoadData())"> </DatePickerEvents>
                                </SfDatePicker>
                            </Template>
                        </ToolbarItem>
                    </ToolbarItems>
                </SfToolbar>

                <Card>
                    <div class="grid-80" style="zoom: @session.zoomLevel;">
                        <SfGrid EnableVirtualization Height="100%" DataSource="@(items)" Toolbar="@(new List<object>() { "Print", "ExcelExport", "Search" })" AllowSorting AllowFiltering AllowExcelExport>
                            <GridPageSettings PageSize="100" />
                            <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.CheckBox"></GridFilterSettings>
                            <GridAggregates>
                                <GridAggregate>
                                    <GridAggregateColumns>
                                        <GridAggregateColumn Field="@nameof(API_V_MATERIELENTRETIEN.Qte)" Type="AggregateType.Sum" Format="N2">
                                            <FooterTemplate>
                                                @{
                                                    var SumValue = (context as AggregateTemplateContext);
                                                    <div>@SumValue.Sum</div>
                                                }
                                            </FooterTemplate>
                                        </GridAggregateColumn>
                                        <GridAggregateColumn Field="@nameof(API_V_MATERIELENTRETIEN.Montant)" Type="AggregateType.Sum" Format="N2">
                                            <FooterTemplate>
                                                @{
                                                    var SumValue = (context as AggregateTemplateContext);
                                                    <div>@SumValue.Sum</div>
                                                }
                                            </FooterTemplate>
                                        </GridAggregateColumn>
                                        <GridAggregateColumn Field="@nameof(API_V_MATERIELENTRETIEN.Kilometrage)" Type="AggregateType.Sum" Format="N2">
                                            <FooterTemplate>
                                                @{
                                                    var SumValue = (context as AggregateTemplateContext);
                                                    <div>@SumValue.Sum</div>
                                                }
                                            </FooterTemplate>
                                        </GridAggregateColumn>
                                    </GridAggregateColumns>
                                </GridAggregate>
                            </GridAggregates>
                            <GridColumns>
                                <GridColumn Width="90" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" Field="@nameof(API_V_MATERIELENTRETIEN.Date)" HeaderText="Date" Format="dd/MM/yy" />
                                <GridColumn Width="100" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" Field="@nameof(API_V_MATERIELENTRETIEN.Piece)" HeaderText="Pièce" />
                                <GridColumn Width="120" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" Field="@nameof(API_V_MATERIELENTRETIEN.Immatricule)" HeaderText="Immatricule" />
                                <GridColumn Width="220" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" Field="@nameof(API_V_MATERIELENTRETIEN.Intitule)" HeaderText="Matériel" />
                                <GridColumn Width="250" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" Field="@nameof(API_V_MATERIELENTRETIEN.Nom)" HeaderText="Responsable" />
                                <GridColumn Width="120" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" Field="@nameof(API_V_MATERIELENTRETIEN.CA_Num)" HeaderText="Affaire" />
                                <GridColumn Width="100" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" Field="@nameof(API_V_MATERIELENTRETIEN.Qte)" HeaderText="Qté (L)" Format="N2" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" />
                                <GridColumn Width="120" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" Field="@nameof(API_V_MATERIELENTRETIEN.Montant)" HeaderText="Montant" Format="N2" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" />
                                <GridColumn Width="110" AllowFiltering="false" AllowSorting="false" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" HeaderText="PU Moyen" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right">
                                    <Template>
                                        @{
                                            var dt = (context as API_V_MATERIELENTRETIEN);
                                            <div style="text-align: right;">@((dt.Qte != null && dt.Qte > 0 ? dt.Montant / dt.Qte.Value : 0).ToString("N2"))</div>
                                        }
                                    </Template>
                                </GridColumn>
                                <GridColumn Width="120" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" Field="@nameof(API_V_MATERIELENTRETIEN.Kilometrage)" HeaderText="Kilométrage" Format="N2" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" />
                            </GridColumns>
                        </SfGrid>
                    </div>
                </Card>
            </div>
        </RadzenContent>
    </Card_1>
}
else
{
    <div class="center-screen">
        <Loading_1 />
    </div>
}

@code
{
    [CascadingParameter]
    public SessionDT session { get; set; } = new SessionDT();
    DB db = new DB();
    private List<API_V_MATERIELENTRETIEN> items = new List<API_V_MATERIELENTRETIEN>();
    DateTime? date1 = new DateTime(DateTime.Today.Year, 1, 1);
    DateTime? date2 = new DateTime(DateTime.Today.Year, 12, 31);
    bool IsLoaded = false;

    protected override async Task OnInitializedAsync()
    {
        db = session.db;
        GC.Collect();
        await Task.Delay(1);
        await LoadData();
        IsLoaded = true;
    }

    private async Task LoadData()
    {
        IsLoaded = false;
        await Task.Delay(300);
        items = db.API_V_MATERIELENTRETIEN
            .Where(a => a.Type == 0
                && ((date1 != null && a.Date >= date1) || date1 == null)
                && ((date2 != null && a.Date <= date2) || date2 == null))
            .OrderByDescending(a => a.Date)
            .ToList();
        IsLoaded = true;
        await Task.Delay(300);
    }

    public void Dispose()
    {
        items?.Clear();
        items = null;
    }
}
