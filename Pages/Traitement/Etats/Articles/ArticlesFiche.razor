                                                                <GridColumn AllowSorting="false" Width="72" Field="@nameof(ArticleMvtLigne.PuTtc)" HeaderText="PU.TTC" Format="### ### ##0.00;-### ### ##0.00;#" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
