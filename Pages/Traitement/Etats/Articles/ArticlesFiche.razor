@code {
    [CascadingParameter] 
    public SessionDT session { get; set; }
    DB db = new DB();

    [Parameter] 
    public int cbMarq { get; set; }
    private API_V_ARTICLE row { get; set; } = new API_V_ARTICLE();
    IEnumerable<P_UNITE> unites;
    List<F_ARTCLIENT> tarifs_clients = new List<F_ARTCLIENT>();
    List<F_ARTFOURNISS> tarifs_fournisseurs = new List<F_ARTFOURNISS>();
    List<F_ARTCLIENT> tarifs = new List<F_ARTCLIENT>();
    List<Items> suivistock = new List<Items>();
    List<Items> types = new List<Items>();
    List<Items> nomencalures = new List<Items>();
    IEnumerable<F_FAMILLE> familles;
    IEnumerable<F_DOCLIGNE> achats;
    IEnumerable<F_DOCLIGNE> ventes;
    Helpers helpers = new Helpers();
    DateTime? date1;
    DateTime? date2;
    bool IsLoaded = false;

    private const int MouvementStockTabIndex = 1;
    private int selectedTabIndex;
    private SfGrid<ArticleMvtLigne> mvtGrid;
    private List<ArticleMvtLigne> mvtLignes = new();
    private Dictionary<string, MvtDepotGroupTotal> mvtDepotGroupTotals = new(StringComparer.OrdinalIgnoreCase);
    private decimal mvtQteInitial;
    private List<F_DEPOT> depots = new();
    private DateTime? mvtDateDebut;
    private DateTime? mvtDateFin;
    private int? mvtDepot;
    private bool mvtLoading;
    private bool mvtLoaded;

    private int MvtMovementCount => mvtLignes.Count(x => !x.IsSoldeInitial);

    private string MvtSummaryLabel => mvtDateDebut.HasValue || mvtDateFin.HasValue || mvtDepot.HasValue
        ? $"{(mvtDateDebut.HasValue ? mvtDateDebut.Value.ToString("dd/MM/yyyy") : "…")} — {(mvtDateFin.HasValue ? mvtDateFin.Value.ToString("dd/MM/yyyy") : "…")}"
          + (mvtDepot.HasValue ? $" | {depots.FirstOrDefault(d => d.DE_No == mvtDepot)?.DE_Intitule ?? "Dépôt"}" : "")
        : "Toutes dates";
    private List<API_V_MARGE> items = new List<API_V_MARGE>();
    private List<API_V_MARGE> dt_mois = new List<API_V_MARGE>();
    private List<API_V_MARGE> dt_article = new List<API_V_MARGE>();
    private List<API_V_MARGE> dt_annee = new List<API_V_MARGE>();
    private List<string> annees = new List<string>();
    private async Task LoadData()
    {
        unites = db.P_UNITE.Where(a => (a.U_Intitule ?? "") != "").ToList();
        familles = db.F_FAMILLE.ToList();

        suivistock.Add(new Items { ShortId = 0, Name = "AUCUN" });
        suivistock.Add(new Items { ShortId = 1, Name = "SERIE" });
        suivistock.Add(new Items { ShortId = 2, Name = "CMUP" });
        suivistock.Add(new Items { ShortId = 3, Name = "FIFO" });
        suivistock.Add(new Items { ShortId = 4, Name = "LIFO" });
        suivistock.Add(new Items { ShortId = 5, Name = "LOT" });

        types.Add(new Items { ShortId = 0, Name = "STANDARD" });
        types.Add(new Items { ShortId = 1, Name = "GAMME" });
        types.Add(new Items { ShortId = 2, Name = "RESSOURCE UNITAIRE" });
        types.Add(new Items { ShortId = 3, Name = "RESSOURCE MULTIPLE" });

        nomencalures.Add(new Items { ShortId = 0, Name = "AUCUNE" });
        nomencalures.Add(new Items { ShortId = 1, Name = "FABRICATION" });
        nomencalures.Add(new Items { ShortId = 2, Name = "COMPOSE" });
        nomencalures.Add(new Items { ShortId = 3, Name = "COMPOSANT" });
        nomencalures.Add(new Items { ShortId = 4, Name = "ARTICLE LIE" });
        items = db.API_V_MARGE.Where(a => ((date1 != null && a.DO_Date >= date1) || date1 == null) && ((date2 != null && a.DO_Date <= date2) || date2 == null) && a.AR_Ref == row.AR_Ref).ToList();
        annees = items.OrderBy(a => a.Annee).Select(a => a.Annee).Distinct().ToList();
        dt_mois = items.Where(a => ((date1 != null && a.DO_Date >= date1) || date1 == null) && ((date2 != null && a.DO_Date <= date2) || date2 == null) && a.AR_Ref == row.AR_Ref).GroupBy(a => new { a.Mois })
     .Select(a => new API_V_MARGE
         {
             Mois = a.Key.Mois,
             DL_Qte = a.Sum(a => a.DL_Qte),
             DL_MontantHT = a.Sum(a => a.DL_MontantHT),
             DL_MontantTTC = a.Sum(a => a.DL_MontantTTC),
             CMUPCoutTotal = a.Sum(a => a.CMUPCoutTotal),
             CMUPMarge = a.Sum(a => a.CMUPMarge),
             CMUPMargeP = a.Sum(a => a.DL_MontantHT) != 0.0m ? a.Sum(a => a.CMUPMarge) / a.Sum(a => a.DL_MontantHT) : 0.0m
         }).OrderBy(a => a.Mois).Take(12).ToList();

        dt_annee = items.Where(a => ((date1 != null && a.DO_Date >= date1) || date1 == null) && ((date2 != null && a.DO_Date <= date2) || date2 == null) && a.AR_Ref == row.AR_Ref).GroupBy(a => new { a.Annee })
            .Select(a => new API_V_MARGE
            {
                    Annee = a.Key.Annee,
                DL_Qte = a.Sum(a => a.DL_Qte),
                DL_MontantHT = a.Sum(a => a.DL_MontantHT),
                DL_MontantTTC = a.Sum(a => a.DL_MontantTTC),
                CMUPCoutTotal = a.Sum(a => a.CMUPCoutTotal),
                CMUPMarge = a.Sum(a => a.CMUPMarge),
                CMUPMargeP = a.Sum(a => a.DL_MontantHT) != 0.0m ? a.Sum(a => a.CMUPMarge) / a.Sum(a => a.DL_MontantHT) : 0.0m
                }).OrderByDescending(a => a.Annee).Take(12).ToList();

        dt_article = items.Where(a => ((date1 != null && a.DO_Date >= date1) || date1 == null) && ((date2 != null && a.DO_Date <= date2) || date2 == null) && a.AR_Ref == row.AR_Ref).GroupBy(a => new { a.CT_Intitule, a.CT_Num })
       .Select(a => new API_V_MARGE
           {
               CT_Num = a.Key.CT_Num,
               CT_Intitule = a.Key.CT_Intitule,
               DL_Qte = a.Sum(a => a.DL_Qte),
               DL_MontantHT = a.Sum(a => a.DL_MontantHT),
               DL_MontantTTC = a.Sum(a => a.DL_MontantTTC),
               CMUPCoutTotal = a.Sum(a => a.CMUPCoutTotal),
               CMUPMarge = a.Sum(a => a.CMUPMarge),
               CMUPMargeP = a.Sum(a => a.DL_MontantHT) != 0.0m ? a.Sum(a => a.CMUPMarge) / a.Sum(a => a.DL_MontantHT) : 0.0m
           }).OrderByDescending(a => a.DL_MontantTTC).ToList();
    }


    private void OnTabSelecting(SelectingEventArgs args)
    {
        fn.DisableTabSelect(args);
        if (args.Cancel) return;
        if (args.SelectingIndex == MouvementStockTabIndex && !mvtLoaded)
            _ = LoadMouvementsStock();
    }

    private static DateTime MvtEffectiveDate(API_V_ARTICLEMVT a) =>
        a.DL_DateBL ?? a.DO_Date ?? DateTime.MinValue;

    private string MvtDepotLabel =>
        mvtDepot.HasValue
            ? depots.FirstOrDefault(d => d.DE_No == mvtDepot.Value)?.DE_Intitule ?? "Dépôt"
            : "Tous dépôts";

    private sealed class MvtDepotGroupTotal
    {
        public decimal SumMvt { get; set; }
        public decimal FinalQte { get; set; }
    }

    private async Task LoadMouvementsStock()
    {
        if (string.IsNullOrWhiteSpace(row?.AR_Ref))
        {
            mvtLignes = new();
            mvtDepotGroupTotals = new(StringComparer.OrdinalIgnoreCase);
            mvtQteInitial = 0m;
            mvtLoaded = true;
            return;
        }

        mvtLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var depotLabel = MvtDepotLabel;
            await Task.Run(() =>
            {
                var arRef = row.AR_Ref;
                IQueryable<API_V_ARTICLEMVT> BaseQuery()
                {
                    var q = db.API_V_ARTICLEMVT.AsNoTracking().Where(a => a.AR_Ref == arRef);
                    if (mvtDepot.HasValue)
                        q = q.Where(a => a.DE_No == mvtDepot.Value);
                    return q;
                }

                var runningByDepot = new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase);
                mvtQteInitial = 0m;
                if (mvtDateDebut.HasValue)
                {
                    var debut = mvtDateDebut.Value.Date;
                    foreach (var g in BaseQuery().AsEnumerable().Where(a => MvtEffectiveDate(a) < debut).GroupBy(a => a.DE_Intitule ?? ""))
                    {
                        runningByDepot[g.Key] = g.Sum(a => a.Mvt ?? 0m);
                        mvtQteInitial += runningByDepot[g.Key];
                    }
                }

                var periodQuery = BaseQuery().AsEnumerable();
                if (mvtDateDebut.HasValue)
                    periodQuery = periodQuery.Where(a => MvtEffectiveDate(a) >= mvtDateDebut.Value.Date);
                if (mvtDateFin.HasValue)
                {
                    var fin = mvtDateFin.Value.Date.AddDays(1).AddTicks(-1);
                    periodQuery = periodQuery.Where(a => MvtEffectiveDate(a) <= fin);
                }

                var chronologique = periodQuery
                    .OrderBy(MvtEffectiveDate)
                    .ThenBy(a => a.DO_Piece)
                    .ToList();

                var lignes = new List<ArticleMvtLigne>
                {
                    new()
                    {
                        IsSoldeInitial = true,
                        Qte = mvtQteInitial,
                        DE_Intitule = depotLabel,
                        DO_Piece = $"Solde initial — {depotLabel}"
                    }
                };

                var sumMvtByDepot = new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase);
                foreach (var m in chronologique)
                {
                    var depot = m.DE_Intitule ?? "";
                    if (!runningByDepot.ContainsKey(depot))
                        runningByDepot[depot] = 0m;
                    var mvt = m.Mvt ?? 0m;
                    runningByDepot[depot] += mvt;
                    sumMvtByDepot[depot] = sumMvtByDepot.GetValueOrDefault(depot) + mvt;
                    lignes.Add(ArticleMvtLigne.From(m, runningByDepot[depot]));
                }

                mvtDepotGroupTotals = runningByDepot
                    .ToDictionary(
                        kv => kv.Key,
                        kv => new MvtDepotGroupTotal
                        {
                            SumMvt = sumMvtByDepot.GetValueOrDefault(kv.Key),
                            FinalQte = kv.Value
                        },
                        StringComparer.OrdinalIgnoreCase);

                mvtLignes = lignes;
            });
            mvtLoaded = true;
        }
        finally
        {
            mvtLoading = false;
            await InvokeAsync(StateHasChanged);
            if (mvtGrid != null && mvtLignes.Count > 0)
                await mvtGrid.ExpandAllGroupAsync();
        }
    }

    private async Task OnMvtGridDataBound(object _)
    {
        if (mvtGrid == null || mvtLignes.Count == 0)
            return;
        await mvtGrid.ExpandAllGroupAsync();
    }

    private void OnMvtRowDataBound(RowDataBoundEventArgs<ArticleMvtLigne> args)
    {
        if (args.Data?.IsSoldeInitial == true)
            args.Row.AddClass(new[] { "cpt-solde-initial-row" });
    }

    private async Task OnMvtDoubleClick(RecordDoubleClickEventArgs<ArticleMvtLigne> args)
    {
        if (args?.RowData == null || args.RowData.IsSoldeInitial || string.IsNullOrWhiteSpace(args.RowData.DO_Piece))
            return;
        await ShowPiece(args.RowData.DO_Piece, args.RowData.DO_Type);
    }

    protected override async Task OnInitializedAsync()
    {
        db = session.db;
        GC.Collect();
        row = db.API_V_ARTICLE.Where(a => a.cbMarq == cbMarq).SingleOrDefault();
        mvtDateDebut = new DateTime(DateTime.Today.Year, 1, 1);
        mvtDateFin = DateTime.Today;
        depots = db.F_DEPOT.OrderBy(d => d.DE_Intitule).ToList();
        await LoadData();
    }
    protected async Task ShowPiece(string DO_Piece, short? DO_Type)
    {
        await DialogService.OpenAsync<DetailsPiece>(DO_Piece,
        new Dictionary<string, object>() { { "DO_Piece", DO_Piece }, { "DO_Type", DO_Type } },
        new Radzen.DialogOptions() { CloseDialogOnEsc = true, Width = "90%", Height = "90%" });
    }
    protected async Task ShowDetail(RecordDoubleClickEventArgs<API_V_MARGE> args, string type)
    {
        if (type == "client")
        {
            await DialogService.OpenAsync<DetailsMarge>(args.RowData.CT_Intitule,
      new Dictionary<string, object>() { { "Date1", date1 }, { "Date2", date2 }, { "CT_Num", args.RowData.CT_Num }, { "AR_Ref", row.AR_Ref }, { "ClassHeight", "grid-84" } },
      new Radzen.DialogOptions() { CloseDialogOnEsc = true, Width = "98%", Height = "95%" });
        }
        if (type == "mois")
        {
            await DialogService.OpenAsync<DetailsMarge>(args.RowData.MoisAnnee,
      new Dictionary<string, object>() { { "Date1", date1 }, { "Date2", date2 }, { "MoisAnnee", args.RowData.MoisAnnee }, { "AR_Ref", row.AR_Ref }, { "ClassHeight", "grid-84" } },
      new Radzen.DialogOptions() { CloseDialogOnEsc = true, Width = "98%", Height = "95%" });
        }

    }
}

