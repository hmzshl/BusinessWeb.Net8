@page "/cpt-echeances-fourn"
@attribute [Authorize]
@implements IDisposable

@if (IsLoaded)
{
    <Card_1 Title="@("ÉCHÉANCES FOURNISSEURS À PAYER — " + annee)">
        <RadzenContent>
            <div class="grid-container no-border">

                <SfToolbar CssClass="btns">
                    <ToolbarItems>
                        <ToolbarItem Align="ItemAlign.Left">
                            <Template>
                                <SfMessage Severity="MessageSeverity.Warning" Variant="MessageVariant.Outlined">
                                    <div style="text-transform: uppercase;">
                                        @filteredItems.Count facture(s) &nbsp;|&nbsp;
                                        Montant dû : @filteredItems.Sum(x => x.Montant).ToString("N2") &nbsp;|&nbsp;
                                        Pénalités estimées : @filteredItems.Sum(x => x.Penalite).ToString("N2")
                                    </div>
                                </SfMessage>
                            </Template>
                        </ToolbarItem>
                        <ToolbarItem Align="ItemAlign.Right" Type="ItemType.Input">
                            <Template>
                                <div style="display:flex; gap:8px; align-items:center;">
                                    <SfDropDownList TValue="int" TItem="int" Width="130px" @bind-Value="annee"
                                                    DataSource="@annees" Placeholder="Année">
                                        <DropDownListEvents TValue="int" TItem="int" ValueChange="@(args => LoadData())" />
                                    </SfDropDownList>
                                    <SfDropDownList TValue="string" TItem="PrioriteOption" Width="220px" @bind-Value="prioriteFilter"
                                                    DataSource="@prioriteOptions" ShowClearButton="true"
                                                    Placeholder="Toutes priorités">
                                        <DropDownListFieldSettings Value="Val" Text="Label" />
                                        <DropDownListEvents TValue="string" TItem="PrioriteOption" ValueChange="@(args => ApplyFilter())" />
                                    </SfDropDownList>
                                </div>
                            </Template>
                        </ToolbarItem>
                    </ToolbarItems>
                </SfToolbar>

                <GridRow Style="margin-bottom:12px;">
                    <GridCol Xs="12" Md="3">
                        <StatCard3 Color="StatColor.Red"
                                   Value="@items.Count(x => x.Priorite == "Urgent").ToString()"
                                   Title="Urgents (> 30j retard)" />
                    </GridCol>
                    <GridCol Xs="12" Md="3">
                        <StatCard3 Color="StatColor.Amber"
                                   Value="@items.Count(x => x.Priorite == "En retard").ToString()"
                                   Title="En retard" />
                    </GridCol>
                    <GridCol Xs="12" Md="3">
                        <StatCard3 Color="StatColor.Blue"
                                   Value="@items.Count(x => x.Priorite == "Proche").ToString()"
                                   Title="Échéance proche (< 30j)" />
                    </GridCol>
                    <GridCol Xs="12" Md="3">
                        <StatCard3 Color="StatColor.Green"
                                   Value="@items.Count(x => x.Priorite == "À venir").ToString()"
                                   Title="À venir" />
                    </GridCol>
                    <GridCol Xs="12" Md="3">
                        <StatCard3 Color="StatColor.Red"
                                   Value="@(items.Where(x => x.Priorite == "Urgent").Sum(x => x.Montant).ToString("N0"))"
                                   Title="Montant urgent" />
                    </GridCol>
                    <GridCol Xs="12" Md="3">
                        <StatCard3 Color="StatColor.Amber"
                                   Value="@(items.Where(x => x.Priorite == "En retard").Sum(x => x.Montant).ToString("N0"))"
                                   Title="Montant en retard" />
                    </GridCol>
                    <GridCol Xs="12" Md="3">
                        <StatCard3 Color="StatColor.Purple"
                                   Value="@(items.Sum(x => x.Penalite).ToString("N2"))"
                                   Title="Total pénalités estimées" />
                    </GridCol>
                    <GridCol Xs="12" Md="3">
                        <StatCard3 Color="StatColor.Blue"
                                   Value="@(items.Sum(x => x.Montant).ToString("N0"))"
                                   Title="Total à payer" />
                    </GridCol>
                </GridRow>

                <GridRow>
                    <GridCol Xs="24" Md="24">
                        <Card>
                            <div class="grid-67" style="zoom: @session.zoomLevel;">
                                <SfGrid Height="100%" DataSource="@filteredItems"
                                        Toolbar="@(new List<object>() { "Print", "ExcelExport", "Search" })"
                                        AllowSorting AllowResizing AllowGrouping>
                                    <GridPageSettings PageSize="200" />
                                    <GridGroupSettings Columns="@(new string[] { "CT_Intitule" })" ShowDropArea="false"
                                                       ShowToggleButton EnableLazyLoading DisablePageWiseAggregates>
                                        <CaptionTemplate>
                                            @{ var ag = (context as CaptionTemplateContext); }
                                            <div style="font-weight:700;">@ag.Key</div>
                                        </CaptionTemplate>
                                    </GridGroupSettings>
                                    <GridAggregates>
                                        <GridAggregate>
                                            <GridAggregateColumns>
                                                <GridAggregateColumn Field="@nameof(EchFournItem.Montant)" Type="AggregateType.Sum" Format="N2">
                                                    <FooterTemplate>
                                                        @{ var s = (context as AggregateTemplateContext); }
                                                        <div style="text-align:right; font-weight:600;">@s.Sum</div>
                                                    </FooterTemplate>
                                                </GridAggregateColumn>
                                                <GridAggregateColumn Field="@nameof(EchFournItem.Penalite)" Type="AggregateType.Sum" Format="N2">
                                                    <FooterTemplate>
                                                        @{ var s = (context as AggregateTemplateContext); }
                                                        <div style="text-align:right; font-weight:600; color:#e53935;">@s.Sum</div>
                                                    </FooterTemplate>
                                                </GridAggregateColumn>
                                            </GridAggregateColumns>
                                        </GridAggregate>
                                    </GridAggregates>
                                    <GridColumns>
                                        <GridColumn Width="90" HeaderText="Priorité" Field="@nameof(EchFournItem.Priorite)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center">
                                            <Template>
                                                @{ var dt = (context as EchFournItem); }
                                                <span class="@PrioriteClass(dt.Priorite)">@dt.Priorite</span>
                                            </Template>
                                        </GridColumn>
                                        <GridColumn Width="70"  HeaderText="Date mv." Field="@nameof(EchFournItem.MV_Date)" Format="dd/MM/yyyy" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                        <GridColumn Width="80" HeaderText="Échéance" Field="@nameof(EchFournItem.DateEcheance)" Format="dd/MM/yyyy" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                        <GridColumn Width="70"  HeaderText="Src.éch." Field="@nameof(EchFournItem.EcheanceSource)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                        <GridColumn Width="80"  HeaderText="Retard (j)" Field="@nameof(EchFournItem.JoursRetard)" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center">
                                            <Template>
                                                @{ var dt = (context as EchFournItem); }
                                                @if (dt.JoursRetard > 0)
                                                {
                                                    <span style="color:#e53935; font-weight:600;">@dt.JoursRetard j</span>
                                                }
                                                else
                                                {
                                                    <span style="color:#43a047;">@Math.Abs(dt.JoursRetard) j</span>
                                                }
                                            </Template>
                                        </GridColumn>
                                        <GridColumn Width="80" HeaderText="Pièce" Field="@nameof(EchFournItem.EC_Piece)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                        <GridColumn Width="65"  HeaderText="Journal" Field="@nameof(EchFournItem.JO_Num)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                        <GridColumn Width="180" HeaderText="Fournisseur" Field="@nameof(EchFournItem.CT_Intitule)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                        <GridColumn Width="100" HeaderText="Compte" Field="@nameof(EchFournItem.CG_Intitule)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                        <GridColumn Width="300" HeaderText="Libellé" Field="@nameof(EchFournItem.EC_Intitule)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                        <GridColumn Width="100" HeaderText="Montant" Field="@nameof(EchFournItem.Montant)" Format="N2" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                        <GridColumn Width="100" HeaderText="Pénalité est." Field="@nameof(EchFournItem.Penalite)" Format="N2" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center">
                                            <Template>
                                                @{ var dt = (context as EchFournItem); }
                                                <div style="text-align:right; @(dt.Penalite > 0 ? "color:#e53935; font-weight:600;" : "")">
                                                    @dt.Penalite.ToString("N2")
                                                </div>
                                            </Template>
                                        </GridColumn>
                                    </GridColumns>
                                </SfGrid>
                            </div>
                        </Card>
                    </GridCol>
                </GridRow>

            </div>
        </RadzenContent>
    </Card_1>
}
else
{
    <div class="center-screen"><Loading_1 /></div>
}

@code {
    [CascadingParameter] public SessionDT session { get; set; } = new SessionDT();
    DB db = new DB();

    private List<EchFournItem> items         = new();
    private List<EchFournItem> filteredItems = new();
    private List<PrioriteStatItem> parPriorite = new();
    private List<FournStatItem>    topFourn    = new();

    int annee = DateTime.Today.Year;
    string prioriteFilter = null;
    bool IsLoaded = false;
    private List<int> annees = Enumerable.Range(0, 10).Select(i => DateTime.Today.Year - i).ToList();

    // ── DTOs ────────────────────────────────────────────────────────────────
    private class EchFournItem
    {
        public string   JO_Num          { get; set; }
        public string   JO_Intitule     { get; set; }
        public DateTime? MV_Date        { get; set; }
        public string   EC_Piece        { get; set; }
        public string   CT_Num          { get; set; }
        public string   CT_Intitule     { get; set; }
        public string   CG_Num          { get; set; }
        public string   CG_Intitule     { get; set; }
        public string   EC_Intitule     { get; set; }
        public decimal  Montant         { get; set; }
        public DateTime DateEcheance    { get; set; }
        public string   EcheanceSource  { get; set; }  // "Échéance" | "Délai tiers" | "+60j"
        public int      JoursRetard     { get; set; }  // >0 = retard, <0 = jours restants
        public int      NbMoisRetard    { get; set; }
        public string   Priorite        { get; set; }  // "Urgent" | "En retard" | "Proche" | "À venir"
        public decimal  Penalite        { get; set; }
    }
    private class PrioriteOption   { public string Val { get; set; } public string Label { get; set; } }
    private class PrioriteStatItem { public string Priorite { get; set; } public decimal Montant { get; set; } }
    private class FournStatItem    { public string Fourn    { get; set; } public decimal Montant { get; set; } }

    private List<PrioriteOption> prioriteOptions = new()
    {
        new PrioriteOption { Val = "Urgent",    Label = "🔴 Urgent" },
        new PrioriteOption { Val = "En retard", Label = "🟠 En retard" },
        new PrioriteOption { Val = "Proche",    Label = "🔵 Proche" },
        new PrioriteOption { Val = "À venir",   Label = "🟢 À venir" }
    };

    protected override async Task OnInitializedAsync()
    {
        db = session.db;
        GC.Collect();
        await Task.Delay(1);
        await LoadData();
        IsLoaded = true;
    }

    private async Task LoadData()
    {
        IsLoaded = false;
        await Task.Delay(300);

        // 1. Fetch filter sets from DB
        var fournNums  = db.F_COMPTET
            .Where(c => c.CT_Type == 1)
            .Select(c => c.CT_Num)
            .ToHashSet();

        var journalNums = db.F_JOURNAUX
            .Where(j => j.JO_Type == 0 || j.JO_Type == 3)
            .Select(j => j.JO_Num)
            .ToHashSet();

        // 2. MAX(RT_NbJour) per CT_Num — used as fallback payment delay
        var delaiParTiers = db.F_REGLEMENTT
            .Where(r => r.RT_NbJour.HasValue)
            .ToList()
            .GroupBy(r => r.CT_Num)
            .ToDictionary(g => g.Key, g => (int)(g.Max(r => r.RT_NbJour) ?? 30));

        // 3. Load raw entries
        var raw = db.API_V_ECRITUREC
            .Where(e => e.EC_Lettre == 0
                     && e.EC_Sens == 1
                     && e.MV_Date.HasValue
                     && e.MV_Date.Value.Year == annee)
            .ToList()
            .Where(e => fournNums.Contains(e.CT_Num) && journalNums.Contains(e.JO_Num))
            .ToList();

        var today = DateTime.Today;
        var dateMin1 = new DateTime(1753, 1, 1);
        var dateMin2 = new DateTime(1900, 1, 1);

        // 4. Project with computed fields
        items = raw.Select(e =>
        {
            // ── Date échéance ──────────────────────────────────────────────
            DateTime dateEch;
            string source;

            bool echeanceValide = e.EC_Echeance.HasValue
                               && e.EC_Echeance.Value.Date != dateMin1
                               && e.EC_Echeance.Value.Date != dateMin2;

            if (echeanceValide)
            {
                dateEch = e.EC_Echeance.Value.Date;
                source  = "Échéance";
            }
            else if (delaiParTiers.TryGetValue(e.CT_Num, out int nbJour) && nbJour > 0)
            {
                dateEch = e.JM_Date.Date.AddDays(nbJour);
                source  = "Délai tiers";
            }
            else
            {
                dateEch = (e.MV_Date ?? e.JM_Date).Date.AddDays(60);
                source  = "+60j";
            }

            // ── Retard ────────────────────────────────────────────────────
            int joursRetard  = (today - dateEch).Days;           // >0 = en retard
            int moisRetard   = Math.Max(0, joursRetard / 30);

            // ── Priorité ─────────────────────────────────────────────────
            string priorite = joursRetard > 30  ? "Urgent"
                            : joursRetard > 0   ? "En retard"
                            : joursRetard > -30 ? "Proche"
                            :                     "À venir";

            // ── Pénalité — (EC_Montant × 0.03) + 0.005 × EC_Montant × NbMoisRetard
            decimal montant  = e.EC_Montant ?? 0m;
            decimal penalite = moisRetard > 0
                ? (montant * 0.03m) + (0.005m * montant * moisRetard)
                : 0m;

            return new EchFournItem
            {
                JO_Num         = e.JO_Num,
                JO_Intitule    = e.JO_Intitule,
                MV_Date        = e.MV_Date,
                EC_Piece       = e.EC_Piece,
                CT_Num         = e.CT_Num,
                CT_Intitule    = e.CT_Intitule,
                CG_Num         = e.CG_Num,
                CG_Intitule    = e.CG_Intitule,
                EC_Intitule    = e.EC_Intitule,
                Montant        = montant,
                DateEcheance   = dateEch,
                EcheanceSource = source,
                JoursRetard    = joursRetard,
                NbMoisRetard   = moisRetard,
                Priorite       = priorite,
                Penalite       = penalite
            };
        })
        .OrderBy(x => x.DateEcheance)
        .ToList();

        BuildCharts();
        prioriteFilter = null;
        ApplyFilter();

        IsLoaded = true;
        await Task.Delay(300);
    }

    private void BuildCharts()
    {
        var prioriteOrder = new[] { "Urgent", "En retard", "Proche", "À venir" };
        parPriorite = prioriteOrder
            .Select(p => new PrioriteStatItem
            {
                Priorite = p,
                Montant  = items.Where(x => x.Priorite == p).Sum(x => x.Montant)
            })
            .Where(x => x.Montant > 0)
            .ToList();

        topFourn = items
            .GroupBy(x => x.CT_Intitule)
            .Select(g => new FournStatItem { Fourn = g.Key, Montant = g.Sum(x => x.Montant) })
            .OrderByDescending(x => x.Montant)
            .Take(8)
            .ToList();
    }

    private void ApplyFilter()
    {
        filteredItems = string.IsNullOrEmpty(prioriteFilter)
            ? items
            : items.Where(x => x.Priorite == prioriteFilter).ToList();
    }

    private static string PrioriteClass(string priorite) => priorite switch
    {
        "Urgent"    => "statustxt e-inactivecolor",
        "En retard" => "statustxt e-warningcolor",
        "Proche"    => "statustxt e-infocolor",
        _           => "statustxt e-activecolor"
    };

    public void Dispose()
    {
        items?.Clear();
        filteredItems?.Clear();
        parPriorite?.Clear();
        topFourn?.Clear();
        items = null;
        filteredItems = null;
        parPriorite = null;
        topFourn = null;
    }
}
