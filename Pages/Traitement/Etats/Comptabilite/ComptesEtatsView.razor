        balanceDisplayType = BalanceDisplayType.Base;
    }

    private async Task LoadData()
    {
        var seq = Interlocked.Increment(ref loadSeq);

        if (IsLoaded)
        {
            isDataLoading = true;
            await InvokeAsync(StateHasChanged);
            await Task.Yield();
        }
        else
        {
            await Task.Delay(200);
        }

        try
        {
            await Task.Run(() =>
            {
                if (seq != loadSeq) return;
                LoadDataCore();
            });
        }
        finally
        {
            if (seq == loadSeq)
            {
                IsLoaded = true;
                isDataLoading = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private void LoadDataCore()
    {
        if (CurrentExo == null)
        {
            balanceItems.Clear();
            tierBalanceItems.Clear();
            ecritureItems.Clear();
            comptesGeneraux.Clear();
            comptesClients.Clear();
            comptesFournisseurs.Clear();
            ecritureComptesCount = 0;
            journalOptions.Clear();
            compteOptions.Clear();
            tierOptions.Clear();
            return;
        }

        ClampDates();
        LoadLabelLookups();

        var baseQuery = CptEcritureQuery.ByEcDate(db, dateDebut, dateFin);

        if (IsGeneral)
        {
            if (generalAccountNumbers.Count == 0)
                generalAccountNumbers = db.F_COMPTEG
                    .Where(g => g.CG_Num != null)
                    .Select(g => g.CG_Num)
                    .ToHashSet(StringComparer.OrdinalIgnoreCase);
        }

        var scopeQuery = IsGeneral
            ? baseQuery.Where(e => e.CG_Num != null && generalAccountNumbers.Contains(e.CG_Num))
            : baseQuery.Where(e => e.CT_Num != null && e.CT_Num != "");

        LoadFilterOptions(scopeQuery);

        if (IsGeneral)
        {
            balanceItems = BuildGeneralBalance();

            var labels = CurrentLabels();

            var generalRows = ApplyEcritureFilters(
                    CptEcritureQuery.ExcludeAN(
                        baseQuery.Where(e => e.CG_Num != null && generalAccountNumbers.Contains(e.CG_Num))))
                .OrderBy(e => e.CG_Num)
                .ThenBy(e => e.EC_Date)
                .ToList();

            ecritureItems = CptEcritureQuery.ToItemList(generalRows, labels);

            var activeCg = ecritureItems.Select(x => x.CG_Num).Distinct().ToHashSet(StringComparer.OrdinalIgnoreCase);
            comptesGeneraux = db.F_COMPTEG
                .Where(g => g.CG_Num != null && activeCg.Contains(g.CG_Num))
                .OrderBy(g => g.CG_Num)
                .ToList();

            ecritureComptesCount = activeCg.Count;
        }
        else
        {
            var labels = CurrentLabels();

            var tierQuery = ApplyEcritureFilters(
                CptEcritureQuery.ExcludeAN(
                    baseQuery.Where(e => e.CT_Num != null && e.CT_Num != "")));

            tierBalanceItems = (
                from e in tierQuery
                join ct in db.F_COMPTET on e.CT_Num equals ct.CT_Num into ctJoin
                from ct in ctJoin.DefaultIfEmpty()
                group e by new { e.CT_Num, CT_Intitule = ct != null ? ct.CT_Intitule : null, e.CG_Num } into g
                select new CptTierBalanceItem
                {
                    CT_Num = g.Key.CT_Num,
                    CT_Intitule = g.Key.CT_Intitule,
                    CG_NumPrinc = g.Key.CG_Num,
                    TotalDebit = g.Sum(x => x.EC_Sens == 0 ? x.EC_Montant ?? 0m : 0m),
                    TotalCredit = g.Sum(x => x.EC_Sens == 1 ? x.EC_Montant ?? 0m : 0m)
                })
                .OrderBy(x => x.CT_Num)
                .ToList();

            var tierRows = tierQuery
                .OrderBy(e => e.CT_Num)
                .ThenBy(e => e.EC_Date)
                .ToList();

            ecritureItems = CptEcritureQuery.ToItemList(tierRows, labels);

            var activeCt = ecritureItems.Select(x => x.CT_Num).Distinct().ToHashSet(StringComparer.OrdinalIgnoreCase);
            var tiersList = db.F_COMPTET
                .Where(t => t.CT_Num != null && activeCt.Contains(t.CT_Num))
                .OrderBy(t => t.CT_Num)
                .ToList();

            comptesClients = tiersList.Where(t => t.CT_Type == 0).ToList();
            comptesFournisseurs = tiersList.Where(t => t.CT_Type == 1).ToList();

            ecritureComptesCount = activeCt.Count;
        }
    }

    private CptEcritureQuery.LabelLookups CurrentLabels() => new()
    {
        Journal = journalLabels,
        Compte = compteLabels,
        Tier = tierLabels
    };

    private void LoadLabelLookups()
    {
        var labels = CptEcritureQuery.LoadLabels(db);
        journalLabels = labels.Journal;
        compteLabels = labels.Compte;
        tierLabels = labels.Tier;
    }

    private void LoadFilterOptions(IQueryable<F_ECRITUREC> scopeQuery)
    {
        journalOptions = scopeQuery
            .Where(e => e.JO_Num != null && e.JO_Num != "")
            .Select(e => e.JO_Num)
            .Distinct()
            .AsEnumerable()
            .Select(code => new FilterOption
            {
                Code = code,
                Label = code + " - " + (journalLabels.TryGetValue(code, out var lib) ? lib : "")
            })
            .OrderBy(x => x.Code)
            .ToList();

        compteOptions = scopeQuery
            .Where(e => e.CG_Num != null && e.CG_Num != "")
            .Select(e => e.CG_Num)
            .Distinct()
            .AsEnumerable()
            .Select(code => new FilterOption
            {
                Code = code,
                Label = code + " - " + (compteLabels.TryGetValue(code, out var lib) ? lib : "")
            })
            .OrderBy(x => x.Code)
            .ToList();

        tierOptions = scopeQuery
            .Where(e => e.CT_Num != null && e.CT_Num != "")
            .Select(e => e.CT_Num)
            .Distinct()
            .AsEnumerable()
            .Select(code => new FilterOption
            {
                Code = code,
                Label = code + " - " + (tierLabels.TryGetValue(code, out var lib) ? lib : "")
            })
            .OrderBy(x => x.Code)
            .ToList();

        var journalCodes = journalOptions.Select(x => x.Code).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var compteCodes = compteOptions.Select(x => x.Code).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var tierCodes = tierOptions.Select(x => x.Code).ToHashSet(StringComparer.OrdinalIgnoreCase);

        selectedJournals = selectedJournals?.Where(c => journalCodes.Contains(c)).ToList() ?? new();
        selectedComptes = selectedComptes?.Where(c => compteCodes.Contains(c)).ToList() ?? new();
        selectedTiers = selectedTiers?.Where(c => tierCodes.Contains(c)).ToList() ?? new();
    }

    private IQueryable<F_ECRITUREC> ApplyEcritureFilters(IQueryable<F_ECRITUREC> query)
    {
        if (selectedJournals?.Count > 0)
            query = query.Where(e => selectedJournals.Contains(e.JO_Num));
        if (selectedComptes?.Count > 0)
            query = query.Where(e => selectedComptes.Contains(e.CG_Num));
        if (selectedTiers?.Count > 0)
            query = query.Where(e => selectedTiers.Contains(e.CT_Num));
        return query;
    }

    private List<CptBalanceItem> BuildGeneralBalance()
    {
        var rows = new Dictionary<string, CptBalanceItem>(StringComparer.OrdinalIgnoreCase);

        void MergeAmounts(string cgNum, string cgIntitule, decimal debit, decimal credit, bool isAn)
        {
            if (string.IsNullOrWhiteSpace(cgNum))
                return;

            if (!rows.TryGetValue(cgNum, out var row))
            {
                row = new CptBalanceItem { CG_Num = cgNum, CG_Intitule = cgIntitule };
                rows[cgNum] = row;
            }

            if (isAn)
            {
                row.AnDebit += debit;
                row.AnCredit += credit;
            }
            else
            {
                row.MvDebit += debit;
                row.MvCredit += credit;
            }
        }

        var mvQuery = ApplyEcritureFilters(
            CptEcritureQuery.ExcludeAN(
                db.F_ECRITUREC.Where(e =>
                    e.CG_Num != null
                    && generalAccountNumbers.Contains(e.CG_Num)
                    && e.EC_Date.HasValue
                    && e.EC_Date.Value >= dateDebut
                    && e.EC_Date.Value <= dateFin)));

        var mvGroups = (
            from e in mvQuery
            join cg in db.F_COMPTEG on e.CG_Num equals cg.CG_Num into cgJoin
            from cg in cgJoin.DefaultIfEmpty()
            group e by new { e.CG_Num, CG_Intitule = cg != null ? cg.CG_Intitule : null } into grp
            select new
            {
                grp.Key.CG_Num,
                grp.Key.CG_Intitule,
                Debit = grp.Sum(l => l.EC_Sens == 0 ? l.EC_Montant ?? 0m : 0m),
                Credit = grp.Sum(l => l.EC_Sens == 1 ? l.EC_Montant ?? 0m : 0m)
            }).ToList();

        foreach (var g in mvGroups)
            MergeAmounts(g.CG_Num, g.CG_Intitule, g.Debit, g.Credit, isAn: false);

        if (IsSixColonnesBalance && CurrentExo != null)
        {
            var exoDeb = CurrentExo.Debut;
            var exoFin = CurrentExo.Fin;

            var anBase = ApplyEcritureFilters(
                db.F_ECRITUREC.Where(e =>
                    e.CG_Num != null
                    && generalAccountNumbers.Contains(e.CG_Num)
                    && e.EC_ANType == 1
                    && e.JM_Date >= exoDeb
                    && e.JM_Date <= exoFin));

            var anGroups = (
                from e in anBase
                join cg in db.F_COMPTEG on e.CG_Num equals cg.CG_Num into cgJoin
                from cg in cgJoin.DefaultIfEmpty()
                group e by new { e.CG_Num, CG_Intitule = cg != null ? cg.CG_Intitule : null } into grp
                select new
                {
                    grp.Key.CG_Num,
                    grp.Key.CG_Intitule,
                    Debit = grp.Sum(l => l.EC_Sens == 0 ? l.EC_Montant ?? 0m : 0m),
                    Credit = grp.Sum(l => l.EC_Sens == 1 ? l.EC_Montant ?? 0m : 0m)
                }).ToList();

            foreach (var g in anGroups)
                MergeAmounts(g.CG_Num, g.CG_Intitule ?? "", g.Debit, g.Credit, isAn: true);
        }

        return rows.Values
            .Where(x => x.AnDebit != 0m || x.AnCredit != 0m || x.MvDebit != 0m || x.MvCredit != 0m)
            .OrderBy(x => x.CG_Num)
            .Select(x =>
            {
                x.ComputeSolde();
                return x;
            })
            .ToList();
    }

    private async Task OnBalanceDataBound(object _)
    {
        if (balanceGeneralGrid == null || balanceItems.Count == 0)
            return;
        await balanceGeneralGrid.ExpandAllGroupAsync();
    }

    private async Task OnGrandLivreDataBound(object _)
    {
        if (grandLivreGrid == null || ecritureItems.Count == 0)
            return;
        await grandLivreGrid.ExpandAllGroupAsync();
    }

    public void Dispose()
    {
        balanceItems?.Clear();
        tierBalanceItems?.Clear();
        ecritureItems?.Clear();
        comptesGeneraux?.Clear();
        comptesClients?.Clear();
        comptesFournisseurs?.Clear();
        generalAccountNumbers?.Clear();
        journalLabels?.Clear();
        compteLabels?.Clear();
        tierLabels?.Clear();
        journalOptions?.Clear();
        compteOptions?.Clear();
        tierOptions?.Clear();
        selectedJournals?.Clear();
        selectedComptes?.Clear();
        selectedTiers?.Clear();
    }
}

