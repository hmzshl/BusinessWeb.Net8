@implements IDisposable

@if (IsLoaded)
{
    <Card_1 Title="@CardTitle">
        <RadzenContent>
            <div class="grid-container no-border">

                <SfToolbar CssClass="btns">
                    <ToolbarItems>
                        <ToolbarItem Align="ItemAlign.Left">
                            <Template>
                                <SfMessage Severity="MessageSeverity.Info" Variant="MessageVariant.Outlined">
                                    <div style="text-transform: uppercase;">
                                        @ToolbarSummary
                                    </div>
                                </SfMessage>
                            </Template>
                        </ToolbarItem>
                        <ToolbarItem Align="ItemAlign.Right" Overflow="OverflowOption.Show" Type="ItemType.Input">
                            <Template>
                                <SfTextBox Width="200px" Placeholder="Recherche" CssClass="e-small"
                                           ValueChanged="@(args => SearchActiveGrid(args))" />
                            </Template>
                        </ToolbarItem>
                        <ToolbarItem OnClick="@(_ => showFiltersDialog = true)" TooltipText="Filtres"
                                     ShowTextOn="DisplayMode.Overflow" Align="ItemAlign.Right"
                                     PrefixIcon="e-icons e-filter" />
                        <ToolbarItem OnClick="@(_ => PrintActiveGrid())" TooltipText="Imprimer"
                                     ShowTextOn="DisplayMode.Overflow" Align="ItemAlign.Right"
                                     PrefixIcon="e-icons e-print" />
                        <ToolbarItem OnClick="@(_ => ExportActiveGrid())" TooltipText="Export Excel"
                                     ShowTextOn="DisplayMode.Overflow" Align="ItemAlign.Right"
                                     PrefixIcon="e-icons e-export-excel" />
                    </ToolbarItems>
                </SfToolbar>

                <SfDialog @bind-Visible="showFiltersDialog" Width="520px" ShowCloseIcon="true" IsModal="true">
                    <DialogTemplates>
                        <Header>Filtres</Header>
                        <Content>
                            <div class="cpt-filters-dialog">
                                <SfDropDownList TValue="int" TItem="ExoItem" Width="100%"
                                                @bind-Value="selectedExoIndex" DataSource="@exoItems"
                                                Placeholder="Exercice">
                                    <DropDownListFieldSettings Text="Label" Value="Idx" />
                                    <DropDownListEvents TValue="int" TItem="ExoItem"
                                                        ValueChange="@(args => OnExerciceInDialogChanged(args))" />
                                </SfDropDownList>
                                @if (IsGeneral)
                                {
                                    <SfDropDownList TValue="BalanceDisplayType" TItem="BalanceFormatOption" Width="100%"
                                                    @bind-Value="balanceDisplayType" DataSource="@balanceFormatOptions"
                                                    Placeholder="Type balance">
                                        <DropDownListFieldSettings Text="Label" Value="Value" />
                                    </SfDropDownList>
                                }
                                <SfMultiSelect TValue="List<string>" TItem="FilterOption" Width="100%"
                                               @bind-Value="selectedJournals" DataSource="@journalOptions"
                                               Placeholder="Journal" Mode="VisualMode.CheckBox" AllowFiltering
                                               ShowSelectAll ShowDropDownIcon ShowClearButton PopupHeight="280px">
                                    <MultiSelectFieldSettings Text="Label" Value="Code" />
                                </SfMultiSelect>
                                <SfMultiSelect TValue="List<string>" TItem="FilterOption" Width="100%"
                                               @bind-Value="selectedComptes" DataSource="@compteOptions"
                                               Placeholder="Compte" Mode="VisualMode.CheckBox" AllowFiltering
                                               ShowSelectAll ShowDropDownIcon ShowClearButton PopupHeight="280px">
                                    <MultiSelectFieldSettings Text="Label" Value="Code" />
                                </SfMultiSelect>
                                <SfMultiSelect TValue="List<string>" TItem="FilterOption" Width="100%"
                                               @bind-Value="selectedTiers" DataSource="@tierOptions"
                                               Placeholder="Tiers" Mode="VisualMode.CheckBox" AllowFiltering
                                               ShowSelectAll ShowDropDownIcon ShowClearButton PopupHeight="280px">
                                    <MultiSelectFieldSettings Text="Label" Value="Code" />
                                </SfMultiSelect>
                                <div class="cpt-filters-dates">
                                    <SfDatePicker TValue="DateTime" Width="100%" @bind-Value="dateDebut"
                                                  Format="dd/MM/yyyy" Placeholder="Date début"
                                                  Min="@dateMin" Max="@dateMax" />
                                    <SfDatePicker TValue="DateTime" Width="100%" @bind-Value="dateFin"
                                                  Format="dd/MM/yyyy" Placeholder="Date fin"
                                                  Min="@dateMin" Max="@dateMax" />
                                </div>
                            </div>
                        </Content>
                    </DialogTemplates>
                    <DialogButtons>
                        <DialogButton Content="Effacer" OnClick="@ClearFiltersFromDialog" />
                        <DialogButton Content="Appliquer" IsPrimary="true" OnClick="@ApplyFiltersFromDialog" />
                    </DialogButtons>
                </SfDialog>

                <div class="cpt-tabs-panel">
                        <SfTab @bind-SelectedItem="activeTabIndex" CssClass="e-fill lf-tabs" HeaderPlacement="HeaderPosition.Left">
                            <TabItems>

                        <TabItem>
                            <ChildContent><TabHeader Text="Balance générale"></TabHeader></ChildContent>
                            <ContentTemplate>
                                <div class="cpt-tab-body">
                                    @if (IsGeneral)
                                    {
                                        <Card>
                                            <div class="grid-84 cpt-balance-grid" style="zoom: @session.zoomLevel;">
                                                @if (isDataLoading)
                                                {
                                                    <div class="cpt-grid-loading"><Loading_1 /></div>
                                                }
                                                else
                                                {
                                                <SfGrid @ref="balanceGeneralGrid" @key="balanceDisplayType" Height="100%" RowHeight="26" DataSource="@balanceItems"
                                                        AllowSorting AllowResizing AllowGrouping AllowExcelExport>
                                                    <GridEvents TValue="CptBalanceItem" DataBound="OnBalanceDataBound" />
                                                    <GridPageSettings PageSize="200" />
                                                    <GridGroupSettings Columns="@(new string[] { nameof(CptBalanceItem.ClasseLabel) })" ShowDropArea="false" ShowToggleButton>
                                                        <CaptionTemplate>
                                                            @{ var ag = (context as CaptionTemplateContext); }
                                                            <div style="font-weight:700;">@ag.Key</div>
                                                        </CaptionTemplate>
                                                    </GridGroupSettings>
                                                    <GridAggregates>
                                                        <GridAggregate>
                                                            <GridAggregateColumns>
                                                                @if (IsSixColonnesBalance)
                                                                {
                                                                    <GridAggregateColumn Field="@nameof(CptBalanceItem.AnDebit)" Type="AggregateType.Sum" Format="@AmountFormat" />
                                                                    <GridAggregateColumn Field="@nameof(CptBalanceItem.AnCredit)" Type="AggregateType.Sum" Format="@AmountFormat" />
                                                                }
                                                                <GridAggregateColumn Field="@nameof(CptBalanceItem.MvDebit)" Type="AggregateType.Sum" Format="@AmountFormat" />
                                                                <GridAggregateColumn Field="@nameof(CptBalanceItem.MvCredit)" Type="AggregateType.Sum" Format="@AmountFormat" />
                                                                <GridAggregateColumn Field="@nameof(CptBalanceItem.SoldeDebit)" Type="AggregateType.Sum" Format="@AmountFormat" />
                                                                <GridAggregateColumn Field="@nameof(CptBalanceItem.SoldeCredit)" Type="AggregateType.Sum" Format="@AmountFormat" />
                                                            </GridAggregateColumns>
                                                        </GridAggregate>
                                                    </GridAggregates>
                                                    <GridColumns>
                                                        <GridColumn Field="@nameof(CptBalanceItem.ClasseLabel)" Visible="false" />
                                                        <GridColumn Width="100" HeaderText="Compte" Field="@nameof(CptBalanceItem.CG_Num)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                        <GridColumn Width="200" HeaderText="Intitulé" Field="@nameof(CptBalanceItem.CG_Intitule)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                        @if (IsSixColonnesBalance)
                                                        {
                                                            <GridColumn HeaderText="A. Nouveau" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center">
                                                                <GridColumns>
                                                                    <GridColumn Width="90" HeaderText="Débit" Field="@nameof(CptBalanceItem.AnDebit)" Format="@AmountFormat" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                                    <GridColumn Width="90" HeaderText="Crédit" Field="@nameof(CptBalanceItem.AnCredit)" Format="@AmountFormat" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                                </GridColumns>
                                                            </GridColumn>
                                                        }
                                                        <GridColumn HeaderText="Mouvements" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center">
                                                            <GridColumns>
                                                                <GridColumn Width="90" HeaderText="Débit" Field="@nameof(CptBalanceItem.MvDebit)" Format="@AmountFormat" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                                <GridColumn Width="90" HeaderText="Crédit" Field="@nameof(CptBalanceItem.MvCredit)" Format="@AmountFormat" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                            </GridColumns>
                                                        </GridColumn>
                                                        <GridColumn HeaderText="Soldes" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center">
                                                            <GridColumns>
                                                                <GridColumn Width="90" HeaderText="Débit" Field="@nameof(CptBalanceItem.SoldeDebit)" Format="@AmountFormat" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                                <GridColumn Width="90" HeaderText="Crédit" Field="@nameof(CptBalanceItem.SoldeCredit)" Format="@AmountFormat" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                            </GridColumns>
                                                        </GridColumn>
                                                    </GridColumns>
                                                </SfGrid>
                                                }
                                            </div>
                                        </Card>
                                    }
                                    else
                                    {
                                        <Card>
                                            <div class="grid-84 cpt-balance-grid" style="zoom: @session.zoomLevel;">
                                                @if (isDataLoading)
                                                {
                                                    <div class="cpt-grid-loading"><Loading_1 /></div>
                                                }
                                                else
                                                {
                                                <SfGrid @ref="balanceTierGrid" Height="100%" RowHeight="26" DataSource="@tierBalanceItems"
                                                        AllowSorting AllowResizing AllowExcelExport>
                                                    <GridPageSettings PageSize="200" />
                                                    <GridColumns>
                                                        <GridColumn Width="120" HeaderText="Tiers" Field="@nameof(CptTierBalanceItem.CT_Num)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                        <GridColumn Width="220" HeaderText="Intitulé" Field="@nameof(CptTierBalanceItem.CT_Intitule)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                        <GridColumn Width="120" HeaderText="Compte coll." Field="@nameof(CptTierBalanceItem.CG_NumPrinc)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                        <GridColumn Width="140" HeaderText="Total Débit" Field="@nameof(CptTierBalanceItem.TotalDebit)" Format="N2" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                        <GridColumn Width="140" HeaderText="Total Crédit" Field="@nameof(CptTierBalanceItem.TotalCredit)" Format="N2" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                        <GridColumn Width="140" HeaderText="Solde" Field="@nameof(CptTierBalanceItem.Solde)" Format="N2" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                        <GridColumn Width="100" HeaderText="Sens" Field="@nameof(CptTierBalanceItem.SoldeSens)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                    </GridColumns>
                                                </SfGrid>
                                                }
                                            </div>
                                        </Card>
                                    }
                                </div>
                            </ContentTemplate>
                        </TabItem>

                        <TabItem>
                            <ChildContent><TabHeader Text="Grand livre"></TabHeader></ChildContent>
                            <ContentTemplate>
                                <div class="cpt-tab-body">
                                    <Card>
                                        <div class="grid-84 cpt-grand-livre-grid" style="zoom: @session.zoomLevel;">
                                            @if (isDataLoading)
                                            {
                                                <div class="cpt-grid-loading"><Loading_1 /></div>
                                            }
                                            else
                                            {
                                            <SfGrid @ref="grandLivreGrid" Height="100%" DataSource="@ecritureItems"
                                                    CssClass="cpt-gl-grid"
                                                    AllowSorting AllowResizing AllowGrouping AllowPaging AllowTextWrap AllowExcelExport>
                                                <GridEvents TValue="CptEcritureItem" DataBound="OnGrandLivreDataBound" />
                                                <GridPageSettings PageSize="50" PageSizes="@(new string[] { "50", "100", "200" })" />
                                                <GridGroupSettings Columns="@(new string[] { GroupField })" ShowDropArea="false" ShowToggleButton>
                                                    <CaptionTemplate>
                                                        @{ var ag = (context as CaptionTemplateContext); }
                                                        <div style="font-weight:700;">@ag.Key</div>
                                                    </CaptionTemplate>
                                                </GridGroupSettings>
                                                <GridAggregates>
                                                    <GridAggregate>
                                                        <GridAggregateColumns>
                                                            <GridAggregateColumn Field="@nameof(CptEcritureItem.Debit)" Type="AggregateType.Sum" Format="@AmountFormat">
                                                                <GroupCaptionTemplate>
                                                                    @{ var s = (context as AggregateTemplateContext); }
                                                                    <div style="text-align:right;font-weight:600;">@s.Sum</div>
                                                                </GroupCaptionTemplate>
                                                            </GridAggregateColumn>
                                                            <GridAggregateColumn Field="@nameof(CptEcritureItem.Credit)" Type="AggregateType.Sum" Format="@AmountFormat">
                                                                <GroupCaptionTemplate>
                                                                    @{ var s = (context as AggregateTemplateContext); }
                                                                    <div style="text-align:right;font-weight:600;">@s.Sum</div>
                                                                </GroupCaptionTemplate>
                                                            </GridAggregateColumn>
                                                        </GridAggregateColumns>
                                                    </GridAggregate>
                                                </GridAggregates>
                                                <GridColumns>
                                                    <GridColumn Field="@GroupField" Visible="false" />
                                                    <GridColumn Width="68" HeaderText="Date" Field="@nameof(CptEcritureItem.MV_Date)" Format="dd/MM/yy" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                    <GridColumn Width="48" HeaderText="Code jnl" Field="@nameof(CptEcritureItem.JO_Num)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                    <GridColumn Width="80" HeaderText="Int. jnl" Field="@nameof(CptEcritureItem.JO_Intitule)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                    <GridColumn Width="60" HeaderText="Pièce" Field="@nameof(CptEcritureItem.EC_Piece)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                    <GridColumn Width="72" HeaderText="Réf." Field="@nameof(CptEcritureItem.EC_Reference)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                    <GridColumn Width="100" HeaderText="Libellé" Field="@nameof(CptEcritureItem.EC_Intitule)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                    <GridColumn Width="68" HeaderText="N° tiers" Field="@nameof(CptEcritureItem.CT_Num)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                    <GridColumn Width="160" HeaderText="Int. tiers" Field="@nameof(CptEcritureItem.CT_Intitule)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                    <GridColumn Width="160" HeaderText="Intitulé compte" Field="@nameof(CptEcritureItem.CG_Intitule)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                    <GridColumn Width="52" HeaderText="Let." Field="@nameof(CptEcritureItem.EC_Lettrage)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                    <GridColumn Width="68" HeaderText="Éch." Field="@nameof(CptEcritureItem.EC_Echeance)" Format="dd/MM/yy" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                    <GridColumn Width="68" HeaderText="Rapp." Field="@nameof(CptEcritureItem.Rapprochement)" Format="dd/MM/yy" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                    <GridColumn Width="76" HeaderText="Débit" Field="@nameof(CptEcritureItem.Debit)" Format="@AmountFormat" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                    <GridColumn Width="76" HeaderText="Crédit" Field="@nameof(CptEcritureItem.Credit)" Format="@AmountFormat" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                </GridColumns>
                                            </SfGrid>
                                            }
                                        </div>
                                    </Card>
                                </div>
                            </ContentTemplate>
                        </TabItem>

                        <TabItem>
                            <ChildContent><TabHeader Text="Gestion compte"></TabHeader></ChildContent>
                            <ContentTemplate>
                                <div class="cpt-tab-body">
                                    <Card>
                                        <div class="grid-84" style="zoom: @session.zoomLevel;">
                                            @if (isDataLoading)
                                            {
                                                <div class="cpt-grid-loading"><Loading_1 /></div>
                                            }
                                            else if (IsGeneral)
                                            {
                                                <SfGrid @ref="comptesGenerauxGrid" Height="100%" DataSource="@comptesGeneraux"
                                                        AllowSorting AllowResizing AllowExcelExport>
                                                    <GridPageSettings PageSize="200" />
                                                    <GridColumns>
                                                        <GridColumn Width="120" HeaderText="Compte" Field="@nameof(F_COMPTEG.CG_Num)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                        <GridColumn Width="260" HeaderText="Intitulé" Field="@nameof(F_COMPTEG.CG_Intitule)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                        <GridColumn Width="100" HeaderText="Type" Field="@nameof(F_COMPTEG.CG_Type)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                        <GridColumn Width="100" HeaderText="Lettrage" Field="@nameof(F_COMPTEG.CG_Lettrage)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                        <GridColumn Width="100" HeaderText="Sommeil" Field="@nameof(F_COMPTEG.CG_Sommeil)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                    </GridColumns>
                                                </SfGrid>
                                            }
                                            else
                                            {
                                                <SfTab @bind-SelectedItem="gestionTiersTabIndex" CssClass="e-fill cpt-gestion-tabs">
                                                    <TabItems>
                                                        <TabItem>
                                                            <ChildContent><TabHeader Text="Clients"></TabHeader></ChildContent>
                                                            <ContentTemplate>
                                                                <SfGrid @ref="comptesClientsGrid" Height="100%" DataSource="@comptesClients"
                                                                        AllowSorting AllowResizing AllowExcelExport>
                                                                    <GridPageSettings PageSize="200" />
                                                                    <GridColumns>
                                                                        <GridColumn Width="120" HeaderText="Tiers" Field="@nameof(F_COMPTET.CT_Num)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                                        <GridColumn Width="240" HeaderText="Intitulé" Field="@nameof(F_COMPTET.CT_Intitule)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                                        <GridColumn Width="120" HeaderText="Compte coll." Field="@nameof(F_COMPTET.CG_NumPrinc)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                                        <GridColumn Width="100" HeaderText="Sommeil" Field="@nameof(F_COMPTET.CT_Sommeil)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                                    </GridColumns>
                                                                </SfGrid>
                                                            </ContentTemplate>
                                                        </TabItem>
                                                        <TabItem>
                                                            <ChildContent><TabHeader Text="Fournisseurs"></TabHeader></ChildContent>
                                                            <ContentTemplate>
                                                                <SfGrid @ref="comptesFournisseursGrid" Height="100%" DataSource="@comptesFournisseurs"
                                                                        AllowSorting AllowResizing AllowExcelExport>
                                                                    <GridPageSettings PageSize="200" />
                                                                    <GridColumns>
                                                                        <GridColumn Width="120" HeaderText="Tiers" Field="@nameof(F_COMPTET.CT_Num)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                                        <GridColumn Width="240" HeaderText="Intitulé" Field="@nameof(F_COMPTET.CT_Intitule)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                                        <GridColumn Width="120" HeaderText="Compte coll." Field="@nameof(F_COMPTET.CG_NumPrinc)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                                        <GridColumn Width="100" HeaderText="Sommeil" Field="@nameof(F_COMPTET.CT_Sommeil)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                                                    </GridColumns>
                                                                </SfGrid>
                                                            </ContentTemplate>
                                                        </TabItem>
                                                    </TabItems>
                                                </SfTab>
                                            }
                                        </div>
                                    </Card>
                                </div>
                            </ContentTemplate>
                        </TabItem>

                            </TabItems>
                        </SfTab>
                </div>

            </div>
        </RadzenContent>
    </Card_1>
}
else
{
    <div class="center-screen"><Loading_1 /></div>
}

@code {
    [Parameter] public string CardTitle { get; set; } = "";
    [Parameter] public bool IsGeneral { get; set; } = true;

    [CascadingParameter] public SessionDT session { get; set; } = new SessionDT();
    DB db = new DB();

    private class ExoItem
    {
        public int Idx { get; set; }
        public string Label { get; set; }
        public DateTime Debut { get; set; }
        public DateTime Fin { get; set; }
    }

    private class FilterOption
    {
        public string Code { get; set; }
        public string Label { get; set; }
    }

    private enum BalanceDisplayType { Base, SixColonnes }

    private class BalanceFormatOption
    {
        public BalanceDisplayType Value { get; set; }
        public string Label { get; set; }
    }

    private static readonly List<BalanceFormatOption> balanceFormatOptions = new()
    {
        new() { Value = BalanceDisplayType.Base, Label = "Base" },
        new() { Value = BalanceDisplayType.SixColonnes, Label = "6 colonnes" }
    };

    private BalanceDisplayType balanceDisplayType = BalanceDisplayType.Base;
    private bool IsSixColonnesBalance => balanceDisplayType == BalanceDisplayType.SixColonnes;

    private List<ExoItem> exoItems = new();
    private int selectedExoIndex;
    private ExoItem CurrentExo => exoItems.Count > 0 && selectedExoIndex >= 0 && selectedExoIndex < exoItems.Count
        ? exoItems[selectedExoIndex] : null;

    private DateTime dateDebut;
    private DateTime dateFin;
    private DateTime dateMin => CurrentExo?.Debut ?? new DateTime(1900, 1, 1);
    private DateTime dateMax => CurrentExo?.Fin ?? new DateTime(2099, 12, 31);

    private List<CptBalanceItem> balanceItems = new();
    private List<CptTierBalanceItem> tierBalanceItems = new();
    private List<CptEcritureItem> ecritureItems = new();
    private List<F_COMPTEG> comptesGeneraux = new();
    private List<F_COMPTET> comptesClients = new();
    private List<F_COMPTET> comptesFournisseurs = new();
    private HashSet<string> generalAccountNumbers = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, string> journalLabels = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, string> compteLabels = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, string> tierLabels = new(StringComparer.OrdinalIgnoreCase);

    private List<FilterOption> journalOptions = new();
    private List<FilterOption> compteOptions = new();
    private List<FilterOption> tierOptions = new();
    private List<string> selectedJournals = new();
    private List<string> selectedComptes = new();
    private List<string> selectedTiers = new();

    private int ecritureComptesCount;
    private int activeTabIndex;
    private int gestionTiersTabIndex;
    private bool showFiltersDialog;
    private const int ComptesTabIndex = 2;

    private SfGrid<CptBalanceItem> balanceGeneralGrid;
    private SfGrid<CptTierBalanceItem> balanceTierGrid;
    private SfGrid<CptEcritureItem> grandLivreGrid;
    private SfGrid<F_COMPTEG> comptesGenerauxGrid;
    private SfGrid<F_COMPTET> comptesClientsGrid;
    private SfGrid<F_COMPTET> comptesFournisseursGrid;
    private const string AmountFormat = "# ##0.00;-# ##0.00;#";
    private string GroupField => IsGeneral ? nameof(CptEcritureItem.CompteLabel) : nameof(CptEcritureItem.TierLabel);
    private string ToolbarSummary => IsGeneral
        ? $"{balanceItems.Count} compte(s) | {ecritureItems.Count} écriture(s) | {PeriodLabel}"
        : $"{comptesClients.Count} client(s) | {comptesFournisseurs.Count} fournisseur(s) | {ecritureItems.Count} écriture(s) | {PeriodLabel}";

    private string PeriodLabel => CurrentExo == null
        ? "—"
        : $"{dateDebut:dd/MM/yyyy} — {dateFin:dd/MM/yyyy}";

    bool IsLoaded;
    private bool isDataLoading;
    private int loadSeq;

    protected override async Task OnInitializedAsync()
    {
        db = session.db;
        LoadExercices();
        SyncDatesToExercice();
        await LoadData();
    }

    private void LoadExercices()
    {
        var d = db.P_DOSSIER.FirstOrDefault();
        if (d == null) return;

        var raw = new (DateTime? Debut, DateTime? Fin)[]
        {
            (d.D_DebutExo01, d.D_FinExo01), (d.D_DebutExo02, d.D_FinExo02),
            (d.D_DebutExo03, d.D_FinExo03), (d.D_DebutExo04, d.D_FinExo04),
            (d.D_DebutExo05, d.D_FinExo05),
        };

        exoItems = raw
            .Where(x => x.Debut.HasValue && x.Fin.HasValue && x.Debut.Value.Year > 1900)
            .OrderByDescending(x => x.Debut)
            .Select((x, i) => new ExoItem
            {
                Idx = i,
                Debut = x.Debut!.Value.Date,
                Fin = x.Fin!.Value.Date,
                Label = ExoLabel(x.Debut!.Value, x.Fin!.Value)
            })
            .ToList();

        selectedExoIndex = 0;
    }

    private static string ExoLabel(DateTime d, DateTime f)
    {
        bool cal = d.Day == 1 && d.Month == 1 && f.Day == 31 && f.Month == 12 && d.Year == f.Year;
        return cal ? d.Year.ToString() : $"{d:dd/MM/yy} — {f:dd/MM/yy}";
    }

    private void SyncDatesToExercice()
    {
        if (CurrentExo == null) return;
        dateDebut = CurrentExo.Debut;
        dateFin = CurrentExo.Fin;
    }

    private void ClampDates()
    {
        if (CurrentExo == null) return;
        if (dateDebut < CurrentExo.Debut) dateDebut = CurrentExo.Debut;
        if (dateFin > CurrentExo.Fin) dateFin = CurrentExo.Fin;
        if (dateDebut > dateFin) dateDebut = dateFin;
    }

