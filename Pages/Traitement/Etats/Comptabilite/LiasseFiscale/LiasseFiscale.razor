@page "/cpt-liasse"
@attribute [Authorize]
@implements IDisposable

@if (IsLoaded)
{
    <Card_1 Title="LIASSE FISCALE IS">
        <RadzenContent>
            <div class="grid-container no-border">

                <SfToolbar CssClass="btns">
                    <ToolbarItems>
                        <ToolbarItem Align="ItemAlign.Left">
                            <Template>
                                <SfMessage Severity="MessageSeverity.Info" Variant="MessageVariant.Outlined">
                                    <div style="text-transform: uppercase;">
                                        Modèle Normal IS
                                    </div>
                                </SfMessage>
                            </Template>
                        </ToolbarItem>
                        <ToolbarItem Align="ItemAlign.Right" Type="ItemType.Input">
                            <Template>
                                <SfDropDownList TValue="int" TItem="ExoItem" Width="200px"
                                                @bind-Value="selectedExoIndex" DataSource="@exoItems"
                                                Placeholder="Exercice">
                                    <DropDownListFieldSettings Text="Label" Value="Idx" />
                                    <DropDownListEvents TValue="int" TItem="ExoItem"
                                                        ValueChange="@(args => LoadData())" />
                                </SfDropDownList>
                            </Template>
                        </ToolbarItem>
                    </ToolbarItems>
                </SfToolbar>

                <SfTab CssClass="e-fill lf-tabs" HeaderPlacement="HeaderPosition.Left">
                    <TabItems>

                        @* ══ T00 — IDENTIFICATION ══ *@
                        <TabItem>
                            <ChildContent><TabHeader Text="T00 — Identification"></TabHeader></ChildContent>
                            <ContentTemplate>
                                <div class="lf-section">
                                    <div class="lf-title">IDENTIFICATION DE L'ENTREPRISE — DÉCLARATION FISCALE IS</div>
                                    <div class="lf-note">ℹ️ Modèle 100/IS/N — Modèle Comptable Normal. Les informations d'identification sont à compléter manuellement.</div>
                                    <div class="table-responsive">
                                        <table class="lf-table">
                                            <thead>
                                                <tr><th class="col-label">Rubrique</th><th class="col-label">Valeur</th></tr>
                                            </thead>
                                            <tbody>
                                                <tr class="lf-total"><td class="fw-bold">Exercice comptable</td><td>@(CurrentExo?.Label ?? "—")</td></tr>
                                                <tr class="lf-total"><td class="fw-bold">Du</td><td>@(CurrentExo?.Debut.ToString("dd/MM/yyyy") ?? "—")</td></tr>
                                                <tr class="lf-total"><td class="fw-bold">Au</td><td>@(CurrentExo?.Fin.ToString("dd/MM/yyyy") ?? "—")</td></tr>
                                                <tr class="lf-subheader"><td colspan="2" class="fw-bold">INFORMATIONS SOCIÉTÉ (à saisir)</td></tr>
                                                <tr><td>Raison sociale</td><td>—</td></tr>
                                                <tr><td>Identifiant fiscal (IF)</td><td>—</td></tr>
                                                <tr><td>I.C.E.</td><td>—</td></tr>
                                                <tr><td>Numéro RC</td><td>—</td></tr>
                                                <tr><td>CNSS</td><td>—</td></tr>
                                                <tr><td>Activité principale</td><td>—</td></tr>
                                                <tr><td>Adresse</td><td>—</td></tr>
                                                <tr><td>Ville</td><td>—</td></tr>
                                                <tr><td>Téléphone</td><td>—</td></tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </ContentTemplate>
                        </TabItem>

                        @* ══ BILAN ACTIF ══ *@
                        <TabItem>
                            <ChildContent><TabHeader Text="T01 — Bilan Actif"></TabHeader></ChildContent>
                            <ContentTemplate>
                                <div class="lf-section">
                                    <div class="lf-title">BILAN — ACTIF</div>
                                    <div class="table-responsive">
                                        <table class="lf-table">
                                            <thead>
                                                <tr>
                                                    <th class="col-cat"></th>
                                                    <th class="col-label">Éléments</th>
                                                    <th class="col-num">Brut</th>
                                                    <th class="col-num">Amort. &amp; Prov.</th>
                                                    <th class="col-num">Net</th>
                                                    <th class="col-num">Exercice Précédent</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var line in actifLines)
                                                {
                                                    <tr class="@BilanRowClass(line.IsHeader, line.IsTotal, line.Cat) @(line.Pfx != null ? "cell-link" : "")"
                                                        @onclick="@(() => OnCellClick(line.Label.Length > 0 ? line.Label : line.Cat, line.Pfx))">
                                                        <td class="col-cat">@(line.IsHeader || line.IsTotal ? line.Cat : "")</td>
                                                        <td class="col-label @(line.IsHeader ? "fw-bold upcase" : "")">@line.Label</td>
                                                        <td class="col-num">@Fmt(line.Brut)</td>
                                                        <td class="col-num">@Fmt(line.Amort)</td>
                                                        <td class="col-num">@Fmt(line.Net)</td>
                                                        <td class="col-num">@Fmt(line.PrevNet)</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </ContentTemplate>
                        </TabItem>

                        @* ══ BILAN PASSIF ══ *@
                        <TabItem>
                            <ChildContent><TabHeader Text="T01 — Bilan Passif"></TabHeader></ChildContent>
                            <ContentTemplate>
                                <div class="lf-section">
                                    <div class="lf-title">BILAN — PASSIF</div>
                                    <div class="table-responsive">
                                        <table class="lf-table">
                                            <thead>
                                                <tr>
                                                    <th class="col-cat"></th>
                                                    <th class="col-label">Éléments</th>
                                                    <th class="col-num">Exercice</th>
                                                    <th class="col-num">Exercice Précédent</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var line in passifLines)
                                                {
                                                    <tr class="@BilanRowClass(line.IsHeader, line.IsTotal, line.Cat) @(line.Pfx != null ? "cell-link" : "")"
                                                        @onclick="@(() => OnCellClick(line.Label.Length > 0 ? line.Label : line.Cat, line.Pfx))">
                                                        <td class="col-cat">@(line.IsHeader || line.IsTotal ? line.Cat : "")</td>
                                                        <td class="col-label @(line.IsHeader ? "fw-bold upcase" : "")">@line.Label</td>
                                                        <td class="col-num">@Fmt(line.Val)</td>
                                                        <td class="col-num">@Fmt(line.PrevVal)</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </ContentTemplate>
                        </TabItem>

                        @* ══ CPC ══ *@
                        <TabItem>
                            <ChildContent><TabHeader Text="T02 — C.P.C."></TabHeader></ChildContent>
                            <ContentTemplate>
                                <div class="lf-section">
                                    <div class="lf-title">COMPTE DE PRODUITS ET CHARGES (C.P.C.)</div>
                                    <div class="table-responsive">
                                        <table class="lf-table">
                                            <thead>
                                                <tr>
                                                    <th class="col-sign"></th>
                                                    <th class="col-label">Nature</th>
                                                    <th class="col-num">Exercice</th>
                                                    <th class="col-num">Exercice Précédent</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var line in cpcLines)
                                                {
                                                    <tr class="@CpcRowClass(line) @(line.Pfx != null ? "cell-link" : "")"
                                                        @onclick="@(() => OnCellClick(line.Label.Length > 0 ? line.Label : line.Cat, line.Pfx))">
                                                        <td class="col-sign">@(line.IsTotal || line.IsResult ? line.Cat : "")</td>
                                                        <td class="col-label @(line.IsHeader || line.IsTotal || line.IsResult ? "fw-bold" : "")">@line.Label</td>
                                                        <td class="col-num">@(line.IsHeader ? "" : Fmt(line.Val))</td>
                                                        <td class="col-num">@(line.IsHeader ? "" : Fmt(line.PrevVal))</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </ContentTemplate>
                        </TabItem>

                        @* ══ T03 — RÉSULTAT FISCAL ══ *@
                        <TabItem>
                            <ChildContent><TabHeader Text="T03 — Résultat Fiscal"></TabHeader></ChildContent>
                            <ContentTemplate>
                                <div class="lf-section">
                                    <div class="lf-title">PASSAGE DU RÉSULTAT NET COMPTABLE AU RÉSULTAT NET FISCAL</div>
                                    <div class="table-responsive">
                                        <table class="lf-table">
                                            <thead>
                                                <tr>
                                                    <th class="col-label">Intitulés</th>
                                                    <th class="col-num" style="width:160px">Réintégrations</th>
                                                    <th class="col-num" style="width:160px">Déductions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var line in t03Lines)
                                                {
                                                    <tr class="@T03RowClass(line) @(line.Pfx != null ? "cell-link" : "")"
                                                        @onclick="@(() => OnCellClick(line.Label, line.Pfx))">
                                                        <td class="col-label @(line.IsSection || line.IsTotal ? "fw-bold" : "")">@line.Label</td>
                                                        <td class="col-num">@(line.Col == 1 ? Fmt(line.Val) : "")</td>
                                                        <td class="col-num">@(line.Col == 2 ? Fmt(line.Val) : (line.Col == 3 ? Fmt(line.Val) : ""))</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </ContentTemplate>
                        </TabItem>

                        @* ══ T04 — IMMOBILISATIONS ══ *@
                        <TabItem>
                            <ChildContent><TabHeader Text="T04 — Immobilisations"></TabHeader></ChildContent>
                            <ContentTemplate>
                                <div class="lf-section" style="max-width:1100px;">
                                    <div class="lf-title">TABLEAU DES IMMOBILISATIONS AUTRES QUE FINANCIÈRES</div>
                                    <div class="table-responsive">
                                        <table class="lf-table">
                                            <thead>
                                                <tr>
                                                    <th class="col-label">Nature</th>
                                                    <th class="col-num">Montant Brut<br/>Début Exercice</th>
                                                    <th class="col-num">Augmentations<br/>(Acquisitions)</th>
                                                    <th class="col-num">Diminutions<br/>(Cessions/Retraits)</th>
                                                    <th class="col-num">Montant Brut<br/>Fin Exercice</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var line in t04Lines)
                                                {
                                                    <tr class="@(line.IsHeader ? "lf-header" : line.IsTotal ? "lf-total" : "") @(line.Pfx != null ? "cell-link" : "")"
                                                        @onclick="@(() => OnCellClick(line.Label, line.Pfx))">
                                                        <td class="col-label @(line.IsHeader || line.IsTotal ? "fw-bold" : "")">@line.Label</td>
                                                        <td class="col-num">@(line.IsHeader ? "" : Fmt(line.BrutDebut))</td>
                                                        <td class="col-num">@(line.IsHeader ? "" : Fmt(line.Acq))</td>
                                                        <td class="col-num">@(line.IsHeader ? "" : Fmt(line.Cess))</td>
                                                        <td class="col-num">@(line.IsHeader ? "" : Fmt(line.BrutFin))</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </ContentTemplate>
                        </TabItem>

                        @* ══ ESG — TFR ══ *@
                        <TabItem>
                            <ChildContent><TabHeader Text="T05 — T.F.R."></TabHeader></ChildContent>
                            <ContentTemplate>
                                <div class="lf-section">
                                    <div class="lf-title">TABLEAU DE FORMATION DES RÉSULTATS (T.F.R.)</div>
                                    <div class="table-responsive">
                                        <table class="lf-table">
                                            <thead>
                                                <tr>
                                                    <th class="col-sign"></th>
                                                    <th class="col-label">Nature</th>
                                                    <th class="col-num">Exercice</th>
                                                    <th class="col-num">Exercice Précédent</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var line in tfrLines)
                                                {
                                                    <tr class="@EsgRowClass(line) @(line.Pfx != null ? "cell-link" : "")"
                                                        @onclick="@(() => OnCellClick(line.Label, line.Pfx))">
                                                        <td class="col-sign">@line.Sign</td>
                                                        <td class="col-label">@line.Label</td>
                                                        <td class="col-num">@Fmt(line.Val)</td>
                                                        <td class="col-num">@Fmt(line.PrevVal)</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </ContentTemplate>
                        </TabItem>

                        @* ══ ESG — CAF ══ *@
                        <TabItem>
                            <ChildContent><TabHeader Text="T05 — C.A.F."></TabHeader></ChildContent>
                            <ContentTemplate>
                                <div class="lf-section">
                                    <div class="lf-title">CAPACITÉ D'AUTOFINANCEMENT (C.A.F.) — AUTOFINANCEMENT</div>
                                    <div class="table-responsive">
                                        <table class="lf-table">
                                            <thead>
                                                <tr>
                                                    <th class="col-sign"></th>
                                                    <th class="col-label">Nature</th>
                                                    <th class="col-num">Exercice</th>
                                                    <th class="col-num">Exercice Précédent</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var line in cafLines)
                                                {
                                                    <tr class="@EsgRowClass(line) @(line.Pfx != null ? "cell-link" : "")"
                                                        @onclick="@(() => OnCellClick(line.Label, line.Pfx))">
                                                        <td class="col-sign">@line.Sign</td>
                                                        <td class="col-label">@line.Label</td>
                                                        <td class="col-num">@Fmt(line.Val)</td>
                                                        <td class="col-num">@Fmt(line.PrevVal)</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </ContentTemplate>
                        </TabItem>

                        @* ══ T06 — DÉTAIL CPC ══ *@
                        <TabItem>
                            <ChildContent><TabHeader Text="T06 — Détail C.P.C."></TabHeader></ChildContent>
                            <ContentTemplate>
                                <div class="lf-section">
                                    <div class="lf-title">DÉTAIL DES POSTES DU C.P.C.</div>
                                    <div class="table-responsive">
                                        <table class="lf-table">
                                            <thead>
                                                <tr>
                                                    <th class="col-sign">Poste</th>
                                                    <th class="col-label">Intitulé</th>
                                                    <th class="col-num">Exercice</th>
                                                    <th class="col-num">Exercice Précédent</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var line in t06Lines)
                                                {
                                                    <tr class="@T06RowClass(line) @(line.Pfx != null ? "cell-link" : "")"
                                                        @onclick="@(() => OnCellClick(line.Label, line.Pfx))">
                                                        <td class="col-sign" style="font-size:.72rem">@line.Poste</td>
                                                        <td class="col-label @(line.IsSection || line.IsPoste || line.IsTotal ? "fw-bold" : "  pl-indent")">@line.Label</td>
                                                        <td class="col-num">@(line.IsSection ? "" : Fmt(line.Val))</td>
                                                        <td class="col-num">@(line.IsSection ? "" : Fmt(line.Prev))</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </ContentTemplate>
                        </TabItem>

                        @* ══ T07 — CRÉDIT-BAIL ══ *@
                        <TabItem>
                            <ChildContent><TabHeader Text="T07 — Crédit-Bail"></TabHeader></ChildContent>
                            <ContentTemplate>
                                <div class="lf-section">
                                    <div class="lf-title">TABLEAU DES BIENS EN CRÉDIT-BAIL</div>
                                    <div class="lf-note">
                                        ℹ️ Ce tableau nécessite une saisie manuelle des détails de chaque contrat (fournisseur, durée, montant du bien).
                                        Seul le total des redevances comptabilisées (compte 6132) est extrait automatiquement.
                                    </div>
                                    <div class="table-responsive">
                                        <table class="lf-table">
                                            <thead>
                                                <tr>
                                                    <th class="col-label">Nature des biens</th>
                                                    <th class="col-num">Redevances payées<br/>Exercice N</th>
                                                    <th class="col-num">Redevances payées<br/>Exercice N-1</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr class="lf-total">
                                                    <td class="col-label fw-bold">Total Redevances de Crédit-Bail (6132)</td>
                                                    <td class="col-num">@Fmt(C("6132"))</td>
                                                    <td class="col-num">@Fmt(P("6132"))</td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </ContentTemplate>
                        </TabItem>

                        @* ══ T08 — AMORTISSEMENTS ══ *@
                        <TabItem>
                            <ChildContent><TabHeader Text="T08 — Amortissements"></TabHeader></ChildContent>
                            <ContentTemplate>
                                <div class="lf-section" style="max-width:1100px;">
                                    <div class="lf-title">TABLEAU DES AMORTISSEMENTS</div>
                                    <div class="table-responsive">
                                        <table class="lf-table">
                                            <thead>
                                                <tr>
                                                    <th class="col-label">Nature</th>
                                                    <th class="col-num">Cumul<br/>Début Exercice</th>
                                                    <th class="col-num">Dotation<br/>Exercice</th>
                                                    <th class="col-num">Amort. sur Immo<br/>Sorties</th>
                                                    <th class="col-num">Cumul<br/>Fin Exercice</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var line in t08Lines)
                                                {
                                                    <tr class="@(line.IsHeader ? "lf-header" : line.IsTotal ? "lf-total" : "") @(line.Pfx != null ? "cell-link" : "")"
                                                        @onclick="@(() => OnCellClick(line.Label, line.Pfx))">
                                                        <td class="col-label @(line.IsHeader || line.IsTotal ? "fw-bold" : "")">@line.Label</td>
                                                        <td class="col-num">@(line.IsHeader ? "" : Fmt(line.CumulDebut))</td>
                                                        <td class="col-num">@(line.IsHeader ? "" : Fmt(line.Dotation))</td>
                                                        <td class="col-num">@(line.IsHeader ? "" : Fmt(line.Sorties))</td>
                                                        <td class="col-num">@(line.IsHeader ? "" : Fmt(line.CumulFin))</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </ContentTemplate>
                        </TabItem>

                        @* ══ T09 — PROVISIONS ══ *@
                        <TabItem>
                            <ChildContent><TabHeader Text="T09 — Provisions"></TabHeader></ChildContent>
                            <ContentTemplate>
                                <div class="lf-section" style="max-width:1100px;">
                                    <div class="lf-title">TABLEAU DES PROVISIONS</div>
                                    <div class="table-responsive">
                                        <table class="lf-table">
                                            <thead>
                                                <tr>
                                                    <th class="col-label">Nature</th>
                                                    <th class="col-num">Début<br/>Exercice</th>
                                                    <th class="col-num">Dotations<br/>Exercice</th>
                                                    <th class="col-num">Reprises<br/>Exercice</th>
                                                    <th class="col-num">Fin<br/>Exercice</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var line in t09Lines)
                                                {
                                                    <tr class="@(line.IsHeader ? "lf-header" : line.IsTotal ? "lf-total" : "") @(line.Pfx != null ? "cell-link" : "")"
                                                        @onclick="@(() => OnCellClick(line.Label, line.Pfx))">
                                                        <td class="col-label @(line.IsTotal ? "fw-bold" : "")">@line.Label</td>
                                                        <td class="col-num">@Fmt(line.Debut)</td>
                                                        <td class="col-num">@Fmt(line.TotDot)</td>
                                                        <td class="col-num">@Fmt(line.TotRep)</td>
                                                        <td class="col-num">@Fmt(line.Fin)</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </ContentTemplate>
                        </TabItem>

                        @* ══ T10 — PLUS/MOINS VALUES ══ *@
                        <TabItem>
                            <ChildContent><TabHeader Text="T10 — Plus/Moins Values"></TabHeader></ChildContent>
                            <ContentTemplate>
                                <div class="lf-section" style="max-width:1000px;">
                                    <div class="lf-title">TABLEAU DES PLUS ET MOINS VALUES SUR CESSIONS D'IMMOBILISATIONS</div>
                                    <div class="table-responsive">
                                        <table class="lf-table">
                                            <thead>
                                                <tr>
                                                    <th class="col-label">Nature des immobilisations</th>
                                                    <th class="col-num">Produit de<br/>Cession (751)</th>
                                                    <th class="col-num">V.N.A.<br/>(651)</th>
                                                    <th class="col-num">Plus-Value</th>
                                                    <th class="col-num">Moins-Value</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var line in t10Lines)
                                                {
                                                    <tr class="@(line.IsHeader ? "lf-header" : line.IsTotal ? "lf-total" : "") @(line.Pfx != null ? "cell-link" : "")"
                                                        @onclick="@(() => OnCellClick(line.Label, line.Pfx))">
                                                        <td class="col-label @(line.IsTotal ? "fw-bold" : "")">@line.Label</td>
                                                        <td class="col-num">@Fmt(line.ProdCession)</td>
                                                        <td class="col-num">@Fmt(line.VNA)</td>
                                                        <td class="col-num" style="@(line.PlusValue > 0 ? "color:#16a34a;font-weight:700;" : "")">@Fmt(line.PlusValue)</td>
                                                        <td class="col-num" style="@(line.MoinsValue > 0 ? "color:#c0392b;font-weight:700;" : "")">@Fmt(line.MoinsValue)</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </ContentTemplate>
                        </TabItem>

                        @* ══ T11 — TITRES DE PARTICIPATION ══ *@
                        <TabItem>
                            <ChildContent><TabHeader Text="T11 — Titres Part."></TabHeader></ChildContent>
                            <ContentTemplate>
                                <div class="lf-section">
                                    <div class="lf-title">TABLEAU DES TITRES DE PARTICIPATION ET AUTRES TITRES IMMOBILISÉS</div>
                                    <div class="lf-note">
                                        ℹ️ Les détails par société (raison sociale, capital, quote-part, dividendes) nécessitent une saisie manuelle.
                                    </div>
                                    <div class="table-responsive">
                                        <table class="lf-table">
                                            <thead>
                                                <tr>
                                                    <th class="col-label">Désignation</th>
                                                    <th class="col-num">Exercice N</th>
                                                    <th class="col-num">Exercice N-1</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var line in t11Lines)
                                                {
                                                    <tr class="@(line.IsTotal ? "lf-total" : "") @(line.Pfx != null ? "cell-link" : "")"
                                                        @onclick="@(() => OnCellClick(line.Label, line.Pfx))">
                                                        <td class="col-label @(line.IsTotal ? "fw-bold" : "")">@line.Label</td>
                                                        <td class="col-num">@Fmt(line.ValN)</td>
                                                        <td class="col-num">@Fmt(line.ValN1)</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </ContentTemplate>
                        </TabItem>

                        @* ══ T12 — TVA ══ *@
                        <TabItem>
                            <ChildContent><TabHeader Text="T12 — Détail TVA"></TabHeader></ChildContent>
                            <ContentTemplate>
