                    </table>
                }
            </Content>
        </DialogTemplates>
    </SfDialog>
}
else
{
    <div class="center-screen"><Loading_1 /></div>
}

@code {
    [CascadingParameter] public SessionDT session { get; set; } = new SessionDT();
    DB db = new DB();
    bool IsLoaded = false;

    // ── Exercices ────────────────────────────────────────────────────
    private class ExoItem { public int Idx { get; set; } public string Label { get; set; } public DateTime Debut { get; set; } public DateTime Fin { get; set; } }
    private List<ExoItem> exoItems = new();
    private int selectedExoIndex = 0;
    private ExoItem CurrentExo => exoItems.Count > 0 ? exoItems[selectedExoIndex] : null;
    private ExoItem PrevExo    => selectedExoIndex + 1 < exoItems.Count ? exoItems[selectedExoIndex + 1] : null;

    // ── Records ──────────────────────────────────────────────────────
    private record ActifLine (string Cat, string Label, bool IsHeader, bool IsTotal, decimal Brut, decimal Amort, decimal PrevNet, string[] Pfx = null) { public decimal Net => Brut - Amort; }
    private record PassifLine(string Cat, string Label, bool IsHeader, bool IsTotal, decimal Val,  decimal PrevVal,  string[] Pfx = null);
    private record CpcLine   (string Cat, string Label, bool IsHeader, bool IsTotal, bool IsResult, decimal Val, decimal PrevVal, string[] Pfx = null);
    private record EsgLine   (string Sign, string Label, bool IsResult, bool IsGrand, decimal Val, decimal PrevVal, string[] Pfx = null);
    private record SyntheseLine(string Label, bool IsTotal, decimal ValN, decimal ValN1, string[] Pfx = null)
    {
        public decimal Var      => ValN - ValN1;
        public decimal Emploi   => Var > 0 ?  Var : 0;
        public decimal Ressource => Var < 0 ? -Var : 0;
    }
    private record TfLine(string Label, bool IsHeader, bool IsTotal, decimal Val, decimal PrevVal, string[] Pfx = null);
    // Col: 1=réintégration, 2=déduction, 3=both (total row showing résultat)
    private record T03Line(string Label, bool IsSection, bool IsTotal, bool IsGrand, int Col, decimal Val, string[] Pfx = null);
    private record ImmobLine(string Label, bool IsHeader, bool IsTotal, decimal BrutDebut, decimal Acq, decimal Cess, decimal BrutFin, string[] Pfx = null);
    private record T06Line(string Poste, string Label, bool IsSection, bool IsPoste, bool IsTotal, decimal Val, decimal Prev, string[] Pfx = null);
    private record AmortLine(string Label, bool IsHeader, bool IsTotal, decimal CumulDebut, decimal Dotation, decimal Sorties, string[] Pfx = null)
    {
        public decimal CumulFin => CumulDebut + Dotation - Sorties;
    }
    private record ProvLine(string Label, bool IsHeader, bool IsTotal, decimal Debut, decimal TotDot, decimal TotRep, decimal Fin, string[] Pfx = null);
    private record CessionLine(string Label, bool IsHeader, bool IsTotal, decimal ProdCession, decimal VNA, string[] Pfx = null)
    {
        public decimal PlusValue  => ProdCession > VNA ? ProdCession - VNA : 0m;
        public decimal MoinsValue => VNA > ProdCession ? VNA - ProdCession : 0m;
    }
    private record TvaLine(string Label, bool IsSub, bool IsTotal, decimal Debut, decimal Fin, string[] Pfx = null);
    private record AffLine(string LabelA, decimal ValA, string LabelB, decimal ValB, bool IsTotal, bool IsHeader);
    private record StockLine(string Label, bool IsHeader, bool IsSubItem, bool IsTotal, decimal FinBrut, decimal FinProv, decimal IniBrut, decimal IniProv, string[] Pfx = null)
    {
        public decimal FinNet    => FinBrut - FinProv;
        public decimal IniNet    => IniBrut - IniProv;
        public decimal Variation => FinNet - IniNet;
    }

    // ── Data lists ───────────────────────────────────────────────────
    private List<ActifLine>    actifLines      = new();
    private List<PassifLine>   passifLines     = new();
    private List<CpcLine>      cpcLines        = new();
    private List<EsgLine>      tfrLines        = new();
    private List<EsgLine>      cafLines        = new();
    private List<SyntheseLine> syntheseLines   = new();
    private List<TfLine>       emploisLines    = new();
    private List<TfLine>       ressourcesLines = new();
    private List<T03Line>      t03Lines        = new();
    private List<ImmobLine>    t04Lines        = new();
    private List<T06Line>      t06Lines        = new();
    private List<AmortLine>    t08Lines        = new();
    private List<ProvLine>     t09Lines        = new();
    private List<CessionLine>  t10Lines        = new();
    private List<SyntheseLine> t11Lines        = new();
    private List<TvaLine>      t12Lines        = new();
    private List<AffLine>      t14Lines        = new();
    private List<StockLine>    t20Lines        = new();

    // ── Detail popup ─────────────────────────────────────────────────
    private bool     showDetail  = false;
    private string   detailTitle = "";
    private string[] detailPfx   = null;
    private class DetailItem { public string CG_Num { get; set; } public decimal Solde { get; set; } }
    private List<DetailItem> detailItems = new();

    // Shared TFR → CAF values
    private decimal _rnet, _rnetp, _de, _dep, _t5fin, _t5finp, _t9nc, _t9ncp;
    private decimal _rpe, _rpep, _rpf, _rpfp, _rpnc, _rpncp, _pci, _pcip, _vna, _vnap;

    // ── Lifecycle ────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        db = session.db;
        GC.Collect();
        await Task.Delay(1);
        LoadExercices();
        await LoadData();
        IsLoaded = true;
    }

    private void LoadExercices()
    {
        var d = db.P_DOSSIER.FirstOrDefault();
        if (d == null) return;
        var raw = new (DateTime? Debut, DateTime? Fin)[]
        {
            (d.D_DebutExo01, d.D_FinExo01), (d.D_DebutExo02, d.D_FinExo02),
            (d.D_DebutExo03, d.D_FinExo03), (d.D_DebutExo04, d.D_FinExo04),
            (d.D_DebutExo05, d.D_FinExo05),
        };
        exoItems = raw
            .Where(x => x.Debut.HasValue && x.Fin.HasValue && x.Debut.Value.Year > 1900)
            .OrderByDescending(x => x.Debut)
            .Select((x, i) => new ExoItem { Idx = i, Debut = x.Debut!.Value, Fin = x.Fin!.Value, Label = ExoLabel(x.Debut!.Value, x.Fin!.Value) })
            .ToList();
        selectedExoIndex = 0;
    }

    private static string ExoLabel(DateTime d, DateTime f)
    {
        bool cal = d.Day == 1 && d.Month == 1 && f.Day == 31 && f.Month == 12 && d.Year == f.Year;
        return cal ? d.Year.ToString() : $"{d:dd/MM/yy} — {f:dd/MM/yy}";
    }

    private async Task LoadData()
    {
        IsLoaded = false;
        await Task.Delay(300);
        if (CurrentExo != null)
        {
            BuildActif();
            BuildPassif();
            BuildCPC();
            BuildTFR();   // sets shared _* fields
            BuildCAF();   // reads shared _* fields
            BuildSynthese();
            BuildEmploisRessources();
            BuildT03();
            BuildT04();
            BuildT06();
            BuildT08();
            BuildT09();
            BuildT10();
            BuildT11();
            BuildT12();
            BuildT14();
            BuildT20();
        }
        IsLoaded = true;
        await Task.Delay(300);
    }

    // ── Query helpers ─────────────────────────────────────────────────
    private decimal S(string pfx, DateTime debut, DateTime fin) =>
        db.F_ECRITUREC
          .Where(e => e.EC_Date.HasValue && e.EC_Date.Value >= debut && e.EC_Date.Value <= fin
                   && e.CG_Num != null && e.CG_Num.StartsWith(pfx))
          .Sum(e => e.EC_Sens == 0 ? (e.EC_Montant ?? 0m) : -(e.EC_Montant ?? 0m));

    private decimal C(string pfx) => CurrentExo != null ? S(pfx, CurrentExo.Debut, CurrentExo.Fin) : 0m;
    private decimal P(string pfx) => PrevExo    != null ? S(pfx, PrevExo.Debut,    PrevExo.Fin)    : 0m;

    private decimal Balance(string pfx, DateTime asOf) =>
        db.F_ECRITUREC
          .Where(e => e.EC_Date.HasValue && e.EC_Date.Value <= asOf
                   && e.CG_Num != null && e.CG_Num.StartsWith(pfx))
          .Sum(e => e.EC_Sens == 0 ? (e.EC_Montant ?? 0m) : -(e.EC_Montant ?? 0m));

    private decimal BN (string pfx) => CurrentExo != null ? Balance(pfx, CurrentExo.Fin) : 0m;
    private decimal BN1(string pfx) => PrevExo    != null ? Balance(pfx, PrevExo.Fin)    : 0m;

    // Debit-only / Credit-only movements within current or prev exercice
    private decimal SD(string pfx) => CurrentExo == null ? 0m :
        db.F_ECRITUREC.Where(e => e.EC_Date.HasValue && e.EC_Date.Value >= CurrentExo.Debut && e.EC_Date.Value <= CurrentExo.Fin
                              && e.CG_Num != null && e.CG_Num.StartsWith(pfx) && e.EC_Sens == 0)
          .Sum(e => e.EC_Montant ?? 0m);
    private decimal SC(string pfx) => CurrentExo == null ? 0m :
        db.F_ECRITUREC.Where(e => e.EC_Date.HasValue && e.EC_Date.Value >= CurrentExo.Debut && e.EC_Date.Value <= CurrentExo.Fin
                              && e.CG_Num != null && e.CG_Num.StartsWith(pfx) && e.EC_Sens == 1)
          .Sum(e => e.EC_Montant ?? 0m);
    private decimal SD1(string pfx) => PrevExo == null ? 0m :
        db.F_ECRITUREC.Where(e => e.EC_Date.HasValue && e.EC_Date.Value >= PrevExo.Debut && e.EC_Date.Value <= PrevExo.Fin
                              && e.CG_Num != null && e.CG_Num.StartsWith(pfx) && e.EC_Sens == 0)
          .Sum(e => e.EC_Montant ?? 0m);
    private decimal SC1(string pfx) => PrevExo == null ? 0m :
        db.F_ECRITUREC.Where(e => e.EC_Date.HasValue && e.EC_Date.Value >= PrevExo.Debut && e.EC_Date.Value <= PrevExo.Fin
                              && e.CG_Num != null && e.CG_Num.StartsWith(pfx) && e.EC_Sens == 1)
          .Sum(e => e.EC_Montant ?? 0m);

    // ── Detail click ─────────────────────────────────────────────────
    private void OnCellClick(string label, string[] pfx)
    {
        if (pfx == null || pfx.Length == 0 || CurrentExo == null) return;
        var debut = CurrentExo.Debut; var fin = CurrentExo.Fin;
        detailTitle = label; detailPfx = pfx;
        detailItems = pfx
            .SelectMany(p => db.F_ECRITUREC
                .Where(e => e.EC_Date.HasValue && e.EC_Date.Value >= debut && e.EC_Date.Value <= fin
                         && e.CG_Num != null && e.CG_Num.StartsWith(p))
                .GroupBy(e => e.CG_Num)
                .Select(g => new DetailItem { CG_Num = g.Key, Solde = g.Sum(e => e.EC_Sens == 0 ? (e.EC_Montant ?? 0m) : -(e.EC_Montant ?? 0m)) })
                .ToList())
            .GroupBy(x => x.CG_Num)
            .Select(g => new DetailItem { CG_Num = g.Key, Solde = g.Sum(x => x.Solde) })
            .OrderBy(x => x.CG_Num).ToList();
        showDetail = true;
    }

    // ════════════════════════════════════════════════════════════════
    // BILAN — ACTIF
    // ════════════════════════════════════════════════════════════════
    private void BuildActif()
    {
        var L = new List<ActifLine>();

        decimal fPrB=C("211"),fPrA=-C("2811"),fPrP=P("211")+P("2811");
        decimal chB=C("212"),chA=-C("2812"),chP=P("212")+P("2812");
        decimal pmB=C("213"),pmA=-C("2813"),pmP=P("213")+P("2813");
        decimal nvB=fPrB+chB+pmB,nvA=fPrA+chA+pmA,nvP=fPrP+chP+pmP;
        L.Add(new("ACTIF IMMOBILISÉ","IMMOBILISATION EN NON VALEUR ( a )",true,false,nvB,nvA,nvP,new[]{"211","2811","212","2812","213","2813"}));
        L.Add(new("","Frais préliminaires",false,false,fPrB,fPrA,fPrP,new[]{"211","2811"}));
        L.Add(new("","Charges à repartir sur plusieurs exercices",false,false,chB,chA,chP,new[]{"212","2812"}));
        L.Add(new("","Primes de remboursement des obligations",false,false,pmB,pmA,pmP,new[]{"213","2813"}));

