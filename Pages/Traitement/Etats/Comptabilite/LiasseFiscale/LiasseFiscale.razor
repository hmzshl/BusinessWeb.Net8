                                                <tr><td class="col-sign">B</td><td>IS calculé = Résultat fiscal × taux IS</td><td class="col-num">À saisir</td><td class="col-num">-</td></tr>
                                                <tr><td class="col-sign">C</td><td>Cotisation Minimale (CM) = CA × 0,50 %</td><td class="col-num">0,50 %</td><td class="col-num">@Fmt((-C("711")-C("712")-C("718")-C("738")) * 0.005m)</td></tr>
                                                <tr class="lf-total">
                                                    <td class="col-sign">D</td>
                                                    <td class="fw-bold">IS / CM effectivement payé (compte 670)</td>
                                                    <td class="col-num">—</td>
                                                    <td class="col-num fw-bold">@Fmt(C("670"))</td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </ContentTemplate>
                        </TabItem>

                    </TabItems>
                </SfTab>

            </div>
        </RadzenContent>
    </Card_1>

    <SfDialog @bind-Visible="showDetail" Width="520px" ShowCloseIcon="true" IsModal="true">
        <DialogTemplates>
            <Header>@detailTitle</Header>
            <Content>
                <div style="font-size:.76rem;color:#6b7280;margin-bottom:.7rem;font-family:monospace;background:#f4f6fb;padding:.3rem .5rem;border-radius:4px;border:1px solid #dbe3ef;">
                    Plage : @string.Join("  |  ", detailPfx ?? Array.Empty<string>())
                </div>
                @if (detailItems.Count == 0)
                {
                    <p style="color:#888;font-size:.85rem;margin:0;">Aucun mouvement pour cette plage sur cet exercice.</p>
                }
                else
                {
                    <table class="detail-table">
                        <thead><tr><th>Compte</th><th style="text-align:right">Solde</th></tr></thead>
