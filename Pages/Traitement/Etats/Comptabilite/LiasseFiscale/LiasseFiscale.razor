        decimal v616=C("616"), p616=P("616");
        Poste("616","Impôts et taxes",v616,p616,new[]{"616"});
        Total("Total 616",v616,p616);

        decimal v617=C("617"), p617=P("617");
        Poste("617","Charges de personnel",v617,p617,new[]{"617"});
        Sub("— Rémunérations du personnel",C("6171"),P("6171"),new[]{"6171"});
