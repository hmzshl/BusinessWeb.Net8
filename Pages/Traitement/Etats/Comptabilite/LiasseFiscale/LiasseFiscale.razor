        L.Add(new("","Reprises financières; transferts de charges (4)",false,false,false,rpf,rpfp,new[]{"739"}));
        L.Add(new("IV","TOTAL  IV  —  PRODUITS FINANCIERS",false,true,false,t4,t4p));

        decimal ci=C("631"),cip=P("631"); decimal pc=C("632"),pcp=P("632");
        decimal acf=C("638"),acfp=P("638"); decimal df=C("639"),dfp=P("639");
        decimal t5=ci+pc+acf+df,t5p=cip+pcp+acfp+dfp;
        L.Add(new("","CHARGES FINANCIÈRES",true,false,false,0,0));
        L.Add(new("","Charges d'intérêts (1)",false,false,false,ci,cip,new[]{"631"}));
        L.Add(new("","Pertes de change (2)",false,false,false,pc,pcp,new[]{"632"}));
        L.Add(new("","Autres charges financières (3)",false,false,false,acf,acfp,new[]{"638"}));
        L.Add(new("","Dotations financières aux amortissements et provisions (4)",false,false,false,df,dfp,new[]{"639"}));
        L.Add(new("V","TOTAL  V  —  CHARGES FINANCIÈRES",false,true,false,t5,t5p));

        decimal re=t1-t2,rep=t1p-t2p; decimal rf=t4-t5,rfp=t4p-t5p; decimal rc=re+rf,rcp=rep+rfp;
        L.Add(new("VI","RÉSULTAT FINANCIER  ( IV - V )",false,false,true,rf,rfp));
        L.Add(new("VII","RÉSULTAT COURANT  ( III + VI )",false,false,true,rc,rcp));

        decimal pci=-C("751"),pcip=-P("751"); decimal seq=-C("756"),seqp=-P("756");
        decimal rsi=-C("757"),rsip=-P("757"); decimal apnc=-C("758"),apncp=-P("758");
        decimal rpnc=-C("759"),rpncp=-P("759"); decimal t8=pci+seq+rsi+apnc+rpnc,t8p=pcip+seqp+rsip+apncp+rpncp;
        L.Add(new("","PRODUITS NON COURANTS",true,false,false,0,0));
        L.Add(new("","Produits des cessions d'immobilisations (1)",false,false,false,pci,pcip,new[]{"751"}));
        L.Add(new("","Subventions d'équilibre (2)",false,false,false,seq,seqp,new[]{"756"}));
        L.Add(new("","Reprises sur subventions d'investissement (3)",false,false,false,rsi,rsip,new[]{"757"}));
        L.Add(new("","Autres produits non courants (4)",false,false,false,apnc,apncp,new[]{"758"}));
        L.Add(new("","Reprises non courantes; transferts de charges (5)",false,false,false,rpnc,rpncp,new[]{"759"}));
        L.Add(new("VIII","TOTAL  VIII  —  PRODUITS NON COURANTS",false,true,false,t8,t8p));

        decimal vna=C("651"),vnap=P("651"); decimal sa=C("656"),sap=P("656");
        decimal acnc=C("658"),acncp=P("658"); decimal dnc=C("659"),dncp=P("659");
        decimal t9=vna+sa+acnc+dnc,t9p=vnap+sap+acncp+dncp;
        L.Add(new("","CHARGES NON COURANTES",true,false,false,0,0));
        L.Add(new("","Valeurs nettes d'amortissement des immobilisations cédées (1)",false,false,false,vna,vnap,new[]{"651"}));
        L.Add(new("","Subventions accordées (2)",false,false,false,sa,sap,new[]{"656"}));
        L.Add(new("","Autres charges non courantes (3)",false,false,false,acnc,acncp,new[]{"658"}));
        L.Add(new("","Dotations non courantes aux amortissements et provisions (4)",false,false,false,dnc,dncp,new[]{"659"}));
        L.Add(new("IX","TOTAL  IX  —  CHARGES NON COURANTES",false,true,false,t9,t9p));

        decimal rnc=t8-t9,rncp=t8p-t9p; decimal ravi=rc+rnc,ravip=rcp+rncp;
        decimal imp=C("670"),impp=P("670"); decimal rnet=ravi-imp,rnetp=ravip-impp;
        L.Add(new("X","RÉSULTAT NON COURANT  ( VIII - IX )",false,false,true,rnc,rncp));
        L.Add(new("XI","RÉSULTAT AVANT IMPÔTS  ( VII + X )",false,false,true,ravi,ravip));
        L.Add(new("XII","IMPÔTS SUR LES RÉSULTATS",false,false,false,imp,impp,new[]{"670"}));
        L.Add(new("XIII","RÉSULTAT NET  ( XI - XII )",false,false,true,rnet,rnetp));
        cpcLines = L;
    }

    // ════════════════════════════════════════════════════════════════
    // E.S.G. — T.F.R.
    // ════════════════════════════════════════════════════════════════
    private void BuildTFR()
    {
        var L = new List<EsgLine>();
        decimal vm=-C("711"),vmp=-P("711"); decimal arm=C("611"),armp=P("611"); decimal mb=vm-arm,mbp=vmp-armp;
        L.Add(new("","Ventes de marchandises en l'état",false,false,vm,vmp,new[]{"711"}));
        L.Add(new("-","Achats revendus de marchandises",false,false,arm,armp,new[]{"611"}));
        L.Add(new("=","MARGE BRUTE SUR VENTES EN L'ÉTAT",true,false,mb,mbp));

        decimal vbs=-C("712"),vbsp=-P("712"); decimal vs=-C("713"),vsp=-P("713"); decimal ip=-C("714"),ipp=-P("714");
        decimal prod=vbs+vs+ip,prodp=vbsp+vsp+ipp;
        L.Add(new("+","Ventes de biens et services produits",false,false,vbs,vbsp,new[]{"712"}));
        L.Add(new("+","Variation de stocks de produits",false,false,vs,vsp,new[]{"713"}));
        L.Add(new("+","Immobilisations produites par l'entreprise",false,false,ip,ipp,new[]{"714"}));
        L.Add(new("=","PRODUCTION DE L'EXERCICE",true,false,prod,prodp));

        decimal acm=C("612"),acmp=P("612"); decimal ce=C("613")+C("614"),cep=P("613")+P("614");
        decimal cons=acm+ce,consp=acmp+cep;
        L.Add(new("-","Achats consommés de matières et fournitures",false,false,acm,acmp,new[]{"612"}));
        L.Add(new("-","Autres charges externes",false,false,ce,cep,new[]{"613","614"}));
        L.Add(new("=","CONSOMMATION DE L'EXERCICE",true,false,cons,consp));

        decimal va=mb+prod-cons,vap=mbp+prodp-consp;
        L.Add(new("=","VALEUR AJOUTÉE  ( MB + P - C )",true,true,va,vap));

        decimal se=-C("716"),sep=-P("716"); decimal it=C("616"),itp=P("616"); decimal cp=C("617"),cpp=P("617");
        decimal ebe=va+se-it-cp,ebep=vap+sep-itp-cpp;
        L.Add(new("+","Subventions d'exploitation",false,false,se,sep,new[]{"716"}));
        L.Add(new("-","Impôts et taxes",false,false,it,itp,new[]{"616"}));
        L.Add(new("-","Charges de personnel",false,false,cp,cpp,new[]{"617"}));
        L.Add(new("=","EXCÉDENT BRUT D'EXPLOITATION (E.B.E.) ou INSUFFISANCE BRUTE (I.B.E.)",true,true,ebe,ebep));

        decimal ape=-C("718"),apep=-P("718"); decimal ace=C("618"),acep=P("618");
        decimal rpe=-C("719"),rpep=-P("719"); decimal de=C("619"),dep=P("619");
        decimal re=ebe+ape-ace+rpe-de,rep=ebep+apep-acep+rpep-dep;
        L.Add(new("+","Autres produits d'exploitation",false,false,ape,apep,new[]{"718"}));
        L.Add(new("-","Autres charges d'exploitation",false,false,ace,acep,new[]{"618"}));
        L.Add(new("+","Reprises d'exploitation; transferts",false,false,rpe,rpep,new[]{"719"}));
        L.Add(new("-","Dotations d'exploitation",false,false,de,dep,new[]{"619"}));
        L.Add(new("=","RÉSULTAT D'EXPLOITATION  ( + ou - )",true,true,re,rep));

        decimal t4=-C("731")-C("732")-C("738")-C("739"),t4p=-P("731")-P("732")-P("738")-P("739");
        decimal t5=C("631")+C("632")+C("638")+C("639"),t5p=P("631")+P("632")+P("638")+P("639");
        decimal rc=re+(t4-t5),rcp=rep+(t4p-t5p);
        L.Add(new("+","Produits financiers",false,false,t4,t4p,new[]{"731","732","738","739"}));
        L.Add(new("-","Charges financières",false,false,t5,t5p,new[]{"631","632","638","639"}));
        L.Add(new("=","RÉSULTAT COURANT  ( + ou - )",true,true,rc,rcp));

        decimal t8=-C("751")-C("756")-C("757")-C("758")-C("759"),t8p=-P("751")-P("756")-P("757")-P("758")-P("759");
        decimal t9=C("651")+C("656")+C("658")+C("659"),t9p=P("651")+P("656")+P("658")+P("659");
        decimal rnc=t8-t9,rncp=t8p-t9p;
        L.Add(new("+","Produits non courants",false,false,t8,t8p,new[]{"751","756","757","758","759"}));
        L.Add(new("-","Charges non courantes",false,false,t9,t9p,new[]{"651","656","658","659"}));
        L.Add(new("=","RÉSULTAT AVANT IMPÔTS",true,false,rc+rnc,rcp+rncp));

        decimal imp=C("670"),impp=P("670");
        decimal rnet=rc+rnc-imp,rnetp=rcp+rncp-impp;
        L.Add(new("-","Impôts sur les résultats",false,false,imp,impp,new[]{"670"}));
        L.Add(new("=","RÉSULTAT NET  ( + ou - )",true,true,rnet,rnetp));
        tfrLines = L;

        // share to CAF
        _rnet=rnet; _rnetp=rnetp; _de=de; _dep=dep;
        _t5fin=C("639"); _t5finp=P("639"); _t9nc=C("659"); _t9ncp=P("659");
        _rpe=rpe; _rpep=rpep; _rpf=-C("739"); _rpfp=-P("739");
        _rpnc=-C("759"); _rpncp=-P("759"); _pci=-C("751"); _pcip=-P("751");
        _vna=C("651"); _vnap=P("651");
    }

    // ════════════════════════════════════════════════════════════════
    // E.S.G. — C.A.F.
    // ════════════════════════════════════════════════════════════════
    private void BuildCAF()
    {
        var L = new List<EsgLine>();
        decimal caf=_rnet+_de+_t5fin+_t9nc-_rpe-_rpf-_rpnc-_pci+_vna;
        decimal cafp=_rnetp+_dep+_t5finp+_t9ncp-_rpep-_rpfp-_rpncp-_pcip+_vnap;
        L.Add(new("","Résultat net de l'exercice  (bénéfice +, perte -)",false,false,_rnet,_rnetp));
        L.Add(new("+","Dotations d'exploitation (1)",false,false,_de,_dep,new[]{"619"}));
        L.Add(new("+","Dotations financières (1)",false,false,_t5fin,_t5finp,new[]{"639"}));
        L.Add(new("+","Dotations non courantes aux amortissements et provisions (1)",false,false,_t9nc,_t9ncp,new[]{"659"}));
        L.Add(new("-","Reprises d'exploitation (2)",false,false,_rpe,_rpep,new[]{"719"}));
        L.Add(new("-","Reprises financières (2)",false,false,_rpf,_rpfp,new[]{"739"}));
        L.Add(new("-","Reprises non courantes; transferts de charges (2)",false,false,_rpnc,_rpncp,new[]{"759"}));
        L.Add(new("-","Produits des cessions d'immobilisations",false,false,_pci,_pcip,new[]{"751"}));
        L.Add(new("+","Valeurs nettes d'amortissement des immobilisations cédées",false,false,_vna,_vnap,new[]{"651"}));
        L.Add(new("=","CAPACITÉ D'AUTOFINANCEMENT  ( C.A.F. )",true,true,caf,cafp));
        L.Add(new("-","Distributions de bénéfices",false,false,0,0));
        L.Add(new("=","AUTOFINANCEMENT",true,true,caf,cafp));
        cafLines = L;
    }

    // ════════════════════════════════════════════════════════════════
    // T.F. — SYNTHÈSE
    // ════════════════════════════════════════════════════════════════
    private void BuildSynthese()
    {
        var L = new List<SyntheseLine>();
        decimal aiN=BN("2")-(-BN("28"))-(-BN("29")), aiN1=BN1("2")-(-BN1("28"))-(-BN1("29"));
        decimal acN=BN("3")-(-BN("39"))+BN("35")-(-BN("395")), acN1=BN1("3")-(-BN1("39"))+BN1("35")-(-BN1("395"));
        decimal taN=BN("511")+BN("514")+BN("516")-(-BN("5911"))-(-BN("5914"))-(-BN("5916")),
                taN1=BN1("511")+BN1("514")+BN1("516")-(-BN1("5911"))-(-BN1("5914"))-(-BN1("5916"));
        decimal fpN=-BN("1"), fpN1=-BN1("1");
        decimal pcN=-BN("4")-(-BN("34"))-(-BN("39")), pcN1=-BN1("4")-(-BN1("34"))-(-BN1("39"));
        decimal tpN=-BN("552")-BN("553")-BN("554"), tpN1=-BN1("552")-BN1("553")-BN1("554");
        L.Add(new("Financement permanent",           false, fpN,  fpN1,  new[]{"1"}));
        L.Add(new("Actif immobilisé",                false, aiN,  aiN1,  new[]{"2","28","29"}));
        L.Add(new("FONDS DE ROULEMENT NET GLOBAL",   true,  fpN-aiN,  fpN1-aiN1));
        L.Add(new("Actif circulant (hors trésorerie)",false, acN, acN1,  new[]{"3","35","39","395"}));
        L.Add(new("Passif circulant (hors trésorerie)",false,pcN, pcN1,  new[]{"4","34","39"}));
        L.Add(new("BESOIN DE FINANCEMENT GLOBAL",    true,  acN-pcN,  acN1-pcN1));
        L.Add(new("Trésorerie - Actif",              false, taN,  taN1,  new[]{"511","514","516","5911","5914","5916"}));
        L.Add(new("Trésorerie - Passif",             false, tpN,  tpN1,  new[]{"552","553","554"}));
        L.Add(new("TRÉSORERIE NETTE",                true,  taN-tpN, taN1-tpN1));
        syntheseLines = L;
    }

    // ════════════════════════════════════════════════════════════════
    // T.F. — EMPLOIS / RESSOURCES
    // ════════════════════════════════════════════════════════════════
    private void BuildEmploisRessources()
    {
        var emp = new List<TfLine>(); var res = new List<TfLine>();
        decimal de=C("619"),dep=P("619"); decimal dfin=C("639"),dfinp=P("639"); decimal dnc=C("659"),dncp=P("659");
        decimal rpe=-C("719"),rpep=-P("719"); decimal rpf=-C("739"),rpfp=-P("739"); decimal rpnc=-C("759"),rpncp=-P("759");
        decimal pci=-C("751"),pcip=-P("751"); decimal vna=C("651"),vnap=P("651");
        decimal rnet=-C("7")-C("6"),rnetp=-P("7")-P("6");
        decimal caf=rnet+de+dfin+dnc-rpe-rpf-rpnc-pci+vna, cafp=rnetp+dep+dfinp+dncp-rpep-rpfp-rpncp-pcip+vnap;
        decimal acqB=C("2"),acqBp=P("2"); decimal rdfC=C("141")+C("148"),rdfCp=P("141")+P("148");
        decimal nv=C("211")+C("212")+C("213"),nvp=P("211")+P("212")+P("213");
        emp.Add(new("RESSOURCES STABLES",true,false,0,0));
        emp.Add(new("Acquisition et augmentation des immobilisations",false,false,acqB,acqBp,new[]{"2"}));
        emp.Add(new("Remboursements des dettes de financement",false,false,rdfC,rdfCp,new[]{"141","148"}));
        emp.Add(new("Emplois en non valeurs",false,false,nv,nvp,new[]{"211","212","213"}));
        emp.Add(new("TOTAL DES EMPLOIS  ( I )",false,true,acqB+rdfC+nv,acqBp+rdfCp+nvp));
        emp.Add(new("VARIATION DU BESOIN EN FINANCEMENT GLOBAL",true,false,0,0));
        emp.Add(new("(+) Actif circulant",false,false,C("3")+C("35"),P("3")+P("35"),new[]{"3","35"}));
        emp.Add(new("(-) Passif circulant",false,false,-C("4"),-P("4"),new[]{"4"}));
        emp.Add(new("TOTAL  ( II )",false,true,C("3")+C("35")-C("4"),P("3")+P("35")-P("4")));
        decimal taC=C("511")+C("514")+C("516"),taCp=P("511")+P("514")+P("516");
        decimal tpC=C("552")+C("553")+C("554"),tpCp=P("552")+P("553")+P("554");
        emp.Add(new("VARIATION DE LA TRÉSORERIE",true,false,0,0));
        emp.Add(new("(+) Trésorerie actif",false,false,taC,taCp,new[]{"511","514","516"}));
        emp.Add(new("(-) Trésorerie passif",false,false,-tpC,-tpCp,new[]{"552","553","554"}));
        emp.Add(new("TOTAL  ( III )",false,true,taC-tpC,taCp-tpCp));

        decimal augCap=-C("111"),augCapp=-P("111");
        decimal subInv=-C("131")-C("135"),subInvp=-P("131")-P("135");
        decimal cred=-C("141")-C("148"),credp=-P("141")-P("148");
        res.Add(new("RESSOURCES STABLES",true,false,0,0));
        res.Add(new("CAF de l'exercice",false,false,caf,cafp));
        res.Add(new("Cessions et réductions d'immobilisations",false,false,pci,pcip,new[]{"751"}));
        res.Add(new("Augmentation des capitaux propres",false,false,augCap,augCapp,new[]{"111"}));
        res.Add(new("Augmentation des dettes de financement",false,false,cred,credp,new[]{"141","148"}));
        res.Add(new("Subventions d'investissement reçues",false,false,subInv,subInvp,new[]{"131","135"}));
        res.Add(new("TOTAL DES RESSOURCES  ( I )",false,true,caf+pci+augCap+cred+subInv,cafp+pcip+augCapp+credp+subInvp));
        // pad to align rows
        while (res.Count < emp.Count) res.Add(new("",false,false,0,0));
        emploisLines    = emp;
        ressourcesLines = res;
    }

    // ════════════════════════════════════════════════════════════════
    // T03 — PASSAGE RÉSULTAT COMPTABLE → FISCAL
    // ════════════════════════════════════════════════════════════════
    private void BuildT03()
    {
        var L = new List<T03Line>();
        decimal rnet = _rnet; // computed by BuildTFR
        decimal bénéfice = rnet > 0 ? rnet : 0m;
        decimal perte    = rnet < 0 ? -rnet : 0m;

        L.Add(new("I. RÉSULTAT NET COMPTABLE", true, false, false, 0, 0));
        L.Add(new("Bénéfice net",  false, false, false, 2, bénéfice));
        L.Add(new("Perte nette",   false, false, false, 2, perte));

        // Réintégrations — only IS/CM is auto-computable; rest = 0 (manual)
        decimal is670 = C("670");
        L.Add(new("II. RÉINTÉGRATIONS FISCALES", true, false, false, 0, 0));
        L.Add(new("1. Courantes", true, false, false, 0, 0));
        L.Add(new("Impôts sur les bénéfices / C.M.",  false, false, false, 1, is670, new[]{"670"}));
        L.Add(new("Amendes et pénalités",              false, false, false, 1, 0));
        L.Add(new("Autres réintégrations courantes",   false, false, false, 1, 0));
        L.Add(new("2. Non courantes",  true, false, false, 0, 0));
        L.Add(new("Pénalités et amendes fiscales/pénales", false, false, false, 1, 0));
        L.Add(new("Autres réintégrations non courantes",   false, false, false, 1, 0));

        decimal totRéintég = is670; // sum of all réintégrations (only auto ones for now)

        // Déductions — all manual = 0
        L.Add(new("III. DÉDUCTIONS FISCALES", true, false, false, 0, 0));
        L.Add(new("1. Courantes",    true, false, false, 0, 0));
        L.Add(new("Autres déductions courantes",     false, false, false, 2, 0));
        L.Add(new("2. Non courantes", true, false, false, 0, 0));
        L.Add(new("Autres déductions non courantes", false, false, false, 2, 0));

        decimal totDéduct = 0m;

        L.Add(new("TOTAL RÉINTÉGRATIONS / TOTAL DÉDUCTIONS", false, true, false, 0, 0));
        L.Add(new("— Réintégrations",  false, false, false, 1, totRéintég));
        L.Add(new("— Résultat comptable (bénéfice / perte)", false, false, false, 2, rnet >= 0 ? bénéfice : perte));

        decimal résultBrut = rnet + totRéintég - totDéduct;
        L.Add(new("IV. RÉSULTAT BRUT FISCAL", true, false, false, 0, 0));
        L.Add(new("Bénéfice brut fiscal (A)", false, false, false, 2, résultBrut > 0 ? résultBrut : 0m));
        L.Add(new("Déficit brut fiscal (B)",  false, false, false, 2, résultBrut < 0 ? -résultBrut : 0m));

        L.Add(new("V. REPORTS DÉFICITAIRES IMPUTÉS (C)",  true, false, false, 0, 0));
        L.Add(new("— Exercice n-4", false, false, false, 1, 0));
        L.Add(new("— Exercice n-3", false, false, false, 1, 0));
        L.Add(new("— Exercice n-2", false, false, false, 1, 0));
        L.Add(new("— Exercice n-1", false, false, false, 1, 0));

        decimal résultNet = résultBrut; // Reports = 0 (manual)
        L.Add(new("VI. RÉSULTAT NET FISCAL", true, false, true, 0, 0));
        L.Add(new("Bénéfice net fiscal (A-C)", false, false, true, 2, résultNet > 0 ? résultNet : 0m));
        L.Add(new("Déficit net fiscal (B)",    false, false, true, 2, résultNet < 0 ? -résultNet : 0m));

        L.Add(new("VII. CUMUL AMORTISSEMENTS FISCALEMENT DIFFÉRÉS", true, false, false, 0, 0));
        L.Add(new("— Montant", false, false, false, 1, 0));
        L.Add(new("VIII. CUMUL DÉFICITS FISCAUX RESTANT À REPORTER", true, false, false, 0, 0));
        L.Add(new("— Montant", false, false, false, 1, 0));

        t03Lines = L;
    }

    // ════════════════════════════════════════════════════════════════
    // T04 — TABLEAU DES IMMOBILISATIONS
    // ════════════════════════════════════════════════════════════════
    private void BuildT04()
    {
        var L = new List<ImmobLine>();

        (decimal deb, decimal acq, decimal cess, decimal fin) Immo(string pfx)
        {
            decimal debut = BN1(pfx);
            decimal acquisition = SD(pfx);
            decimal cession     = SC(pfx);
            decimal finEx       = BN(pfx);
            return (debut, acquisition, cession, finEx);
        }

        // NON-VALEURS
        var (nvDeb, nvAcq, nvCess, nvFin) = (BN1("211")+BN1("212")+BN1("213"), SD("211")+SD("212")+SD("213"), SC("211")+SC("212")+SC("213"), BN("211")+BN("212")+BN("213"));
        L.Add(new("IMMOBILISATION EN NON-VALEURS", true, false, nvDeb, nvAcq, nvCess, nvFin, new[]{"211","212","213"}));
        var (fp211d,fp211a,fp211c,fp211f)=Immo("211"); L.Add(new("— Frais préliminaires", false, false, fp211d, fp211a, fp211c, fp211f, new[]{"211"}));
