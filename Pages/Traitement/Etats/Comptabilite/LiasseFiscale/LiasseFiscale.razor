    // ════════════════════════════════════════════════════════════════
    // T08 — TABLEAU DES AMORTISSEMENTS
    // ════════════════════════════════════════════════════════════════
    private void BuildT08()
    {
        var L = new List<AmortLine>();

        // For amort accounts (28xx): they are credit-balance → BN returns negative, we negate
        // Cumul début = -BN1(pfx_amort)
        // Dotation N   = credit movements on amort during N = SC(pfx_amort)
        // Sorties N     = debit movements on amort during N = SD(pfx_amort) (reversal on cession)
        // Cumul fin    = CumulDebut + Dotation - Sorties (also = -BN(pfx_amort))

        (decimal d, decimal dot, decimal s) Amort(string pfx)
            => (-BN1(pfx), SC(pfx), SD(pfx));

        // NON-VALEURS
        var (nv2811d,nv2811dot,nv2811s)=Amort("2811");
        var (nv2812d,nv2812dot,nv2812s)=Amort("2812");
        var (nv2813d,nv2813dot,nv2813s)=Amort("2813");
        decimal nvD=-BN1("2811")-BN1("2812")-BN1("2813"), nvDot=SC("2811")+SC("2812")+SC("2813"), nvS=SD("2811")+SD("2812")+SD("2813");
        L.Add(new("IMMOBILISATION EN NON-VALEURS", true, false, nvD, nvDot, nvS, new[]{"2811","2812","2813"}));
        L.Add(new("— Frais préliminaires",                       false, false, nv2811d, nv2811dot, nv2811s, new[]{"2811"}));
        L.Add(new("— Charges à répartir sur plusieurs exercices",false, false, nv2812d, nv2812dot, nv2812s, new[]{"2812"}));
        L.Add(new("— Primes de remboursement obligations",       false, false, nv2813d, nv2813dot, nv2813s, new[]{"2813"}));

        // INCORPORELLES
        var (in2821d,in2821dot,in2821s)=Amort("2821"); var (in2822d,in2822dot,in2822s)=Amort("2822");
        var (in2823d,in2823dot,in2823s)=Amort("2823"); var (in2828d,in2828dot,in2828s)=Amort("2828");
        decimal inD=in2821d+in2822d+in2823d+in2828d, inDot=in2821dot+in2822dot+in2823dot+in2828dot, inS=in2821s+in2822s+in2823s+in2828s;
        L.Add(new("IMMOBILISATIONS INCORPORELLES", true, false, inD, inDot, inS, new[]{"2821","2822","2823","2828"}));
        L.Add(new("— Recherche et développement",                false, false, in2821d, in2821dot, in2821s, new[]{"2821"}));
        L.Add(new("— Brevets, marques, droits et valeurs similaires", false, false, in2822d, in2822dot, in2822s, new[]{"2822"}));
        L.Add(new("— Fonds commercial",                          false, false, in2823d, in2823dot, in2823s, new[]{"2823"}));
        L.Add(new("— Autres immobilisations incorporelles",      false, false, in2828d, in2828dot, in2828s, new[]{"2828"}));

        // CORPORELLES
        var (cp2831d,cp2831dot,cp2831s)=Amort("2831"); var (cp2832d,cp2832dot,cp2832s)=Amort("2832");
        var (cp2833d,cp2833dot,cp2833s)=Amort("2833"); var (cp2834d,cp2834dot,cp2834s)=Amort("2834");
        var (cp2835d,cp2835dot,cp2835s)=Amort("2835"); var (cp2838d,cp2838dot,cp2838s)=Amort("2838");
        var (cp2839d,cp2839dot,cp2839s)=Amort("2839");
        decimal cpD=cp2831d+cp2832d+cp2833d+cp2834d+cp2835d+cp2838d+cp2839d;
        decimal cpDot=cp2831dot+cp2832dot+cp2833dot+cp2834dot+cp2835dot+cp2838dot+cp2839dot;
        decimal cpS=cp2831s+cp2832s+cp2833s+cp2834s+cp2835s+cp2838s+cp2839s;
        L.Add(new("IMMOBILISATIONS CORPORELLES", true, false, cpD, cpDot, cpS, new[]{"2831","2832","2833","2834","2835","2838","2839"}));
        L.Add(new("— Terrains",                                  false, false, cp2831d, cp2831dot, cp2831s, new[]{"2831"}));
        L.Add(new("— Constructions",                             false, false, cp2832d, cp2832dot, cp2832s, new[]{"2832"}));
        L.Add(new("— Installations techniques, matériel et outillage", false, false, cp2833d, cp2833dot, cp2833s, new[]{"2833"}));
        L.Add(new("— Matériel de transport",                     false, false, cp2834d, cp2834dot, cp2834s, new[]{"2834"}));
        L.Add(new("— Mobilier, matériel de bureau et aménagement",false, false, cp2835d, cp2835dot, cp2835s, new[]{"2835"}));
        L.Add(new("— Autres immobilisations corporelles",        false, false, cp2838d, cp2838dot, cp2838s, new[]{"2838"}));
        L.Add(new("— Immobilisations corporelles en cours",      false, false, cp2839d, cp2839dot, cp2839s, new[]{"2839"}));

        decimal totD=nvD+inD+cpD, totDot=nvDot+inDot+cpDot, totS=nvS+inS+cpS;
        L.Add(new("TOTAL", false, true, totD, totDot, totS));
        t08Lines = L;
    }

    // ════════════════════════════════════════════════════════════════
    // T09 — TABLEAU DES PROVISIONS
    // ════════════════════════════════════════════════════════════════
    private void BuildT09()
    {
        var L = new List<ProvLine>();

        // Provision accounts are credit-balance:
        //   Debut = -BN1(pfx), Dotation = SC(pfx), Reprise = SD(pfx), Fin = -BN(pfx)
        (decimal deb, decimal dot, decimal rep, decimal fin) Prov(string pfx)
            => (-BN1(pfx), SC(pfx), SD(pfx), -BN(pfx));

        var (d29,  dot29,  rep29,  f29)  = Prov("29");
        var (d135, dot135, rep135, f135) = Prov("135");
        var (d151, dot151, rep151, f151) = Prov("151");
        var (d155, dot155, rep155, f155) = Prov("155");
        decimal d15 = d151 + d155, dot15 = dot151 + dot155, rep15 = rep151 + rep155, f15 = f151 + f155;
        var (d39,  dot39,  rep39,  f39)  = Prov("39");
        var (d45,  dot45,  rep45,  f45)  = Prov("45");
        var (d59,  dot59,  rep59,  f59)  = Prov("59");

        L.Add(new("Provisions pour dépréciation des immobilisations (29)", false, false, d29,  dot29,  rep29,  f29,  new[]{"29"}));
        L.Add(new("Provisions réglementées (135)",                         false, false, d135, dot135, rep135, f135, new[]{"135"}));
        L.Add(new("Provisions durables pour risques et charges",           false, false, d15,  dot15,  rep15,  f15,  new[]{"151","155"}));
        L.Add(new("— Provisions pour risques (151)",                       false, false, d151, dot151, rep151, f151, new[]{"151"}));
        L.Add(new("— Provisions pour charges (155)",                       false, false, d155, dot155, rep155, f155, new[]{"155"}));
        L.Add(new("Provisions pour dépréciation des stocks (39)",          false, false, d39,  dot39,  rep39,  f39,  new[]{"39"}));
        L.Add(new("Autres provisions pour risques et charges (45)",        false, false, d45,  dot45,  rep45,  f45,  new[]{"45"}));
        L.Add(new("Provisions pour dépréciation de trésorerie (59)",       false, false, d59,  dot59,  rep59,  f59,  new[]{"59"}));

        decimal totD   = d29 + d135 + d15 + d39 + d45 + d59;
        decimal totDot = dot29 + dot135 + dot15 + dot39 + dot45 + dot59;
        decimal totRep = rep29 + rep135 + rep15 + rep39 + rep45 + rep59;
        decimal totF   = f29 + f135 + f15 + f39 + f45 + f59;
        L.Add(new("TOTAL", false, true, totD, totDot, totRep, totF));
        t09Lines = L;
    }

    // ════════════════════════════════════════════════════════════════
    // T10 — PLUS ET MOINS VALUES SUR CESSIONS
    // ════════════════════════════════════════════════════════════════
    private void BuildT10()
    {
        var L = new List<CessionLine>();
