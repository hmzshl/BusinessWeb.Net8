        Sub("— Locations et charges locatives",C("6131"),P("6131"),new[]{"6131"});
        Sub("— Redevances de crédit-bail",C("6132"),P("6132"),new[]{"6132"});
        Sub("— Entretien et réparations",C("6133"),P("6133"),new[]{"6133"});
