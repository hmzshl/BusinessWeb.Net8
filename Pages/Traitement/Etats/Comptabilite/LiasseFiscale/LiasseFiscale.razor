        var (te231d,te231a,te231c,te231f)=Immo("231"); L.Add(new("— Terrains", false, false, te231d, te231a, te231c, te231f, new[]{"231"}));
        var (co232d,co232a,co232c,co232f)=Immo("232"); L.Add(new("— Constructions", false, false, co232d, co232a, co232c, co232f, new[]{"232"}));
        var (it233d,it233a,it233c,it233f)=Immo("233"); L.Add(new("— Installations techniques, matériel et outillage", false, false, it233d, it233a, it233c, it233f, new[]{"233"}));
        var (mt234d,mt234a,mt234c,mt234f)=Immo("234"); L.Add(new("— Matériel de transport", false, false, mt234d, mt234a, mt234c, mt234f, new[]{"234"}));
        var (mb235d,mb235a,mb235c,mb235f)=Immo("235"); L.Add(new("— Mobilier, matériel de bureau et aménagement", false, false, mb235d, mb235a, mb235c, mb235f, new[]{"235"}));
        var (ac238d,ac238a,ac238c,ac238f)=Immo("238"); L.Add(new("— Autres immobilisations corporelles", false, false, ac238d, ac238a, ac238c, ac238f, new[]{"238"}));
        var (ec239d,ec239a,ec239c,ec239f)=Immo("239"); L.Add(new("— Immobilisations corporelles en cours", false, false, ec239d, ec239a, ec239c, ec239f, new[]{"239"}));

        decimal totDeb=nvDeb+inDeb+cpDeb, totAcq=nvAcq+inAcq+cpAcq, totCess=nvCess+inCess+cpCess, totFin=nvFin+inFin+cpFin;
        L.Add(new("TOTAL", false, true, totDeb, totAcq, totCess, totFin));
        t04Lines = L;
    }

