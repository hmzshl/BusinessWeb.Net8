        var (ai228d,ai228a,ai228c,ai228f)=Immo("228"); L.Add(new("— Autres immobilisations incorporelles", false, false, ai228d, ai228a, ai228c, ai228f, new[]{"228"}));

        // CORPORELLES
        var cpDeb=BN1("231")+BN1("232")+BN1("233")+BN1("234")+BN1("235")+BN1("238")+BN1("239");
        var cpAcq=SD("231")+SD("232")+SD("233")+SD("234")+SD("235")+SD("238")+SD("239");
