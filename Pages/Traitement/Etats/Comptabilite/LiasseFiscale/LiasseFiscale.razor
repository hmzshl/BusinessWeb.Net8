        var inDeb=BN1("221")+BN1("222")+BN1("223")+BN1("228"); var inAcq=SD("221")+SD("222")+SD("223")+SD("228"); var inCess=SC("221")+SC("222")+SC("223")+SC("228"); var inFin=BN("221")+BN("222")+BN("223")+BN("228");
