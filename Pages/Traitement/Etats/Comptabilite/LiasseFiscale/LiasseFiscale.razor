    // ════════════════════════════════════════════════════════════════
    // T11 — TITRES DE PARTICIPATION ET AUTRES TITRES IMMOBILISÉS
    // ════════════════════════════════════════════════════════════════
    private void BuildT11()
    {
        var L = new List<SyntheseLine>();
        decimal p241n = BN("241"),  p241n1 = BN1("241");
        decimal p248n = BN("248"),  p248n1 = BN1("248");
        decimal p251n = BN("251"),  p251n1 = BN1("251");
        decimal p258n = BN("258"),  p258n1 = BN1("258");
