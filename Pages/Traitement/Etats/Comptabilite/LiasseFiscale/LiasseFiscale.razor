    // ════════════════════════════════════════════════════════════════
    // T12 — ÉTAT DE LA T.V.A.
    // ════════════════════════════════════════════════════════════════
    private void BuildT12()
    {
        var L = new List<TvaLine>();
        // TVA facturée (4455) — credit-balance → negate BN
        decimal tvaf_debut = -BN1("4455");
        decimal tvaf_fin   = -BN("4455");
        // TVA récupérable sur immobilisations (3451) — debit-balance
        decimal tvai_debut = BN1("3451");
        decimal tvai_fin   = BN("3451");
        // TVA récupérable sur charges (3455) — debit-balance
        decimal tvac_debut = BN1("3455");
        decimal tvac_fin   = BN("3455");
        decimal tvar_debut = tvai_debut + tvac_debut;
        decimal tvar_fin   = tvai_fin   + tvac_fin;

        L.Add(new("A — TVA Facturée (4455)",                 false, false, tvaf_debut,             tvaf_fin,             new[]{"4455"}));
        L.Add(new("B — TVA Récupérable",                     false, false, tvar_debut,             tvar_fin,             new[]{"3451","3455"}));
        L.Add(new("— Sur immobilisations (3451)",            true,  false, tvai_debut,             tvai_fin,             new[]{"3451"}));
        L.Add(new("— Sur charges (3455)",                    true,  false, tvac_debut,             tvac_fin,             new[]{"3455"}));
        L.Add(new("C — TVA Due / (Crédit) = A - B",          false, true,  tvaf_debut - tvar_debut, tvaf_fin - tvar_fin));
        t12Lines = L;
    }

    // ════════════════════════════════════════════════════════════════
    // T14 — AFFECTATION DES RÉSULTATS
    // ════════════════════════════════════════════════════════════════
    private void BuildT14()
    {
        var L = new List<AffLine>();
        decimal rn_debut = -BN1("116"); // Report à nouveau début exercice
        decimal rn_fin   = -BN("116");  // Report à nouveau fin exercice
        decimal rl_fin   = -BN("114");  // Réserve légale fin exercice
        decimal rnet     = _rnet;       // Résultat net exercice (from BuildTFR)

        L.Add(new("Report à nouveau (début exercice)",  rn_debut, "Réserve légale (114)",        rl_fin,             false, false));
        L.Add(new("Résultat net de l'exercice",         rnet,     "Autres réserves (115)",        0m,                 false, false));
        L.Add(new("Prélèvements sur réserves",          0m,       "Dividendes distribués",        0m,                 false, false));
        L.Add(new("",                                   0m,       "Report à nouveau (fin)",       rn_fin,             false, false));
        L.Add(new("TOTAL A",          rn_debut + rnet,            "TOTAL B",        rl_fin + rn_fin, false,           true));
        t14Lines = L;
    }

    // ════════════════════════════════════════════════════════════════
    // T20 — ÉTAT DÉTAILLÉ DES STOCKS
    // ════════════════════════════════════════════════════════════════
    private void BuildT20()
    {
        var L = new List<StockLine>();

        // Stock accounts: debit-balance (positive BN)
        // Provision accounts: credit-balance (negate BN)
        (decimal fb, decimal fp, decimal ib, decimal ip) Stock(string pfxS, string pfxP)
            => (BN(pfxS), -BN(pfxP), BN1(pfxS), -BN1(pfxP));

        var (fb311, fp311, ib311, ip311) = Stock("311", "3911");
        var (fb312, fp312, ib312, ip312) = Stock("312", "3912");
        var (fb313, fp313, ib313, ip313) = Stock("313", "3913");
        var (fb314, fp314, ib314, ip314) = Stock("314", "3914");
        var (fb315, fp315, ib315, ip315) = Stock("315", "3915");

        decimal totFb = fb311 + fb312 + fb313 + fb314 + fb315;
        decimal totFp = fp311 + fp312 + fp313 + fp314 + fp315;
        decimal totIb = ib311 + ib312 + ib313 + ib314 + ib315;
        decimal totIp = ip311 + ip312 + ip313 + ip314 + ip315;

        L.Add(new("Marchandises",                              false, false, false, fb311, fp311, ib311, ip311, new[]{"311","3911"}));
        L.Add(new("Matières et fournitures consommables",      false, false, false, fb312, fp312, ib312, ip312, new[]{"312","3912"}));
        L.Add(new("Produits en cours",                         false, false, false, fb313, fp313, ib313, ip313, new[]{"313","3913"}));
        L.Add(new("Produits intermédiaires et résiduels",      false, false, false, fb314, fp314, ib314, ip314, new[]{"314","3914"}));
        L.Add(new("Produits finis",                            false, false, false, fb315, fp315, ib315, ip315, new[]{"315","3915"}));
        L.Add(new("TOTAL",                                     false, false, true,  totFb, totFp, totIb, totIp));
        t20Lines = L;
    }

    // ── Formatting & row classes ──────────────────────────────────────
    private static string Fmt(decimal v)    => v == 0 ? "-" : v.ToString("N2");
    private static string FmtPos(decimal v) => v <= 0 ? ""  : v.ToString("N2");

    private static string BilanRowClass(bool isHeader, bool isTotal, string cat)
    {
        if (isTotal && string.IsNullOrEmpty(cat)) return "lf-grand-total";
        if (isTotal)                               return "lf-total";
        if (isHeader && string.IsNullOrEmpty(cat)) return "lf-subheader";
        if (isHeader)                              return "lf-header";
        return "";
    }

    private static string CpcRowClass(CpcLine l)
    {
        if (l.Cat == "XIII")             return "lf-grand-total";
        if (l.Cat is "VII" or "XI")      return "lf-result lf-result-key";
        if (l.IsResult)                  return "lf-result";
        if (l.IsTotal && l.Cat != "")    return "lf-total";
        if (l.IsTotal)                   return "lf-subtotal";
        if (l.IsHeader)                  return "lf-header";
        return "";
    }

    private static string EsgRowClass(EsgLine l)
    {
        if (l.IsGrand)  return "lf-grand-total";
        if (l.IsResult) return "lf-total";
        return "";
    }

    private static string T03RowClass(T03Line l)
    {
        if (l.IsGrand)  return "lf-grand-total";
        if (l.IsTotal)  return "lf-total";
        if (l.IsSection)return "lf-subheader";
        return "";
    }

    private static string T06RowClass(T06Line l)
    {
        if (l.IsSection) return "lf-section-hdr";
        if (l.IsTotal)   return "lf-subtotal";
        if (l.IsPoste)   return "lf-header";
        return "";
    }

    public void Dispose()
    {
        actifLines?.Clear();      actifLines      = null;
        passifLines?.Clear();     passifLines     = null;
        cpcLines?.Clear();        cpcLines        = null;
        tfrLines?.Clear();        tfrLines        = null;
        cafLines?.Clear();        cafLines        = null;
        syntheseLines?.Clear();   syntheseLines   = null;
        emploisLines?.Clear();    emploisLines    = null;
        ressourcesLines?.Clear(); ressourcesLines = null;
        detailItems?.Clear();     detailItems     = null;
        t03Lines?.Clear();        t03Lines        = null;
        t04Lines?.Clear();        t04Lines        = null;
        t06Lines?.Clear();        t06Lines        = null;
        t08Lines?.Clear();        t08Lines        = null;
        t09Lines?.Clear();        t09Lines        = null;
        t10Lines?.Clear();        t10Lines        = null;
        t11Lines?.Clear();        t11Lines        = null;
        t12Lines?.Clear();        t12Lines        = null;
        t14Lines?.Clear();        t14Lines        = null;
        t20Lines?.Clear();        t20Lines        = null;
        detailPfx = null;
    }
}

