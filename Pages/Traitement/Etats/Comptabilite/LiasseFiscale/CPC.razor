@page "/cpt-liasse-cpc"
@attribute [Authorize]
@implements IDisposable

@if (IsLoaded)
{
    <Card_1 Title="C.P.C.">
        <RadzenContent>
            <div class="grid-container no-border">

                <SfToolbar CssClass="btns">
                    <ToolbarItems>
                        <ToolbarItem Align="ItemAlign.Left">
                            <Template>
                                <SfMessage Severity="MessageSeverity.Info" Variant="MessageVariant.Outlined">
                                    <div style="text-transform: uppercase;">
                                        Liasse Fiscale IS — Modèle Normal
                                    </div>
                                </SfMessage>
                            </Template>
                        </ToolbarItem>
                        <ToolbarItem Align="ItemAlign.Right" Type="ItemType.Input">
                            <Template>
                                <SfDropDownList TValue="int" TItem="ExoItem" Width="200px"
                                                @bind-Value="selectedExoIndex" DataSource="@exoItems"
                                                Placeholder="Exercice">
                                    <DropDownListFieldSettings Text="Label" Value="Idx" />
                                    <DropDownListEvents TValue="int" TItem="ExoItem"
                                                        ValueChange="@(args => LoadData())" />
                                </SfDropDownList>
                            </Template>
                        </ToolbarItem>
                    </ToolbarItems>
                </SfToolbar>

                <div class="cpc-section">
                    <div class="cpc-title">COMPTE DE PRODUITS ET CHARGES (C.P.C.)</div>
                    <div class="table-responsive">
                        <table class="cpc-table">
                            <thead>
                                <tr>
                                    <th class="col-num-sm"></th>
                                    <th class="col-label">Nature</th>
                                    <th class="col-num">Exercice</th>
                                    <th class="col-num">Exercice Précédent</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var line in cpcLines)
                                {
                                    <tr class="@GetRowClass(line) @(line.Pfx != null ? "cell-link" : "")"
                                        @onclick="@(() => OnCellClick(line.Label.Length > 0 ? line.Label : line.Cat, line.Pfx))">
                                        <td class="col-num-sm">@(line.IsTotal || line.IsResult ? line.Cat : "")</td>
                                        <td class="col-label @(line.IsHeader || line.IsTotal || line.IsResult ? "fw-bold" : "")">@line.Label</td>
                                        <td class="col-num">@(line.IsHeader ? "" : Fmt(line.Val))</td>
                                        <td class="col-num">@(line.IsHeader ? "" : Fmt(line.PrevVal))</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </RadzenContent>
    </Card_1>

    <SfDialog @bind-Visible="showDetail" Width="520px" ShowCloseIcon="true" IsModal="true">
        <DialogTemplates>
            <Header>@detailTitle</Header>
            <Content>
                <div style="font-size:.76rem; color:#6b7280; margin-bottom:.7rem; font-family:monospace; background:#f4f6fb; padding:.3rem .5rem; border-radius:4px; border:1px solid #dbe3ef;">
                    Plage : @string.Join("  |  ", detailPfx ?? Array.Empty<string>())
                </div>
                @if (detailItems.Count == 0)
                {
                    <p style="color:#888; font-size:.85rem; margin:0;">Aucun mouvement pour cette plage sur cet exercice.</p>
                }
                else
                {
                    <table class="detail-table">
                        <thead>
                            <tr>
                                <th>Compte</th>
                                <th style="text-align:right">Solde</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in detailItems)
                            {
                                <tr>
                                    <td>@item.CG_Num</td>
                                    <td style="text-align:right; @(item.Solde < 0 ? "color:#c0392b;" : "")">@item.Solde.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr style="font-weight:700; background:#eef1f6;">
                                <td>Total</td>
                                <td style="text-align:right">@detailItems.Sum(x => x.Solde).ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>
                }
            </Content>
        </DialogTemplates>
    </SfDialog>
}
else
{
    <div class="center-screen"><Loading_1 /></div>
}

@code {
    [CascadingParameter] public SessionDT session { get; set; } = new SessionDT();
    DB db = new DB();

    bool IsLoaded = false;

    // ── Exercices ────────────────────────────────────────────────────
    private class ExoItem
    {
        public int      Idx   { get; set; }
        public string   Label { get; set; }
        public DateTime Debut { get; set; }
        public DateTime Fin   { get; set; }
    }

    private List<ExoItem> exoItems      = new();
    private int           selectedExoIndex = 0;

    private ExoItem CurrentExo => exoItems.Count > 0 ? exoItems[selectedExoIndex] : null;
    private ExoItem PrevExo    => selectedExoIndex + 1 < exoItems.Count ? exoItems[selectedExoIndex + 1] : null;

    // ── CPC lines ────────────────────────────────────────────────────
    private record CpcLine(string Cat, string Label, bool IsHeader, bool IsTotal, bool IsResult, decimal Val, decimal PrevVal, string[] Pfx = null);

    private List<CpcLine> cpcLines = new();

    // ── Detail popup ─────────────────────────────────────────────────
    private bool     showDetail  = false;
    private string   detailTitle = "";
    private string[] detailPfx   = null;
    private class DetailItem { public string CG_Num { get; set; } public decimal Solde { get; set; } }
    private List<DetailItem> detailItems = new();

    protected override async Task OnInitializedAsync()
    {
        db = session.db;
        GC.Collect();
        await Task.Delay(1);
        LoadExercices();
        await LoadData();
        IsLoaded = true;
    }

    private void LoadExercices()
    {
        var d = db.P_DOSSIER.FirstOrDefault();
        if (d == null) return;

        var raw = new (DateTime? Debut, DateTime? Fin)[]
        {
            (d.D_DebutExo01, d.D_FinExo01),
            (d.D_DebutExo02, d.D_FinExo02),
            (d.D_DebutExo03, d.D_FinExo03),
            (d.D_DebutExo04, d.D_FinExo04),
            (d.D_DebutExo05, d.D_FinExo05),
        };

        exoItems = raw
            .Where(x => x.Debut.HasValue && x.Fin.HasValue && x.Debut.Value.Year > 1900)
            .OrderByDescending(x => x.Debut)
            .Select((x, i) => new ExoItem
            {
                Idx   = i,
                Debut = x.Debut!.Value,
                Fin   = x.Fin!.Value,
                Label = BuildExoLabel(x.Debut!.Value, x.Fin!.Value)
            })
            .ToList();

        selectedExoIndex = 0;
    }

    private static string BuildExoLabel(DateTime debut, DateTime fin)
    {
        bool isCalYear = debut.Day == 1 && debut.Month == 1
                      && fin.Day == 31 && fin.Month == 12
                      && debut.Year == fin.Year;
        return isCalYear ? debut.Year.ToString() : $"{debut:dd/MM/yy} — {fin:dd/MM/yy}";
    }

    private async Task LoadData()
    {
        IsLoaded = false;
        await Task.Delay(300);
        if (CurrentExo != null) BuildCPC();
        IsLoaded = true;
        await Task.Delay(300);
    }

    // ── Query helpers ─────────────────────────────────────────────────
    private decimal S(string prefix, DateTime debut, DateTime fin) =>
        db.F_ECRITUREC
            .Where(e => e.EC_Date.HasValue
                     && e.EC_Date.Value >= debut
                     && e.EC_Date.Value <= fin
                     && e.CG_Num != null && e.CG_Num.StartsWith(prefix))
            .Sum(e => e.EC_Sens == 0 ? (e.EC_Montant ?? 0m) : -(e.EC_Montant ?? 0m));

    private decimal C(string prefix) => CurrentExo != null ? S(prefix, CurrentExo.Debut, CurrentExo.Fin) : 0m;
    private decimal P(string prefix) => PrevExo    != null ? S(prefix, PrevExo.Debut,    PrevExo.Fin)    : 0m;

    // ── Detail click ─────────────────────────────────────────────────
    private void OnCellClick(string label, string[] pfx)
    {
        if (pfx == null || pfx.Length == 0 || CurrentExo == null) return;
        var debut = CurrentExo.Debut;
        var fin   = CurrentExo.Fin;
        detailTitle = label;
        detailPfx   = pfx;
        detailItems = pfx
            .SelectMany(prefix =>
                db.F_ECRITUREC
                    .Where(e => e.EC_Date.HasValue
                             && e.EC_Date.Value >= debut
                             && e.EC_Date.Value <= fin
                             && e.CG_Num != null && e.CG_Num.StartsWith(prefix))
                    .GroupBy(e => e.CG_Num)
                    .Select(g => new DetailItem
                    {
                        CG_Num = g.Key,
                        Solde  = g.Sum(e => e.EC_Sens == 0 ? (e.EC_Montant ?? 0m) : -(e.EC_Montant ?? 0m))
                    })
                    .ToList())
            .GroupBy(x => x.CG_Num)
            .Select(g => new DetailItem { CG_Num = g.Key, Solde = g.Sum(x => x.Solde) })
            .OrderBy(x => x.CG_Num)
            .ToList();
        showDetail = true;
    }

    // ── CPC builder ──────────────────────────────────────────────────
    private void BuildCPC()
    {
        var lines = new List<CpcLine>();

        // ─── PRODUITS D'EXPLOITATION ────────────────────────────────
        decimal vm   = -C("711"), vmp   = -P("711");
        decimal vbs  = -C("712"), vbsp  = -P("712");
        decimal ca   = vm + vbs,  cap   = vmp + vbsp;
        decimal vs   = -C("713"), vsp   = -P("713");
        decimal ip   = -C("714"), ipp   = -P("714");
        decimal se   = -C("716"), sep   = -P("716");
        decimal ape  = -C("718"), apep  = -P("718");
        decimal rpe  = -C("719"), rpep  = -P("719");
        decimal t1   = vm+vbs+vs+ip+se+ape+rpe, t1p = vmp+vbsp+vsp+ipp+sep+apep+rpep;

        lines.Add(new("", "PRODUITS D'EXPLOITATION", true, false, false, 0, 0));
        lines.Add(new("", "Ventes de marchandises en l'état (1)",                         false, false, false, vm,  vmp,  new[] { "711" }));
        lines.Add(new("", "Ventes de biens et services produits (2)",                     false, false, false, vbs, vbsp, new[] { "712" }));
        lines.Add(new("", "Chiffre d'affaires (1 + 2)",                                   false, true,  false, ca,  cap));
        lines.Add(new("", "Variation de stocks de produits (3)",                          false, false, false, vs,  vsp,  new[] { "713" }));
        lines.Add(new("", "Immobilisations produites par l'entreprise pour elle-même (4)",false, false, false, ip,  ipp,  new[] { "714" }));
        lines.Add(new("", "Subventions d'exploitation (5)",                               false, false, false, se,  sep,  new[] { "716" }));
        lines.Add(new("", "Autres produits d'exploitation (6)",                           false, false, false, ape, apep, new[] { "718" }));
        lines.Add(new("", "Reprises d'exploitation; transferts de charges (7)",           false, false, false, rpe, rpep, new[] { "719" }));
        lines.Add(new("I", "TOTAL  I  —  PRODUITS D'EXPLOITATION",                       false, true,  false, t1,  t1p));

        // ─── CHARGES D'EXPLOITATION ─────────────────────────────────
        decimal arm  = C("611"),  armp  = P("611");
        decimal acm  = C("612"),  acmp  = P("612");
        decimal ce1  = C("613"),  ce1p  = P("613");
        decimal ce2  = C("614"),  ce2p  = P("614");
        decimal it   = C("616"),  itp   = P("616");
        decimal cp   = C("617"),  cpp   = P("617");
        decimal ace  = C("618"),  acep  = P("618");
        decimal de   = C("619"),  dep   = P("619");
        decimal t2   = arm+acm+ce1+ce2+it+cp+ace+de, t2p = armp+acmp+ce1p+ce2p+itp+cpp+acep+dep;

        lines.Add(new("", "CHARGES D'EXPLOITATION", true, false, false, 0, 0));
        lines.Add(new("", "Achats revendus de marchandises (1)",                          false, false, false, arm, armp, new[] { "611" }));
        lines.Add(new("", "Achats consommés de matières et fournitures (2)",              false, false, false, acm, acmp, new[] { "612" }));
        lines.Add(new("", "Autres charges externes (1) (3)",                              false, false, false, ce1, ce1p, new[] { "613" }));
        lines.Add(new("", "Autres charges externes (2) (4)",                              false, false, false, ce2, ce2p, new[] { "614" }));
        lines.Add(new("", "Impôts et taxes (5)",                                          false, false, false, it,  itp,  new[] { "616" }));
        lines.Add(new("", "Charges de personnel (6)",                                     false, false, false, cp,  cpp,  new[] { "617" }));
        lines.Add(new("", "Autres charges d'exploitation (7)",                            false, false, false, ace, acep, new[] { "618" }));
        lines.Add(new("", "Dotations d'exploitation (8)",                                 false, false, false, de,  dep,  new[] { "619" }));
        lines.Add(new("II", "TOTAL  II  —  CHARGES D'EXPLOITATION",                      false, true,  false, t2,  t2p));

        decimal re = t1 - t2, rep = t1p - t2p;
        lines.Add(new("III", "RÉSULTAT D'EXPLOITATION  ( I - II )", false, false, true, re, rep));

        // ─── PRODUITS FINANCIERS ─────────────────────────────────────
        decimal ptp  = -C("731"), ptpp  = -P("731");
        decimal gc   = -C("732"), gcp   = -P("732");
        decimal ipf  = -C("738"), ipfp  = -P("738");
        decimal rpf  = -C("739"), rpfp  = -P("739");
        decimal t4   = ptp+gc+ipf+rpf, t4p = ptpp+gcp+ipfp+rpfp;

        lines.Add(new("", "PRODUITS FINANCIERS", true, false, false, 0, 0));
        lines.Add(new("", "Produits des titres de participation et autres titres immobilisés (1)", false, false, false, ptp, ptpp, new[] { "731" }));
        lines.Add(new("", "Gains de change (2)",                                          false, false, false, gc,  gcp,  new[] { "732" }));
        lines.Add(new("", "Intérêts et autres produits financiers (3)",                   false, false, false, ipf, ipfp, new[] { "738" }));
        lines.Add(new("", "Reprises financières; transferts de charges (4)",              false, false, false, rpf, rpfp, new[] { "739" }));
        lines.Add(new("IV", "TOTAL  IV  —  PRODUITS FINANCIERS",                         false, true,  false, t4,  t4p));

        // ─── CHARGES FINANCIÈRES ─────────────────────────────────────
        decimal ci   = C("631"),  cip   = P("631");
        decimal pc   = C("632"),  pcp   = P("632");
        decimal acf  = C("638"),  acfp  = P("638");
        decimal df   = C("639"),  dfp   = P("639");
        decimal t5   = ci+pc+acf+df, t5p = cip+pcp+acfp+dfp;

        lines.Add(new("", "CHARGES FINANCIÈRES", true, false, false, 0, 0));
        lines.Add(new("", "Charges d'intérêts (1)",                                       false, false, false, ci,  cip,  new[] { "631" }));
        lines.Add(new("", "Pertes de change (2)",                                         false, false, false, pc,  pcp,  new[] { "632" }));
        lines.Add(new("", "Autres charges financières (3)",                               false, false, false, acf, acfp, new[] { "638" }));
        lines.Add(new("", "Dotations financières aux amortissements et provisions (4)",   false, false, false, df,  dfp,  new[] { "639" }));
        lines.Add(new("V", "TOTAL  V  —  CHARGES FINANCIÈRES",                           false, true,  false, t5,  t5p));

        decimal rf = t4 - t5, rfp = t4p - t5p;
        lines.Add(new("VI", "RÉSULTAT FINANCIER  ( IV - V )", false, false, true, rf, rfp));

        decimal rc = re + rf, rcp = rep + rfp;
        lines.Add(new("VII", "RÉSULTAT COURANT  ( III + VI )", false, false, true, rc, rcp));

        // ─── PRODUITS NON COURANTS ───────────────────────────────────
        decimal pci  = -C("751"), pcip  = -P("751");
        decimal seq  = -C("756"), seqp  = -P("756");
        decimal rsi  = -C("757"), rsip  = -P("757");
        decimal apnc = -C("758"), apncp = -P("758");
        decimal rpnc = -C("759"), rpncp = -P("759");
        decimal t8   = pci+seq+rsi+apnc+rpnc, t8p = pcip+seqp+rsip+apncp+rpncp;

        lines.Add(new("", "PRODUITS NON COURANTS", true, false, false, 0, 0));
        lines.Add(new("", "Produits des cessions d'immobilisations (1)",                  false, false, false, pci,  pcip,  new[] { "751" }));
        lines.Add(new("", "Subventions d'équilibre (2)",                                  false, false, false, seq,  seqp,  new[] { "756" }));
        lines.Add(new("", "Reprises sur subventions d'investissement (3)",                false, false, false, rsi,  rsip,  new[] { "757" }));
        lines.Add(new("", "Autres produits non courants (4)",                             false, false, false, apnc, apncp, new[] { "758" }));
        lines.Add(new("", "Reprises non courantes; transferts de charges (5)",            false, false, false, rpnc, rpncp, new[] { "759" }));
        lines.Add(new("VIII", "TOTAL  VIII  —  PRODUITS NON COURANTS",                   false, true,  false, t8,   t8p));

        // ─── CHARGES NON COURANTES ───────────────────────────────────
        decimal vna  = C("651"),  vnap  = P("651");
        decimal sa   = C("656"),  sap   = P("656");
        decimal acnc = C("658"),  acncp = P("658");
        decimal dnc  = C("659"),  dncp  = P("659");
        decimal t9   = vna+sa+acnc+dnc, t9p = vnap+sap+acncp+dncp;

        lines.Add(new("", "CHARGES NON COURANTES", true, false, false, 0, 0));
        lines.Add(new("", "Valeurs nettes d'amortissement des immobilisations cédées (1)", false, false, false, vna,  vnap,  new[] { "651" }));
        lines.Add(new("", "Subventions accordées (2)",                                    false, false, false, sa,   sap,   new[] { "656" }));
        lines.Add(new("", "Autres charges non courantes (3)",                             false, false, false, acnc, acncp, new[] { "658" }));
        lines.Add(new("", "Dotations non courantes aux amortissements et provisions (4)", false, false, false, dnc,  dncp,  new[] { "659" }));
        lines.Add(new("IX", "TOTAL  IX  —  CHARGES NON COURANTES",                       false, true,  false, t9,   t9p));

        decimal rnc  = t8 - t9,      rncp  = t8p  - t9p;
        decimal ravi = rc  + rnc,    ravip = rcp  + rncp;
        decimal imp  = C("670"),      impp  = P("670");
        decimal rnet = ravi - imp,    rnetp = ravip - impp;

        lines.Add(new("X",    "RÉSULTAT NON COURANT  ( VIII - IX )", false, false, true, rnc,  rncp));
        lines.Add(new("XI",   "RÉSULTAT AVANT IMPÔTS  ( VII + X )",  false, false, true, ravi, ravip));
        lines.Add(new("XII",  "IMPÔTS SUR LES RÉSULTATS",            false, false, false, imp,  impp, new[] { "670" }));
        lines.Add(new("XIII", "RÉSULTAT NET  ( XI - XII )",          false, false, true, rnet, rnetp));

        cpcLines = lines;
    }

    private static string Fmt(decimal v) => v == 0 ? "-" : v.ToString("N2");

    private static string GetRowClass(CpcLine line)
    {
        if (line.Cat == "XIII")  return "cpc-grand-result";
        if (line.Cat is "VII" or "XI") return "cpc-result cpc-result-key";
        if (line.IsResult)       return "cpc-result";
        if (line.IsTotal && line.Cat != "") return "cpc-total";
        if (line.IsTotal)        return "cpc-subtotal";
        if (line.IsHeader)       return "cpc-header";
        return "";
    }

    public void Dispose()
    {
        cpcLines?.Clear();
        detailItems?.Clear();
        cpcLines    = null;
        detailItems = null;
        detailPfx   = null;
    }
}

<style>
    .cpc-section {
        max-width: 860px;
        margin: 0 auto;
        background: #fff;
        border-radius: 6px;
        border: 1px solid #dbe3ef;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(15,23,42,.06);
    }

    .cpc-title {
        background: #203154;
        color: #fff;
        font-weight: 700;
        font-size: 1rem;
        letter-spacing: .04em;
        padding: .6rem 1rem;
        text-transform: uppercase;
    }

    .cpc-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .82rem;
        font-family: "Arial", sans-serif;
    }

    .cpc-table thead tr {
        background: #2d3f5f;
        color: #fff;
    }

    .cpc-table thead th {
        padding: .45rem .6rem;
        text-align: center;
        font-weight: 600;
        border: 1px solid #4a5e7a;
        white-space: nowrap;
    }

    .cpc-table tbody td {
        padding: .3rem .6rem;
        border: 1px solid #dbe3ef;
        vertical-align: middle;
    }

    .col-num-sm { width: 44px; text-align: center; font-weight: 700; font-size: .75rem; color: #203154; }
    .col-label  { min-width: 340px; }
    .col-num    { width: 120px; text-align: right; white-space: nowrap; }

    .fw-bold { font-weight: 700; }

    .cpc-header td      { background: #2d3f5f; color: #fff; font-weight: 700; text-transform: uppercase; font-size: .78rem; letter-spacing: .03em; }
    .cpc-subtotal td    { background: #eef1f6; font-weight: 600; font-style: italic; }
    .cpc-total td       { background: #d4dff0; font-weight: 700; }
    .cpc-result td      { background: #fef3c7; font-weight: 700; color: #92400e; }
    .cpc-result-key td  { background: #fde68a; }
    .cpc-grand-result td{ background: #203154; color: #fff; font-weight: 700; font-size: .88rem; }

    .cell-link { cursor: pointer; }
    .cell-link:hover td { filter: brightness(0.93); }

    .detail-table { width: 100%; border-collapse: collapse; font-size: .85rem; font-family: "Arial", sans-serif; }
    .detail-table th, .detail-table td { padding: .35rem .7rem; border: 1px solid #dbe3ef; }
    .detail-table thead tr { background: #2d3f5f; color: #fff; }
    .detail-table tfoot tr td { border-top: 2px solid #203154; }
</style>
