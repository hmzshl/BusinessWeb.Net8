@code
{
    [CascadingParameter]
    public SessionDT session { get; set; } = new SessionDT();
    DB db = new DB();
    private List<API_V_MARGE> items = new List<API_V_MARGE>();
    private List<ExpandoObject> clientGridRows = new List<ExpandoObject>();
    private List<ExpandoObject> articleGridRows = new List<ExpandoObject>();
    private List<MonthColumn> monthColumns = new List<MonthColumn>();
    DateTime? date1 = new DateTime(DateTime.Today.Year, 1, 1);
    DateTime? date2 = new DateTime(DateTime.Today.Year, 12, 31);
    IEnumerable<API_V_MARGE> data;
    bool IsLoaded = false;
    protected override async Task OnInitializedAsync()
    {
        db = session.db;
        GC.Collect();
        data = db.API_V_MARGE;
        await Task.Delay(1);
        await LoadData();
        IsLoaded = true;
    }
    private async Task LoadData()
    {
        IsLoaded = false;
        await Task.Delay(300);
        items = data
        .Where(a => ((date1 != null && a.DO_Date >= date1) || date1 == null) && ((date2 != null && a.DO_Date <= date2) || date2 == null))
        .OrderByDescending(a => a.DL_MontantTTC).ToList();
        BuildGridRows();
        IsLoaded = true;
        await Task.Delay(300);

    }
    SfGrid<ExpandoObject> RGGrid;
    SfGrid<ExpandoObject> FRGrid;
    SfGrid<ExpandoObject> ARGrid;

    private void BuildGridRows()
    {
        monthColumns = items
            .Where(a => a.DO_Date.HasValue)
            .GroupBy(a => new { a.DO_Date.Value.Year, a.DO_Date.Value.Month, a.MoisAnnee })
            .OrderBy(a => a.Key.Year)
            .ThenBy(a => a.Key.Month)
            .Select((a, index) => new MonthColumn
            {
                Caption = string.IsNullOrWhiteSpace(a.Key.MoisAnnee) ? $"{a.Key.Month:00}/{a.Key.Year}" : a.Key.MoisAnnee,
                AmountField = $"M{index}_Montant",
                QuantityField = $"M{index}_Qte",
                Year = a.Key.Year,
                Month = a.Key.Month
            })
            .ToList();

        clientGridRows = items
            .GroupBy(a => new { a.CT_CodeRegion, a.CT_Intitule, a.AR_Design })
            .Select(a => BuildRow(
                region: a.Key.CT_CodeRegion,
                tiers: a.Key.CT_Intitule,
                article: a.Key.AR_Design,
                source: a,
                includeQuantity: false))
            .OrderByDescending(a => GetDecimal(a, nameof(MonthlySalesGridRow.TotalMontant)))
            .ToList();

        articleGridRows = items
            .GroupBy(a => new { a.AR_Design, a.CT_Intitule })
            .Select(a => BuildRow(
                region: null,
                tiers: a.Key.CT_Intitule,
                article: a.Key.AR_Design,
                source: a,
                includeQuantity: true))
            .OrderByDescending(a => GetDecimal(a, nameof(MonthlySalesGridRow.TotalMontant)))
            .ToList();
    }

    private ExpandoObject BuildRow(string region, string tiers, string article, IEnumerable<API_V_MARGE> source, bool includeQuantity)
    {
        var row = new ExpandoObject();
        var values = (IDictionary<string, object>)row;

        values[nameof(MonthlySalesGridRow.Region)] = region;
        values[nameof(MonthlySalesGridRow.Tiers)] = tiers;
        values[nameof(MonthlySalesGridRow.Article)] = article;

        decimal totalAmount = 0;
        decimal totalQuantity = 0;

        foreach (var month in monthColumns)
        {
            var monthItems = source.Where(a => a.DO_Date.HasValue && a.DO_Date.Value.Year == month.Year && a.DO_Date.Value.Month == month.Month).ToList();
            var amount = monthItems.Sum(a => a.DL_MontantHT ?? 0);
            values[month.AmountField] = amount;
            totalAmount += amount;

            if (includeQuantity)
            {
                var quantity = monthItems.Sum(a => a.DL_Qte ?? 0);
                values[month.QuantityField] = quantity;
                totalQuantity += quantity;
            }
        }

        values[nameof(MonthlySalesGridRow.TotalQte)] = totalQuantity;
        values[nameof(MonthlySalesGridRow.TotalMontant)] = totalAmount;

        return row;
    }

    private decimal GetDecimal(ExpandoObject row, string field)
    {
        var values = (IDictionary<string, object>)row;
        return values.TryGetValue(field, out var value) && value is decimal decimalValue ? decimalValue : 0;
    }

    private string FormatAggregate(object context)
    {
        var value = (context as AggregateTemplateContext)?.Sum;
        return string.IsNullOrWhiteSpace(value) ? string.Empty : value;
    }

    private class MonthColumn
    {
        public string Caption { get; set; }
        public string AmountField { get; set; }
        public string QuantityField { get; set; }
        public int Year { get; set; }
        public int Month { get; set; }
    }

    private class MonthlySalesGridRow
    {
        public string Region { get; set; }
        public string Tiers { get; set; }
        public string Article { get; set; }
        public decimal TotalQte { get; set; }
        public decimal TotalMontant { get; set; }
    }

    protected async Task ShowDetail(RecordDoubleClickEventArgs<API_V_MARGE> args)
    {
        /*await DialogService.OpenAsync<DetailsAchat>(args.RowData.CT_Intitule,
        new Dictionary<string, object>() { { "Date1", date1 }, { "Date2", date2 }, { "CT_Num", args.RowData.CT_Num }, { "ClassHeight", "grid-84" } },
        new Radzen.DialogOptions() { CloseDialogOnEsc = true, Width = "98%", Height = "95%" });    */
    }
    public async Task CustomizeCell(Syncfusion.Blazor.Grids.QueryCellInfoEventArgs<API_V_MARGE> args)
    {
        var dt = args.Data;
        string col = args.Column.Field;
        string header = args.Column.HeaderText;
    }
