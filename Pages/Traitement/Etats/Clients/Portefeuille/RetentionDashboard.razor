@page "/et-retention-clients"
@attribute [Authorize]
@implements IDisposable
@if (IsLoaded)
{
    <Card_1 Title="@PageTitle">
        <RadzenContent>
            <div class="grid-container no-border">

                <SfToolbar CssClass="btns">
                    <ToolbarItems>
                        <ToolbarItem Align="ItemAlign.Left">
                            <Template>
                                <SfMessage Severity="MessageSeverity.Info" Variant="MessageVariant.Outlined">
                                    <div style="text-transform:uppercase;">
                                        Analyse du portefeuille clients — @annee vs @(annee - 1)
                                    </div>
                                </SfMessage>
                            </Template>
                        </ToolbarItem>
                        <ToolbarItem Align="ItemAlign.Right" Type="ItemType.Input">
                            <Template>
                                <SfDropDownList TValue="int" TItem="int" Width="130px" @bind-Value="annee"
                                                DataSource="@annees" Placeholder="Année N">
                                    <DropDownListEvents TValue="int" TItem="int" ValueChange="@(args => LoadData())" />
                                </SfDropDownList>
                            </Template>
                        </ToolbarItem>
                    </ToolbarItems>
                </SfToolbar>
                <GridRow>
                    <GridCol Xs="12" Md="4">
                        <StatCard3 Color="StatColor.Blue"
                                   Value="@totalActifsN1.ToString()"
                                   Title="@("Actifs " + (annee - 1))" 
                                   />
                    </GridCol>
                    <GridCol Xs="12" Md="4">
                        <StatCard3 Color="StatColor.Blue"
                                   Value="@totalActifsN.ToString()"
                                   Title="@("Actifs " + annee)" />
                    </GridCol>
                    <GridCol Xs="12" Md="4">
                        <StatCard3 Color="StatColor.Green"
                                   Value="@nbRetenus.ToString()"
                                   Title="Clients Retenus" />
                    </GridCol>
                    <GridCol Xs="12" Md="4">
                        <StatCard3 Color="StatColor.Amber"
                                   Value="@nbNouveaux.ToString()"
                                   Title="Nouveaux Clients" />
                    </GridCol>
                    <GridCol Xs="12" Md="4">
                        <StatCard3 Color="StatColor.Red"
                                   Value="@nbPerdus.ToString()"
                                   Title="Clients Perdus" />
                    </GridCol>
                    <GridCol Xs="12" Md="4">
                        <StatCard3 Color="@retentionColor"
                                   Value="@(tauxRetention.ToString("N1") + "%")"
                                   Title="Taux de Rétention" />
                    </GridCol>
                </GridRow>
                <GridRow>
                    <GridCol Xs="12" Md="6">
                        <StatCard3 Color="StatColor.Green"
                                   Value="@caRetenus.ToString("N0")"
                                   Title="@("CA Retenus " + annee)"
                                   ShowTrendText="true"
                                   IsPositiveTrend="true"
                                   TrendValue="@nbRetenus.ToString()"
                                   TrendText="clients" />
                    </GridCol>
                    <GridCol Xs="12" Md="6">
                        <StatCard3 Color="StatColor.Amber"
                                   Value="@caNouveaux.ToString("N0")"
                                   Title="@("CA Nouveaux " + annee)"
                                   ShowTrendText="true"
                                   IsPositiveTrend="true"
                                   TrendValue="@nbNouveaux.ToString()"
                                   TrendText="clients" />
                    </GridCol>
                    <GridCol Xs="12" Md="6">
                        <StatCard3 Color="StatColor.Red"
                                   Value="@caPerdus.ToString("N0")"
                                   Title="@("CA Perdu (abs. " + annee + ")")"
                                   ShowTrendText="true"
                                   IsPositiveTrend="false"
                                   TrendValue="@nbPerdus.ToString()"
                                   TrendText="clients" />
                    </GridCol>
                    <GridCol Xs="12" Md="6">
                        <StatCard3 Color="@(caNette >= 0 ? StatColor.Green : StatColor.Red)"
                                   Value="@((caNette >= 0 ? "+" : "") + caNette.ToString("N0"))"
                                   Title="Balance CA Nette"
                                   ShowTrendText="true"
                                   IsPositiveTrend="@(caNette >= 0)"
                                   TrendValue="@(tauxAcquisition.ToString("N1") + "%")"
                                   TrendText="taux acquisition" />
                    </GridCol>
                </GridRow>

                <GridRow>
                    <GridCol Xs="24">
                        <Card>
                            <div style="zoom: @session.zoomLevel;">
                                <SfChart Title="Répartition CA par catégorie clients" Width="100%"
                                         Theme="Syncfusion.Blazor.Theme.Tailwind3" Height="280px">
                                    <ChartArea><ChartAreaBorder Width="0" /></ChartArea>
                                    <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Charts.ValueType.Category">
                                        <ChartAxisMajorGridLines Width="0" />
                                        <ChartAxisMajorTickLines Width="0" />
                                    </ChartPrimaryXAxis>
                                    <ChartPrimaryYAxis LabelFormat="N0" EdgeLabelPlacement="EdgeLabelPlacement.Shift" Visible="false">
                                        <ChartAxisMajorTickLines Width="0" />
                                        <ChartAxisLineStyle Width="0" />
                                    </ChartPrimaryYAxis>
                                    <ChartTooltipSettings Enable="true" />
                                    <ChartSeriesCollection>
                                        <ChartSeries DataSource="@caChart" XName="Label" YName="Value"
                                                     Name="CA" Type="Syncfusion.Blazor.Charts.ChartSeriesType.Column"
                                                     Width="2" ColumnSpacing="0.5">
                                            <ChartMarker>
                                                <ChartDataLabel Visible="true" Position="Syncfusion.Blazor.Charts.LabelPosition.Top">
                                                    <ChartDataLabelFont FontWeight="700" Size="12" />
                                                </ChartDataLabel>
                                            </ChartMarker>
                                        </ChartSeries>
                                    </ChartSeriesCollection>
                                </SfChart>
                            </div>
                        </Card>
                    </GridCol>
                </GridRow>

            </div>
        </RadzenContent>
    </Card_1>
}
else
{
    <div class="center-screen"><Loading_1 /></div>
}

@code {
    [CascadingParameter] public SessionDT session { get; set; } = new SessionDT();
    DB db = new DB();
    int annee = DateTime.Today.Year;
    bool IsLoaded = false;

    private List<int> annees = Enumerable.Range(0, 10).Select(i => DateTime.Today.Year - i).ToList();
    private string PageTitle => "RÉTENTION CLIENTS — " + annee + " vs " + (annee - 1);

    int totalActifsN1, totalActifsN, nbRetenus, nbNouveaux, nbPerdus;
    decimal caRetenus, caNouveaux, caPerdus, caNette;
    decimal tauxRetention, tauxChurn, tauxAcquisition;

    private StatColor retentionColor => tauxRetention >= 70 ? StatColor.Green
                                      : tauxRetention >= 50 ? StatColor.Amber
                                      : StatColor.Red;

    private class ChartPoint { public string Label { get; set; } public decimal Value { get; set; } }
    private List<ChartPoint> caChart = new();

    protected override async Task OnInitializedAsync()
    {
        db = session.db;
        GC.Collect();
        await Task.Delay(1);
        await LoadData();
        IsLoaded = true;
    }

    private async Task LoadData()
    {
        IsLoaded = false;
        await Task.Delay(300);

        var dataN = db.API_V_MARGE
            .Where(a => a.DO_Date.HasValue && a.DO_Date.Value.Year == annee)
            .GroupBy(a => a.CT_Num)
            .Select(g => new { CT_Num = g.Key, CA = g.Sum(x => x.DL_MontantHT) ?? 0 })
            .ToDictionary(x => x.CT_Num, x => x.CA);

        var dataN1 = db.API_V_MARGE
            .Where(a => a.DO_Date.HasValue && a.DO_Date.Value.Year == (annee - 1))
            .GroupBy(a => a.CT_Num)
            .Select(g => new { CT_Num = g.Key, CA = g.Sum(x => x.DL_MontantHT) ?? 0 })
            .ToDictionary(x => x.CT_Num, x => x.CA);

        totalActifsN1 = dataN1.Count;
        totalActifsN = dataN.Count;
        nbRetenus = dataN1.Keys.Count(k => dataN.ContainsKey(k));
        nbNouveaux = dataN.Keys.Count(k => !dataN1.ContainsKey(k));
        nbPerdus = dataN1.Keys.Count(k => !dataN.ContainsKey(k));

        caRetenus = dataN.Where(x => dataN1.ContainsKey(x.Key)).Sum(x => x.Value);
        caNouveaux = dataN.Where(x => !dataN1.ContainsKey(x.Key)).Sum(x => x.Value);
        caPerdus = dataN1.Where(x => !dataN.ContainsKey(x.Key)).Sum(x => x.Value);
        caNette = caNouveaux - caPerdus;

        tauxRetention = totalActifsN1 > 0 ? Math.Round((decimal)nbRetenus / totalActifsN1 * 100, 1) : 0;
        tauxChurn = totalActifsN1 > 0 ? Math.Round((decimal)nbPerdus / totalActifsN1 * 100, 1) : 0;
        tauxAcquisition = totalActifsN > 0 ? Math.Round((decimal)nbNouveaux / totalActifsN * 100, 1) : 0;

        caChart = new List<ChartPoint>
        {
            new() { Label = "Retenus",  Value = caRetenus  },
            new() { Label = "Nouveaux", Value = caNouveaux },
            new() { Label = "Perdus",   Value = caPerdus   }
        };

        IsLoaded = true;
        await Task.Delay(300);
    }

    public void Dispose() { }
}
