@page "/et-rg-dashboard"
@page "/et-rg-dashboard-clients"
@page "/et-rg-dashboard-fournisseurs"
@attribute [Authorize]
@implements IDisposable
@inject NavigationManager Navigation

@if (IsLoaded)
{
    <Card_1 Title="@($"TABLEAU DE BORD REGLEMENTS {TiersLabelPlural.ToUpper()}")">
        <RadzenContent>
            <div class="grid-container no-border">

                <SfToolbar CssClass="btns">
                    <ToolbarItems>
                        <ToolbarItem Align="ItemAlign.Left">
                            <Template>
                                <SfMessage Severity="MessageSeverity.Info" Variant="MessageVariant.Outlined">
                                    <div style="text-transform: uppercase;">
                                        @items.Count règlement(s) | Total : @TotalMontant.ToString("N0")
                                    </div>
                                </SfMessage>
                            </Template>
                        </ToolbarItem>
                        <ToolbarItem Align="ItemAlign.Right" Type="ItemType.Input">
                            <Template>
                                <div style="display:flex; gap:8px; align-items:center;">
                                    <SfDatePicker Width="140px" TValue="DateTime?" @bind-Value="date1" Placeholder="Date début" ShowClearButton ShowTodayButton>
                                        <DatePickerEvents TValue="DateTime?" ValueChange="@(args => LoadData())"></DatePickerEvents>
                                    </SfDatePicker>
                                    <SfDatePicker Width="140px" TValue="DateTime?" @bind-Value="date2" Placeholder="Date fin" ShowClearButton ShowTodayButton>
                                        <DatePickerEvents TValue="DateTime?" ValueChange="@(args => LoadData())"></DatePickerEvents>
                                    </SfDatePicker>
                                </div>
                            </Template>
                        </ToolbarItem>
                    </ToolbarItems>
                </SfToolbar>

                <GridRow Style="margin-bottom:12px;">
                    <GridCol Xs="12" Md="6">
                        <StatCard3 Color="StatColor.Blue" Value="@TotalMontant.ToString("N0")" Title="@($"Total {TiersLabelPlural}")" />
                    </GridCol>
                    <GridCol Xs="12" Md="6">
                        <StatCard3 Color="StatColor.Green" Value="@items.Count.ToString("N0")" Title="Nombre règlements" />
                    </GridCol>
                    <GridCol Xs="12" Md="6">
                        <StatCard3 Color="StatColor.Red" Value="@items.Count(x => x.Impaye == true).ToString("N0")" Title="Impayés" />
                    </GridCol>
                    <GridCol Xs="12" Md="6">
                        <StatCard3 Color="StatColor.Amber" Value="@items.Count(x => x.Rappro == true).ToString("N0")" Title="Rapprochés" />
                    </GridCol>
                </GridRow>

                <GridRow>
                    <GridCol Xs="24" Md="16">
                        <Card>
                            <div style="zoom: @session.zoomLevel; height: 24vh;">
                                <SfChart Title="@($"Evolution mensuelle des règlements {TiersLabelPlural}")" Width="100%"
                                         Theme="Syncfusion.Blazor.Theme.Tailwind3" Height="100%">
                                    <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Charts.ValueType.Category" />
                                    <ChartPrimaryYAxis LabelFormat="N0" />
                                    <ChartTooltipSettings Enable="true" />
                                    <ChartLegendSettings Visible="true" />
                                    <ChartSeriesCollection>
                                        <ChartSeries DataSource="@monthlyData" XName="Period" YName="Montant"
                                                     Name="Montant" Type="Syncfusion.Blazor.Charts.ChartSeriesType.Column">
                                            <ChartMarker>
                                                <ChartDataLabel Visible="true" Position="Syncfusion.Blazor.Charts.LabelPosition.Top">
                                                    <ChartDataLabelFont FontWeight="600" Size="10px" />
                                                </ChartDataLabel>
                                            </ChartMarker>
                                        </ChartSeries>
                                        <ChartSeries DataSource="@monthlyData" XName="Period" YName="Montant"
                                                     Name="Tendance" Type="Syncfusion.Blazor.Charts.ChartSeriesType.Line" Width="2">
                                        </ChartSeries>
                                    </ChartSeriesCollection>
                                </SfChart>
                            </div>
                        </Card>
                    </GridCol>
                    <GridCol Xs="24" Md="8">
                        <Card>
                            <div style="zoom: @session.zoomLevel; height: 24vh;">
                                <SfAccumulationChart Title="Modes de paiement" Width="100%"
                                                     Theme="Syncfusion.Blazor.Theme.Tailwind3" Height="100%">
                                    <AccumulationChartTooltipSettings Enable="true" />
                                    <AccumulationChartLegendSettings Visible="true" />
                                    <AccumulationChartSeriesCollection>
                                        <AccumulationChartSeries DataSource="@modeData" XName="Label" YName="Montant"
                                                                 Name="Montant" InnerRadius="35%">
                                            <AccumulationDataLabelSettings Visible="true" Name="Label"
                                                                           Position="Syncfusion.Blazor.Charts.AccumulationLabelPosition.Outside">
                                                <AccumulationChartDataLabelFont FontWeight="600" Size="11" />
                                            </AccumulationDataLabelSettings>
                                        </AccumulationChartSeries>
                                    </AccumulationChartSeriesCollection>
                                </SfAccumulationChart>
                            </div>
                        </Card>
                    </GridCol>
                </GridRow>

                <GridRow>
                    <GridCol Xs="24" Md="16">
                        <Card>
                            <div style="zoom: @session.zoomLevel; height: 38vh;">
                                <SfGrid EnableVirtualization Height="100%" DataSource="@tiersData"
                                        Toolbar="@(new List<object>() { "ExcelExport", "Search" })"
                                        AllowSorting AllowResizing>
                                    <GridPageSettings PageSize="30" />
                                    <GridColumns>
                                        <GridColumn HeaderText="@TiersLabel" Field="@nameof(RgTiersItem.Tiers)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                        <GridColumn Width="120" HeaderText="Ville" Field="@nameof(RgTiersItem.Ville)" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                        <GridColumn Width="80" HeaderText="Nb" Field="@nameof(RgTiersItem.Nb)" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                        <GridColumn Width="140" HeaderText="Montant" Field="@nameof(RgTiersItem.Montant)" Format="N2" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                        <GridColumn Width="90" HeaderText="% Total" Field="@nameof(RgTiersItem.PctLabel)" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                        <GridColumn Width="90" HeaderText="Impayés" Field="@nameof(RgTiersItem.NbImpayes)" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                        <GridColumn Width="110" HeaderText="Rapprochés" Field="@nameof(RgTiersItem.NbRapproches)" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" HeaderTextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" />
                                    </GridColumns>
                                </SfGrid>
                            </div>
                        </Card>
                    </GridCol>
                    <GridCol Xs="24" Md="8">
                        <Card>
                            <div style="zoom: @session.zoomLevel; height: 38vh;">
                                <SfAccumulationChart Title="Etat des échéances" Width="100%"
                                                     Theme="Syncfusion.Blazor.Theme.Tailwind3" Height="100%">
                                    <AccumulationChartTooltipSettings Enable="true" />
                                    <AccumulationChartLegendSettings Visible="true" />
                                    <AccumulationChartSeriesCollection>
                                        <AccumulationChartSeries DataSource="@echeanceData" XName="Label" YName="Montant"
                                                                 Name="Montant" InnerRadius="35%">
                                            <AccumulationDataLabelSettings Visible="true" Name="Label"
                                                                           Position="Syncfusion.Blazor.Charts.AccumulationLabelPosition.Outside">
                                                <AccumulationChartDataLabelFont FontWeight="600" Size="11" />
                                            </AccumulationDataLabelSettings>
                                        </AccumulationChartSeries>
                                    </AccumulationChartSeriesCollection>
                                </SfAccumulationChart>
                            </div>
                        </Card>
                    </GridCol>
                </GridRow>

            </div>
        </RadzenContent>
    </Card_1>
}
else
{
    <div class="center-screen"><Loading_1 /></div>
}

@code {
    [CascadingParameter] public SessionDT session { get; set; } = new SessionDT();
    DB db = new DB();

    private List<API_V_CREGLEMENT> items = new();
    private List<RgPeriodItem> monthlyData = new();
    private List<RgAmountItem> modeData = new();
    private List<RgAmountItem> echeanceData = new();
    private List<RgTiersItem> tiersData = new();

    DateTime? date1 = new DateTime(DateTime.Today.Year, 1, 1);
    DateTime? date2 = new DateTime(DateTime.Today.Year, 12, 31);
    bool IsLoaded = false;
    short? loadedRgType = null;

    private bool IsFournisseurs => Navigation.Uri.Contains("fournisseurs", StringComparison.OrdinalIgnoreCase);
    private short RgType => IsFournisseurs ? (short)1 : (short)0;
    private string TiersLabel => IsFournisseurs ? "Fournisseur" : "Client";
    private string TiersLabelPlural => IsFournisseurs ? "Fournisseurs" : "Clients";
    private decimal TotalMontant => items.Sum(x => x.RG_Montant ?? 0);

    private class RgPeriodItem
    {
        public string Period { get; set; }
        public int Nb { get; set; }
        public decimal Montant { get; set; }
    }

    private class RgAmountItem
    {
        public string Label { get; set; }
        public decimal Montant { get; set; }
    }

    private class RgTiersItem
    {
        public string Tiers { get; set; }
        public string Ville { get; set; }
        public int Nb { get; set; }
        public decimal Montant { get; set; }
        public string PctLabel { get; set; }
        public int NbImpayes { get; set; }
        public int NbRapproches { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        db = session.db;
        GC.Collect();
        await Task.Delay(1);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (loadedRgType != RgType)
        {
            loadedRgType = RgType;
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        IsLoaded = false;
        await Task.Delay(300);

        items = db.API_V_CREGLEMENT
            .Where(r => r.RG_Type == RgType
                     && r.RG_Date.HasValue
                     && ((date1 != null && r.RG_Date >= date1) || date1 == null)
                     && ((date2 != null && r.RG_Date <= date2) || date2 == null))
            .OrderByDescending(r => r.RG_Date)
            .ToList();

        BuildDashboardData();

        IsLoaded = true;
        await Task.Delay(300);
    }

    private void BuildDashboardData()
    {
        var total = TotalMontant;

        monthlyData = items
            .Where(r => r.RG_Date.HasValue)
            .GroupBy(r => new { r.RG_Date.Value.Year, r.RG_Date.Value.Month })
            .OrderBy(g => g.Key.Year)
            .ThenBy(g => g.Key.Month)
            .Select(g => new RgPeriodItem
            {
                Period = $"{g.Key.Month:00}/{g.Key.Year}",
                Nb = g.Count(),
                Montant = g.Sum(x => x.RG_Montant ?? 0)
            })
            .ToList();

        modeData = items
            .GroupBy(r => string.IsNullOrWhiteSpace(r.R_Intitule) ? "Non renseigné" : r.R_Intitule)
            .Select(g => new RgAmountItem { Label = g.Key, Montant = g.Sum(x => x.RG_Montant ?? 0) })
            .OrderByDescending(x => x.Montant)
            .Take(10)
            .ToList();

        echeanceData = items
            .GroupBy(r => string.IsNullOrWhiteSpace(r.Echeance) ? "Non renseigné" : r.Echeance)
            .Select(g => new RgAmountItem { Label = g.Key, Montant = g.Sum(x => x.RG_Montant ?? 0) })
            .OrderByDescending(x => x.Montant)
            .ToList();

        tiersData = items
            .GroupBy(r => new { r.CT_Intitule, r.CT_Ville })
            .Select(g =>
            {
                var montant = g.Sum(x => x.RG_Montant ?? 0);
                return new RgTiersItem
                {
                    Tiers = string.IsNullOrWhiteSpace(g.Key.CT_Intitule) ? "Non renseigné" : g.Key.CT_Intitule,
                    Ville = g.Key.CT_Ville,
                    Nb = g.Count(),
                    Montant = montant,
                    PctLabel = total > 0 ? ((montant / total) * 100).ToString("N1") + "%" : "0%",
                    NbImpayes = g.Count(x => x.Impaye == true),
                    NbRapproches = g.Count(x => x.Rappro == true)
                };
            })
            .OrderByDescending(x => x.Montant)
            .Take(50)
            .ToList();

    }

    public void Dispose()
    {
        items?.Clear();
        monthlyData?.Clear();
        modeData?.Clear();
        echeanceData?.Clear();
        tiersData?.Clear();
    }
}
