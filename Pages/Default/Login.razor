<ErrorBoundary @ref="errorBoundary">
    <ChildContent>
        <RadzenLayout class="business-login-layout">
            <RadzenBody>
                <div class="business-login-shell">
                    <RadzenCard class="business-login-card">
                        <div class="business-login-header">
                            <RadzenStack Orientation="Radzen.Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
                                <span class="business-login-logo">
                                    <RadzenIcon Icon="business" />
                                </span>
                                <div>
                                    <div class="business-login-brand">BusinessWeb</div>
                                    <div class="business-login-welcome">Bienvenue</div>
                                </div>
                            </RadzenStack>
                            <div class="business-login-caption">Connectez-vous pour accéder à vos sociétés et à vos données.</div>
                        </div>

                        <div class="business-login-body">
                            <div class="business-login-title-row">
                                <div>
                                    <div class="business-login-title">Connexion</div>
                                    <div class="business-login-subtitle">Espace sécurisé</div>
                                </div>
                                <span class="business-login-lock">
                                    <RadzenIcon Icon="lock" />
                                </span>
                            </div>

                            <div class="business-login-form-panel">
                                <RadzenTemplateForm Action="@($"account/login?redirectUrl={redirectUrl}")" Data="@("login")" Method="post">
                                    <RadzenAlert Shade="Radzen.Shade.Lighter" Size="Radzen.AlertSize.Small" AlertStyle="Radzen.AlertStyle.Danger" Visible="@errorVisible">@error</RadzenAlert>
                                    <RadzenAlert Shade="Radzen.Shade.Lighter" Size="Radzen.AlertSize.Small" AlertStyle="Radzen.AlertStyle.Info" Visible="@infoVisible">@info</RadzenAlert>
                                    <RadzenLogin LoginText="Se connecter" PasswordText="Mot de passe" UserText="Nom d'utilisateur" AllowResetPassword="false" AllowRegister="false" />
                                </RadzenTemplateForm>
                            </div>
                        </div>
                    </RadzenCard>

                    <RadzenText Text="BusinessWeb, Copyright to NOVELDATA Ⓒ 2026" TextStyle="Radzen.Blazor.TextStyle.Caption" TextAlign="Radzen.TextAlign.Center" class="business-login-footer" TagName="Radzen.Blazor.TagName.P" />
                </div>
            </RadzenBody>
        </RadzenLayout>
    </ChildContent>
    <ErrorContent Context="ex">
        <div style="padding: 2rem;">
            <RadzenCard>
                <div style="padding: 1.5rem;">
                    <RadzenStack Orientation="Radzen.Orientation.Vertical" Gap="1rem">
                        <RadzenText Style="font-size: 1.25rem; font-weight: bold; color: #e74c3c;">
                            <RadzenIcon Icon="error" Style="margin-right: 0.5rem;" />
                            Erreur
                        </RadzenText>

                        <RadzenText Style="font-weight: bold;">
                            @ex.Message
                        </RadzenText>

                        <RadzenAccordion>
                            <Items>
                                <RadzenAccordionItem Text="Détails techniques" Icon="code"
                                                     ExpandTitle="Afficher les détails techniques"
                                                     CollapseTitle="Masquer les détails techniques">
                                    <RadzenText Style="font-size: 0.8rem; white-space: pre-wrap; font-family: monospace; background: #f8f9fa; padding: 1rem; border-radius: 4px;">
                                        @ex.ToString()
                                    </RadzenText>
                                </RadzenAccordionItem>
                            </Items>
                        </RadzenAccordion>

                        <RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="1rem" Style="margin-top: 1rem;">
                            <RadzenButton Click="@GoBack" Text="Accueil" Icon="home" />
                            <RadzenButton Click="@Reload" Text="Réessayer" Icon="refresh" ButtonStyle="ButtonStyle.Secondary" />
                        </RadzenStack>
                    </RadzenStack>
                </div>
            </RadzenCard>
        </div>
    </ErrorContent>
</ErrorBoundary>

<style>
    .business-login-layout {
        min-height: 100vh;
        background: #f3f6fb;
        font-family: "Ubuntu", system-ui, -apple-system, "Segoe UI", sans-serif !important;
    }

    .business-login-shell {
        min-height: 80vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        font-family: "Ubuntu", system-ui, -apple-system, "Segoe UI", sans-serif !important;
    }

    .business-login-card {
        width: 100%;
        max-width: 540px;
        padding: 0;
        overflow: hidden;
        border-radius: 8px;
        border: 1px solid #dbe3ef;
        box-shadow: 0 18px 55px rgba(15, 23, 42, 0.14);
        font-family: "Ubuntu", system-ui, -apple-system, "Segoe UI", sans-serif !important;
    }

    .business-login-card *,
    .business-login-card .rz-button,
    .business-login-card .rz-button-text,
    .business-login-card .rz-alert,
    .business-login-card .rz-alert * {
        font-family: "Ubuntu", system-ui, -apple-system, "Segoe UI", sans-serif !important;
    }

    .business-login-layout .rzi,
    .business-login-layout .rz-icon,
    .business-login-layout .rz-button-icon,
    .business-login-layout .material-icons,
    .business-login-card .rzi,
    .business-login-card .rz-icon,
    .business-login-card .rz-button-icon,
    .business-login-card .material-icons {
        font-family: "Material Icons" !important;
    }

    .business-login-header {
        background: #203154;
        padding: 1.75rem 2rem 1.5rem;
        color: #fff;
    }

    .business-login-logo {
        width: 38px;
        height: 38px;
        flex: 0 0 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.12);
        color: #fff;
    }

    .business-login-logo .rzi {
        color: #fff !important;
        font-size: 1.45rem !important;
    }

    .business-login-brand {
        font-size: 1.05rem;
        font-weight: 700;
        line-height: 1.15;
    }

    .business-login-welcome {
        margin-top: 0.15rem;
        color: rgba(255, 255, 255, 0.74);
        font-size: 0.85rem;
    }

    .business-login-caption {
        max-width: 360px;
        margin-top: 0.9rem;
        color: rgba(255, 255, 255, 0.68);
        font-size: 0.8rem;
        line-height: 1.45;
    }

    .business-login-body {
        padding: 1.5rem 2rem 1.75rem;
        background: #fff;
    }

    .business-login-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .business-login-title {
        color: #0f172a;
        font-size: 1.05rem;
        font-weight: 700;
        line-height: 1.2;
    }

    .business-login-subtitle {
        margin-top: 0.25rem;
        color: #64748b;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0;
        text-transform: uppercase;
    }

    .business-login-lock {
        width: 38px;
        height: 38px;
        flex: 0 0 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background: #203154;
        color: #fff;
    }

    .business-login-lock .rzi {
        color: #fff !important;
        font-size: 1.1rem !important;
    }

    .business-login-form-panel {
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        background: #fff;
        padding: 1rem;
    }

    .business-login-card .rz-login,
    .business-login-card .rz-login > div,
    .business-login-card .rz-form,
    .business-login-card .rz-form > div {
        width: 100%;
    }

    .business-login-card .rz-login .rz-form {
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
    }

    .business-login-card .rz-form-field,
    .business-login-card .rz-textbox,
    .business-login-card .rz-password,
    .business-login-card .rz-inputtext,
    .business-login-card input {
        width: 100% !important;
    }

    .business-login-card .rz-textbox,
    .business-login-card .rz-password,
    .business-login-card .rz-inputtext {
        min-height: 38px !important;
        border-color: #cfd9e8 !important;
        border-radius: 8px !important;
        background: #fff !important;
        color: #0f172a !important;
        font-size: 0.86rem !important;
        box-shadow: none !important;
    }

    .business-login-card .rz-textbox:hover,
    .business-login-card .rz-password:hover,
    .business-login-card .rz-inputtext:hover {
        border-color: #9fb2cd !important;
        background: #f8fafc !important;
    }

    .business-login-card .rz-textbox:focus,
    .business-login-card .rz-password:focus,
    .business-login-card .rz-inputtext:focus {
        border-color: #203154 !important;
        box-shadow: 0 0 0 3px rgba(32, 49, 84, 0.12) !important;
    }

    .business-login-card .rz-button,
    .business-login-card .rz-login-button {
        width: 100%;
        min-height: 40px !important;
        border-radius: 8px !important;
        border-color: #203154 !important;
        background: #203154 !important;
        color: #fff !important;
        font-weight: 700 !important;
        text-transform: none !important;
        box-shadow: none !important;
    }

    .business-login-card .rz-button:hover,
    .business-login-card .rz-login-button:hover {
        border-color: #2a4070 !important;
        background: #2a4070 !important;
    }

    .business-login-card .rz-alert {
        margin-bottom: 0.8rem;
        border-radius: 8px !important;
        border: 1px solid #dbe3ef;
        font-size: 0.78rem;
    }

    .business-login-footer {
        width: 100%;
        margin-top: 1rem;
        color: rgba(32, 49, 84, 0.68);
        font-family: "Ubuntu", system-ui, -apple-system, "Segoe UI", sans-serif !important;
        font-size: 0.72rem !important;
    }

    @@media (max-width: 768px) {
        .business-login-shell {
            min-height: 100vh;
            padding: 1rem;
            align-items: stretch;
        }

        .business-login-card {
            max-width: none;
        }

        .business-login-header,
        .business-login-body {
            padding-left: 1.25rem;
            padding-right: 1.25rem;
        }

        .business-login-form-panel {
            padding: 0.75rem;
        }
    }
</style>

@code {
    protected string redirectUrl;
    protected string error;
    protected string info;
    protected bool errorVisible;
    protected bool infoVisible;
    ErrorBoundary errorBoundary;

    [Inject]
    protected SecurityService Security { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var query = System.Web.HttpUtility.ParseQueryString(new Uri(NavigationManager.ToAbsoluteUri(NavigationManager.Uri).ToString()).Query);

        error = query.Get("error");

        info = query.Get("info");

        redirectUrl = query.Get("redirectUrl");
        if (string.IsNullOrWhiteSpace(redirectUrl))
        {
            redirectUrl = "select-societe";
        }

        errorVisible = !string.IsNullOrEmpty(error);

        infoVisible = !string.IsNullOrEmpty(info);

        //await sdb.Database.MigrateAsync();

    }
    private void GoBack()
    {
        NavigationManager.NavigateTo("/");
    }
    private void Reload()
    {
        NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
    }
}
