        border-top: 0;
        border-radius: 0 0 14px 14px;
    }

    .business-login-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .business-login-title {
        color: var(--business-login-ink);
        font-size: 1.12rem;
        font-weight: 800;
        line-height: 1.15;
    }

    .business-login-subtitle {
        margin-top: 0.2rem;
        color: #64748b;
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    .business-login-lock {
        width: 34px;
        height: 34px;
        flex: 0 0 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--business-login-line);
        border-radius: 8px;
        background: #eef4ff;
        color: var(--business-login-primary);
    }

    .business-login-lock .rzi {
        color: var(--business-login-primary) !important;
        font-size: 1.05rem !important;
    }

    .business-login-form-panel {
        border: 1px solid #e7edf6;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.78);
        box-shadow: 0 16px 34px rgba(15, 23, 42, 0.09);
        padding: 1rem;
    }

    .business-login-card .rz-login,
    .business-login-card .rz-login > div {
        width: 100%;
    }

    .business-login-card .rz-form-field,
    .business-login-card .rz-textbox,
    .business-login-card .rz-password,
    .business-login-card .rz-inputtext,
    .business-login-card input {
        width: 100% !important;
    }

    .business-login-card .rz-textbox,
    .business-login-card .rz-password,
    .business-login-card .rz-inputtext {
        border-color: #cfd9e8 !important;
        border-radius: 8px !important;
        background: #ffffff !important;
        color: #1f2a3d !important;
        box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.04);
        transition: border-color 160ms ease, box-shadow 160ms ease, background-color 160ms ease;
        min-height: 36px !important;
        font-size: 0.82rem !important;
    }

    .business-login-card .rz-textbox:hover,
    .business-login-card .rz-password:hover,
    .business-login-card .rz-inputtext:hover {
        border-color: #9fb2cd !important;
        background: #fbfdff !important;
    }

    .business-login-card .rz-textbox:focus,
    .business-login-card .rz-password:focus,
    .business-login-card .rz-inputtext:focus {
        border-color: var(--business-login-primary) !important;
        box-shadow: 0 0 0 3px rgba(32, 49, 84, 0.14) !important;
    }

    .business-login-card .rz-button,
    .business-login-card .rz-login-button {
        width: 100%;
        border-radius: 8px !important;
        background: linear-gradient(180deg, var(--business-login-primary-2) 0%, var(--business-login-primary) 100%) !important;
        border-color: var(--business-login-primary) !important;
        color: #ffffff !important;
        font-weight: 700 !important;
        min-height: 38px !important;
        box-shadow: 0 12px 24px rgba(32, 49, 84, 0.24);
        transition: transform 160ms ease, box-shadow 160ms ease, background-color 160ms ease;
    }

    .business-login-card .rz-button:hover,
    .business-login-card .rz-login-button:hover {
        background: #2b416f !important;
        border-color: #2b416f !important;
        box-shadow: 0 16px 30px rgba(32, 49, 84, 0.30);
        transform: translateY(-1px);
    }

    .business-login-card .rz-login .rz-button {
        margin-top: 0.25rem;
    }

    .business-login-card .rz-alert {
        border-radius: 8px !important;
        border: 1px solid #dbe3ef;
        margin-bottom: 0.8rem;
        font-size: 0.76rem;
    }

    .business-login-footer {
        position: relative;
        z-index: 3;
        width: 100%;
        margin-top: 1rem;
