<ErrorBoundary @ref="errorBoundary">
    <ChildContent>
        <RadzenLayout class="business-login-shell">
            <RadzenBody>
                <div class="business-login-page">
                    <div class="business-login-stage">
                        <RadzenCard class="business-login-card">
                            <div class="business-login-card-shine"></div>
                            <div class="business-login-header">
                                <div class="business-login-header-pattern"></div>
                                <RadzenStack Orientation="Radzen.Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
                                    <span class="business-login-logo-mark">
                                        <RadzenIcon Icon="verified_user" />
                                    </span>
                                    <div>
                                        <div class="business-login-brand">BusinessWeb</div>
                                        <div class="business-login-welcome">Bienvenue</div>
                                    </div>
                                </RadzenStack>
                                <div class="business-login-caption">Connectez-vous pour accéder à vos sociétés et à vos données.</div>
                            </div>

                            <div class="business-login-body">
                                <div class="business-login-title-row">
                                    <div>
                                        <div class="business-login-title">Connexion</div>
                                        <div class="business-login-subtitle">Espace sécurisé</div>
                                    </div>
                                    <span class="business-login-lock">
                                        <RadzenIcon Icon="lock" />
                                    </span>
                                </div>
                                <div class="business-login-form-panel">
                                    <RadzenTemplateForm Action="@($" account/login?redirectUrl={redirectUrl}")" Data="@("login")" Method="post">
                                        <RadzenAlert Shade="Radzen.Shade.Lighter" Size="Radzen.AlertSize.Small" AlertStyle="Radzen.AlertStyle.Danger" Visible="@errorVisible">@error</RadzenAlert>
                                        <RadzenAlert Shade="Radzen.Shade.Lighter" Size="Radzen.AlertSize.Small" AlertStyle="Radzen.AlertStyle.Info" Visible="@infoVisible">@info</RadzenAlert>
                                        <RadzenLogin LoginText="SE CONNECTER" PasswordText="Mot de passe" UserText="Nom d'utilisateur" AllowResetPassword="false" AllowRegister="false" />
                                    </RadzenTemplateForm>
                                </div>
                            </div>
                        </RadzenCard>
                    </div>

                    <RadzenText Text="BusinessWeb, Copyright to NOVELDATA Ⓒ 2026" TextStyle="Radzen.Blazor.TextStyle.Caption" TextAlign="Radzen.TextAlign.Center" class="business-login-footer" TagName="Radzen.Blazor.TagName.P" />
                </div>
            </RadzenBody>
        </RadzenLayout>
    </ChildContent>
    <ErrorContent Context="ex">
        <div style="padding: 2rem;">
            <RadzenCard>
                <div style="padding: 1.5rem;">
                    <RadzenStack Orientation="Radzen.Orientation.Vertical" Gap="1rem">
                        <RadzenText Style="font-size: 1.25rem; font-weight: bold; color: #e74c3c;">
                            <RadzenIcon Icon="error" Style="margin-right: 0.5rem;" />
                            Erreur
                        </RadzenText>

                        <RadzenText Style="font-weight: bold;">
                            @ex.Message
                        </RadzenText>

                        <RadzenAccordion>
                            <Items>
                                <RadzenAccordionItem Text="Détails techniques" Icon="code"
                                                     ExpandTitle="Afficher les détails techniques"
                                                     CollapseTitle="Masquer les détails techniques">
                                    <RadzenText Style="font-size: 0.8rem; white-space: pre-wrap; font-family: monospace; background: #f8f9fa; padding: 1rem; border-radius: 4px;">
                                        @ex.ToString()
                                    </RadzenText>
                                </RadzenAccordionItem>
                            </Items>
                        </RadzenAccordion>

                        <RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="1rem" Style="margin-top: 1rem;">
                            <RadzenButton Click="@GoBack" Text="Accueil" Icon="home" />
                            <RadzenButton Click="@Reload" Text="Réessayer" Icon="refresh" ButtonStyle="ButtonStyle.Secondary" />
                        </RadzenStack>
                    </RadzenStack>
                </div>
            </RadzenCard>
        </div>
    </ErrorContent>
</ErrorBoundary>






<style>
    .rz-login .rz-form {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .business-login-shell {
        --business-login-ink: #0f172a;
        --business-login-primary: #203154;
        --business-login-primary-2: #2a4070;
        --business-login-primary-3: #3d5d98;
        --business-login-line: #dbe3ef;
        --business-login-soft: #f7f9fc;
        position: relative;
        min-height: 90vh;
        background:
            radial-gradient(circle at 50% 18%, rgba(143, 178, 242, 0.24), transparent 30%),
            radial-gradient(circle at 12% 80%, rgba(32, 49, 84, 0.11), transparent 28%),
            var(--business-login-soft);
        overflow: hidden;
    }

    .business-login-shell::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
            linear-gradient(90deg, rgba(32, 49, 84, 0.045) 1px, transparent 1px),
            linear-gradient(180deg, rgba(32, 49, 84, 0.035) 1px, transparent 1px);
        background-size: 58px 58px;
        mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.54), transparent 82%);
        pointer-events: none;
    }

    .business-login-shell::after {
        content: "";
        position: absolute;
        inset: auto 0 0;
        height: 46%;
        background: linear-gradient(180deg, transparent, rgba(32, 49, 84, 0.08));
        pointer-events: none;
    }

    .business-login-page {
        position: relative;
        z-index: 1;
        min-height: 80vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }

    .business-login-stage {
        width: min(100%, 430px);
        display: flex;
        flex-direction: column;
        align-items: center;
        border: 0;
        border-radius: 0;
        background: transparent;
        box-shadow: none;
    }

    .business-login-card {
        position: relative;
        width: 100%;
        max-width: 430px;
        padding: 0;
        overflow: hidden;
        border-radius: 14px;
        border: 0;
        background: #ffffff;
        box-shadow:
            0 4px 6px rgba(20, 25, 50, 0.04),
            0 22px 60px rgba(32, 49, 84, 0.18);
        display: flex;
        flex-direction: column;
        font-family: "Ubuntu", system-ui, -apple-system, "Segoe UI", sans-serif !important;
    }

    .business-login-card::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        pointer-events: none;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.94);
        z-index: 2;
    }

    .business-login-card-shine {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.52), transparent 34%);
        pointer-events: none;
        z-index: 1;
    }

    .business-login-card *,
    .business-login-card .rz-button,
    .business-login-card .rz-button-text,
    .business-login-card .rz-alert,
    .business-login-card .rz-alert * {
        font-family: "Ubuntu", system-ui, -apple-system, "Segoe UI", sans-serif !important;
    }

    .business-login-card .rzi,
    .business-login-card .rz-button-icon,
    .business-login-card .rz-icon,
    .business-login-card .material-icons {
        font-family: "Material Icons" !important;
    }

    .business-login-header {
        position: relative;
        z-index: 2;
        width: 100%;
        background:
            radial-gradient(circle at 86% 8%, rgba(143, 178, 242, 0.34), transparent 32%),
            linear-gradient(180deg, var(--business-login-primary-2) 0%, var(--business-login-primary) 100%);
        color: #ffffff;
        padding: 1.65rem 1.75rem 1.45rem;
        overflow: hidden;
        border: 1px solid #c8d5e8;
        border-bottom: 0;
        border-radius: 14px 14px 0 0;
    }

    .business-login-header::after {
        content: "";
        position: absolute;
        inset: auto 0 0;
        height: 3px;
        background: linear-gradient(90deg, #8fb2f2, #ffffff, var(--business-login-primary-3));
        opacity: 0.7;
    }

    .business-login-header > *:not(.business-login-header-pattern) {
        position: relative;
        z-index: 1;
    }

    .business-login-header-pattern {
        position: absolute;
        inset: 0;
        background:
            linear-gradient(135deg, transparent 0 58%, rgba(255, 255, 255, 0.07) 58% 60%, transparent 60%),
            linear-gradient(45deg, transparent 0 72%, rgba(255, 255, 255, 0.045) 72% 74%, transparent 74%);
        background-size: 74px 74px;
        opacity: 0.8;
    }

    .business-login-logo-mark {
        width: 46px;
        height: 46px;
        flex: 0 0 46px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255, 255, 255, 0.24);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.12);
        color: #ffffff;
        box-shadow: 0 12px 26px rgba(7, 14, 31, 0.24);
    }

    .business-login-logo-mark .rzi {
        color: #ffffff !important;
        font-size: 1.42rem !important;
    }

    .business-login-brand {
        font-size: 1.12rem;
        font-weight: 800;
        line-height: 1.1;
    }

    .business-login-welcome {
        margin-top: 0.22rem;
        color: rgba(255, 255, 255, 0.76);
        font-size: 0.78rem;
        font-weight: 600;
    }

    .business-login-caption {
        margin-top: 1.05rem;
        color: rgba(255, 255, 255, 0.74);
        font-size: 0.76rem;
        font-weight: 500;
        line-height: 1.45;
        max-width: 310px;
    }

    .business-login-body {
        position: relative;
        z-index: 2;
        width: 100%;
        padding: 1.45rem 1.65rem 1.7rem;
        background:
            linear-gradient(180deg, #ffffff 0%, var(--business-login-soft) 100%);
