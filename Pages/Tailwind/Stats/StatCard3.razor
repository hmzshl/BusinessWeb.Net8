<div class="business-stat-card" style="@GetAccentStyle()">
    <div class="business-stat-accent"></div>
    <div class="business-stat-content">
        <div class="business-stat-copy">
            <p class="business-stat-title">@Title</p>
            <h3 class="business-stat-value">@Value</h3>
        </div>
        <div class="business-stat-icon">
            @if (IconContent is not null)
            {
                @IconContent
            }
            else
            {
                <span class="business-stat-dot"></span>
            }
        </div>
    </div>
    @if (ShowTrendText)
    {
        <div class="business-stat-trend">
            <span class="@GetTrendColor() business-stat-trend-value">
                @if (IsPositiveTrend)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" class="business-stat-trend-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
                    </svg>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" class="business-stat-trend-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                    </svg>
                }
                @TrendValue
            </span>
            <span class="business-stat-trend-text">@TrendText</span>
        </div>
    }
</div>

<style>
    .business-stat-card {
        position: relative;
        width: 100%;
        min-height: 92px;
        margin: 5px;
        padding: 10px 12px;
        border: 1px solid #dbe3ef;
        border-radius: 8px;
        background: linear-gradient(180deg, #ffffff 0%, #f7f9fc 100%);
        box-shadow: 0 14px 34px rgba(15, 23, 42, 0.10);
        color: #203154;
        overflow: hidden;
        transition: border-color 160ms ease, box-shadow 160ms ease, transform 160ms ease;
        font-family: "Ubuntu", system-ui, -apple-system, "Segoe UI", sans-serif;
    }

    .business-stat-card :not(svg):not(path) {
        font-family: "Ubuntu", system-ui, -apple-system, "Segoe UI", sans-serif;
    }

    .business-stat-card:hover {
        border-color: var(--business-stat-accent);
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.14);
        transform: translateY(-1px);
    }

    .business-stat-accent {
        position: absolute;
        inset: 0 auto 0 0;
        width: 4px;
        background: var(--business-stat-accent);
    }

    .business-stat-card::after {
        content: "";
        position: absolute;
        right: 0;
        top: 0;
        width: 86px;
        height: 86px;
        background: var(--business-stat-soft);
        border-bottom-left-radius: 80px;
        pointer-events: none;
    }

    .business-stat-content {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
    }

    .business-stat-copy {
        min-width: 0;
    }

    .business-stat-title {
        margin: 0;
        color: #64748b;
        font-size: 0.58rem;
        font-weight: 700;
        line-height: 1.15;
        text-transform: uppercase;
    }

    .business-stat-value {
        margin: 4px 0 0;
        color: #203154;
        font-size: 1.02rem;
        font-weight: 800;
        line-height: 1.15;
        overflow-wrap: anywhere;
    }

    .business-stat-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        flex: 0 0 28px;
        border: 1px solid var(--business-stat-border);
        border-radius: 8px;
        background: var(--business-stat-soft);
        color: var(--business-stat-accent);
    }

    .business-stat-icon svg {
        width: 16px;
        height: 16px;
    }

    .business-stat-dot {
        width: 9px;
        height: 9px;
        border-radius: 999px;
        background: var(--business-stat-accent);
        box-shadow: 0 0 0 4px var(--business-stat-ring);
    }

    .business-stat-trend {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        gap: 7px;
        margin-top: 10px;
        font-size: 0.66rem;
        line-height: 1.25;
    }

    .business-stat-trend-value {
        display: inline-flex;
        align-items: center;
        font-weight: 800;
    }

    .business-stat-trend-icon {
        width: 12px;
        height: 12px;
        margin-right: 3px;
    }

    .business-stat-trend-text {
        color: #64748b;
        font-weight: 600;
    }
</style>

@code {
    [Parameter]
    public bool ShowTrendText { get; set; }

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Value { get; set; } = string.Empty;

    [Parameter]
    public string TrendValue { get; set; } = string.Empty;

    [Parameter]
    public bool IsPositiveTrend { get; set; } = true;

    [Parameter]
    public string TrendText { get; set; } = "vs last month";

    [Parameter]
    public StatColor Color { get; set; } = StatColor.Blue;

    [Parameter]
    public RenderFragment? IconContent { get; set; }

    private string GetAccentStyle()
    {
        return Color switch
        {
            StatColor.Blue => "--business-stat-accent:#2563eb;--business-stat-soft:#eff6ff;--business-stat-border:#bfdbfe;--business-stat-ring:rgba(37,99,235,0.14);",
            StatColor.Green => "--business-stat-accent:#16a34a;--business-stat-soft:#f0fdf4;--business-stat-border:#bbf7d0;--business-stat-ring:rgba(22,163,74,0.14);",
            StatColor.Purple => "--business-stat-accent:#7c3aed;--business-stat-soft:#f5f3ff;--business-stat-border:#ddd6fe;--business-stat-ring:rgba(124,58,237,0.14);",
            StatColor.Amber => "--business-stat-accent:#d97706;--business-stat-soft:#fffbeb;--business-stat-border:#fde68a;--business-stat-ring:rgba(217,119,6,0.16);",
            StatColor.Red => "--business-stat-accent:#dc2626;--business-stat-soft:#fef2f2;--business-stat-border:#fecaca;--business-stat-ring:rgba(220,38,38,0.14);",
            _ => "--business-stat-accent:#2563eb;--business-stat-soft:#eff6ff;--business-stat-border:#bfdbfe;--business-stat-ring:rgba(37,99,235,0.14);"
        };
    }

    private string GetTrendColor()
    {
        return IsPositiveTrend ? "text-green-500" : "text-red-500";
    }
}
